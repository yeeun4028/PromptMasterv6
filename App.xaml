<Application x:Class="PromptMasterv5.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PromptMasterv5"
             xmlns:models="clr-namespace:PromptMasterv5.Models">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 1. HandyControl 默认主题 -->
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>

                <!-- 2. ★★★ 新增：GitHub Markdown 主题 ★★★ -->
                <ResourceDictionary Source="Themes/GitHubMarkdownTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ===============================================
                 以下是项目原有的本地资源，保持不变
                 =============================================== -->

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

            <DropShadowEffect x:Key="EffectShadow2" Color="#000000" Direction="270" ShadowDepth="4" BlurRadius="10" Opacity="0.4"/>

            <SolidColorBrush x:Key="MiniBackgroundBrush" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="MiniTextBrush" Color="#DEDEDE"/>
            <SolidColorBrush x:Key="MiniSearchBackgroundBrush" Color="#252526"/>
            <SolidColorBrush x:Key="MiniHighlightBrush" Color="#3C3C3C"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#4183C4"/>
            <SolidColorBrush x:Key="MiniModeBtnInactiveBrush" Color="#8A8A8A"/>
            <SolidColorBrush x:Key="MiniModeBtnActiveBrush" Color="#B0B0B0"/>

            <SolidColorBrush x:Key="ShellBackground" Color="#FAFAFA"/>
            <SolidColorBrush x:Key="Block1Background" Color="#F1F1EF"/>
            <SolidColorBrush x:Key="Block2Background" Color="#F1F1EF"/>
            <SolidColorBrush x:Key="Block3Background" Color="#FAFAFA"/>
            <SolidColorBrush x:Key="Block4Background" Color="#FAFAFA"/>

            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#333333"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#666666"/>
            <SolidColorBrush x:Key="PlaceholderTextBrush" Color="#999999"/>

            <SolidColorBrush x:Key="DividerBrush" Color="#E0E0E0"/>

            <SolidColorBrush x:Key="ActionIconBrush" Color="#898888"/>
            <SolidColorBrush x:Key="ActionIconHoverBrush" Color="#000000"/>
            <SolidColorBrush x:Key="HeaderIconBrush" Color="#666666"/>
            <SolidColorBrush x:Key="HeaderIconHoverBrush" Color="#333333"/>

            <SolidColorBrush x:Key="InputFocusBackgroundBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="ListItemHoverBackgroundBrush" Color="#EAEAEA"/>
            <SolidColorBrush x:Key="ListItemSelectedBackgroundBrush" Color="#E0E0E0"/>

            <SolidColorBrush x:Key="AppBackground" Color="#F1F1EF"/>
            <SolidColorBrush x:Key="SidebarBackground" Color="#F7F7F7"/>
            <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextPrimary" Color="#333333"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#666666"/>
            <SolidColorBrush x:Key="DividerColor" Color="#E5E5E5"/>
            <SolidColorBrush x:Key="HintBrush" Color="#999999"/>

            <Style x:Key="MiniTextBoxStyle" TargetType="TextBox">
                <Setter Property="Background" Value="#363B40"/>
                <Setter Property="Foreground" Value="{StaticResource MiniTextBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CaretBrush" Value="#DEDEDE"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>

                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="AcceptsReturn" Value="True"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Hidden"/>

                <Setter Property="VerticalContentAlignment" Value="Top"/>

                <Setter Property="Padding" Value="4"/>
                <Setter Property="TextBlock.LineHeight" Value="25.6"/>
                <Setter Property="TextBlock.LineStackingStrategy" Value="BlockLineHeight"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}">
                                <ScrollViewer x:Name="PART_ContentHost" Background="Transparent" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="MiniModeButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="4,0"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource MiniModeBtnInactiveBrush}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1FFFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#26FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
