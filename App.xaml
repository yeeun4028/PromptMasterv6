<Application x:Class="PromptMasterv5.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PromptMasterv5">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 1. HandyControl 默认主题 -->
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>

                <!-- 2. ★★★ 新增：GitHub Markdown 主题 ★★★ -->
                <ResourceDictionary Source="Themes/GitHubMarkdownTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ===============================================
                 以下是项目原有的本地资源，保持不变
                 =============================================== -->

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <local:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

            <DropShadowEffect x:Key="EffectShadow2" Color="#000000" Direction="270" ShadowDepth="4" BlurRadius="10" Opacity="0.4"/>

            <SolidColorBrush x:Key="ShellBackground" Color="#2E3033"/>
            <SolidColorBrush x:Key="AppBackground" Color="#2E3033"/>
            <SolidColorBrush x:Key="SidebarBackground" Color="#363B40"/>
            <SolidColorBrush x:Key="CardBackground" Color="#363B40"/>

            <SolidColorBrush x:Key="Block1Background" Color="#E8E7E7"/>
            <SolidColorBrush x:Key="Block2Background" Color="#E8E7E7"/>
            <SolidColorBrush x:Key="Block3Background" Color="#EDEDED"/>
            <SolidColorBrush x:Key="Block4Background" Color="#EDEDED"/>

            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E6E8EA"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B0B4B8"/>
            <SolidColorBrush x:Key="PlaceholderTextBrush" Color="#8A8F96"/>
            <SolidColorBrush x:Key="DividerBrush" Color="#4A4F55"/>
            <SolidColorBrush x:Key="ListItemHoverBackgroundBrush" Color="#3A3F45"/>
            <SolidColorBrush x:Key="ListItemSelectedBackgroundBrush" Color="#444A52"/>
            <SolidColorBrush x:Key="InputFocusBackgroundBrush" Color="#2E3033"/>

            <SolidColorBrush x:Key="TextPrimary" Color="#E6E8EA"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#B0B4B8"/>
            <SolidColorBrush x:Key="DividerColor" Color="#4A4F55"/>
            <SolidColorBrush x:Key="HintBrush" Color="#8A8F96"/>

            <SolidColorBrush x:Key="ActionIconBrush" Color="#B0B4B8"/>
            <SolidColorBrush x:Key="ActionIconHoverBrush" Color="#E6E8EA"/>
            <SolidColorBrush x:Key="HeaderIconBrush" Color="#B0B4B8"/>
            <SolidColorBrush x:Key="HeaderIconHoverBrush" Color="#E6E8EA"/>

            <SolidColorBrush x:Key="MiniBackgroundBrush" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="MiniTextBrush" Color="#E0E0E0"/>
            <SolidColorBrush x:Key="MiniSearchBackgroundBrush" Color="#252526"/>
            <SolidColorBrush x:Key="MiniHighlightBrush" Color="#3C3C3C"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#4183C4"/>
            <SolidColorBrush x:Key="MiniModeBtnInactiveBrush" Color="#B0B4B8"/>
            <SolidColorBrush x:Key="MiniModeBtnActiveBrush" Color="#4183C4"/>

            <Style x:Key="MiniModeButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource MiniModeBtnInactiveBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="6,2"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource MiniHighlightBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource MiniHighlightBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="MiniTextBoxStyle" TargetType="TextBox">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource MiniTextBrush}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CaretBrush" Value="White"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>

                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="AcceptsReturn" Value="True"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Hidden"/>

                <Setter Property="VerticalContentAlignment" Value="Center"/>

                <Setter Property="Padding" Value="5,2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <ScrollViewer x:Name="PART_ContentHost" Background="Transparent"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
