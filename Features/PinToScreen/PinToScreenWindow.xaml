<Window x:Class="PromptMasterv6.Features.PinToScreen.PinToScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="贴图"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        MouseDown="Window_MouseDown">

    <Grid x:Name="RootGrid">
        <Border x:Name="ImageBorder"
                Background="Transparent"
                BorderBrush="{Binding BorderColor, RelativeSource={RelativeSource AncestorType=Window}}"
                BorderThickness="{Binding BorderSize, RelativeSource={RelativeSource AncestorType=Window}}"
                CornerRadius="4">
            <Border.Effect>
                <DropShadowEffect x:Name="ShadowEffect"
                                  Color="Black"
                                  BlurRadius="15"
                                  ShadowDepth="3"
                                  Opacity="0.3"
                                  Direction="315"/>
            </Border.Effect>

            <Image x:Name="PinnedImage"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>
    </Grid>
</Window>
