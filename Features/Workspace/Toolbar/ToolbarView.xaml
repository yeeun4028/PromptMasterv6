<UserControl x:Class="PromptMasterv6.Features.Workspace.Toolbar.ToolbarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:PromptMasterv6.Infrastructure.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="600">

    <UserControl.Resources>
        <converters:StringToGeometryConverter x:Key="StringToGeometryConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Geometry x:Key="IconCopyThin">M20 2H10c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H10V4h10v12zM4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6z</Geometry>
        <Geometry x:Key="IconGitHub">M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z</Geometry>
    </UserControl.Resources>

    <Grid Margin="20,0,20,6">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <ItemsControl ItemsSource="{Binding WebDirectTargets}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.OpenWebTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                ToolTip="{Binding Name}"
                                Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,8,0"
                                Padding="6,4"
                                Cursor="Hand"
                                Background="Transparent"
                                BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path x:Name="Icon" 
                                                  Data="{Binding IconData, Converter={StaticResource StringToGeometryConverter}}"
                                                  Visibility="{Binding IconData, Converter={StaticResource StringVisibilityConverter}}"
                                                  Fill="{DynamicResource ActionIconBrush}"
                                                  Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="Label" Text="{Binding Name}" 
                                                       Foreground="{DynamicResource SecondaryTextBrush}" 
                                                       FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"
                                                       FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                            <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                                            <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Command="{Binding SearchOnGitHubCommand}"
                    ToolTip="在 GitHub 上搜索 (仅搜索此输入框内容)"
                    Margin="0,0,0,0"
                    Padding="6,4"
                    Cursor="Hand"
                    Background="Transparent"
                    BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Path x:Name="Icon" 
                                      Data="{StaticResource IconGitHub}"
                                      Fill="{DynamicResource ActionIconBrush}"
                                      Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                                <TextBlock x:Name="Label" Text="GitHub" 
                                           Foreground="{DynamicResource SecondaryTextBrush}" 
                                           FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"
                                           FontFamily="Segoe UI, Microsoft YaHei UI"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                                <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <Button Command="{Binding CopyCompiledTextCommand}"
                ToolTip="复制最终结果 (Ctrl+C)"
                HorizontalAlignment="Right"
                Margin="0,0,0,0"
                Padding="6,4"
                Cursor="Hand"
                Background="Transparent"
                BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <Path x:Name="Icon" 
                              Data="{StaticResource IconCopyThin}"
                              Fill="{DynamicResource ActionIconBrush}"
                              Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                            <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
