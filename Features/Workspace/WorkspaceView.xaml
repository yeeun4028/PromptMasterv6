<UserControl x:Class="PromptMasterv6.Features.Workspace.WorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:md="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:converters="clr-namespace:PromptMasterv6.Infrastructure.Converters"
             xmlns:utils="clr-namespace:PromptMasterv6.Infrastructure.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="700">

    <UserControl.Resources>
        <utils:StringToGeometryConverter x:Key="StringToGeometryConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Geometry x:Key="IconCopyThin">M20 2H10c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H10V4h10v12zM4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6z</Geometry>
        <Geometry x:Key="IconGitHub">M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z</Geometry>

        <Style x:Key="Block4MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}" 
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="ContentPresenter" 
                                              Content="{TemplateBinding Header}" 
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              ContentStringFormat="{TemplateBinding HeaderStringFormat}"
                                              RecognizesAccessKey="True" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemSelectedBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NoIconSeparatorStyle" TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="{TemplateBinding Height}" 
                                Background="{TemplateBinding Background}" 
                                Margin="{TemplateBinding Margin}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Block4EditorContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Padding" Value="0,4"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource Block4MenuItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="12" Opacity="0.3"/>
                            </Border.Effect>
                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ContextMenu x:Key="Block4EditorContextMenu" x:Shared="False" Style="{StaticResource Block4EditorContextMenuStyle}">
            <MenuItem Command="ApplicationCommands.Cut" Header="剪切" InputGestureText=""/>
            <MenuItem Command="ApplicationCommands.Copy" Header="复制" InputGestureText=""/>
            <MenuItem Command="ApplicationCommands.Paste" Header="粘贴" InputGestureText=""/>
            <Separator Style="{StaticResource NoIconSeparatorStyle}"/>
            <MenuItem Command="ApplicationCommands.SelectAll" Header="全选" InputGestureText=""/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Block3Background}">
        <Grid.Resources>
            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="0"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="Transparent"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="ScrollViewer">
                <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="7*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <!-- 空状态占位提示 -->
        <TextBlock Grid.Row="0"
                   Text="请在左侧选择或新建提示词"
                   FontSize="16"
                   Foreground="{DynamicResource PlaceholderTextBrush}"
                   FontFamily="Segoe UI, Microsoft YaHei UI"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedFile}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <Grid Grid.Row="0" Margin="20,0,4,0" TextElement.Foreground="{DynamicResource Block3EditorTextBrush}" TextElement.FontFamily="Segoe UI, Microsoft YaHei UI">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedFile}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid>
                <TextBox x:Name="Block3ContentEditor"
                         Margin="0,0,0,0"
                         ContextMenu="{DynamicResource Block4EditorContextMenu}"
                         Text="{Binding SelectedFile.Content, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource Block3EditorTextBrush}"
                         CaretBrush="{DynamicResource Block3EditorCaretBrush}"
                         SelectionBrush="{DynamicResource Block3EditorSelectionBrush}"
                         SelectionOpacity="1"
                         FontSize="13"
                         TextOptions.TextFormattingMode="Ideal"
                         TextOptions.TextRenderingMode="ClearType"
                         Padding="5"
                         FontFamily="Segoe UI, Microsoft YaHei UI"
                         hc:InfoElement.Placeholder="在此处键入提示词内容...">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>

            <md:MarkdownViewer Margin="0,0,0,0"
                              Markdown="{Binding PreviewContent}"
                              Pipeline="{Binding Pipeline}"
                              xml:lang="zh-CN"
                              Background="{DynamicResource Block3Background}">
                <md:MarkdownViewer.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#4A89DC"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#B8BFC6"/>

                    <Style TargetType="FlowDocumentScrollViewer">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>

                    <Style x:Key="{x:Static md:Styles.ParagraphStyleKey}" TargetType="{x:Type Paragraph}">
                        <Setter Property="LineHeight" Value="30"/>
                        <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
                        <Setter Property="Margin" Value="0,0,0,12"/>
                    </Style>

                    <Style x:Key="{x:Static md:Styles.DocumentStyleKey}" TargetType="{x:Type FlowDocument}">
                        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Foreground" Value="{DynamicResource Block3EditorTextBrush}"/>
                        <Setter Property="TextAlignment" Value="Left"/>
                        <Setter Property="PagePadding" Value="30,0,30,50"/>
                        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
                        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </md:MarkdownViewer.Resources>
                <md:MarkdownViewer.Style>
                    <Style TargetType="md:MarkdownViewer">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Setter Property="Margin" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </md:MarkdownViewer.Style>
            </md:MarkdownViewer>
            <TextBlock Margin="5,5,5,5"
                       Text="在此处键入内容..."
                       Foreground="{DynamicResource PlaceholderTextBrush}"
                       FontFamily="Segoe UI, Microsoft YaHei UI"
                       FontSize="14"
                       IsHitTestVisible="False"
                       VerticalAlignment="Top">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedFile.Content}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SelectedFile.Content}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <Border Grid.Row="1" Height="1" Background="{DynamicResource DividerBrush}" VerticalAlignment="Center" IsHitTestVisible="False"/>
        <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent" ResizeBehavior="PreviousAndNext" ShowsPreview="True"/>

        <Border Grid.Row="2" Background="{DynamicResource Block4Background}">
            <Grid Margin="20,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Web Direct Targets -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ItemsControl ItemsSource="{Binding Config.WebDirectTargets}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.OpenWebTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding Name}"
                                            Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}"
                                            Margin="0,0,8,0"
                                            Padding="6,4"
                                            Cursor="Hand"
                                            Background="Transparent"
                                            BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path x:Name="Icon" 
                                                              Data="{Binding IconData, Converter={StaticResource StringToGeometryConverter}}"
                                                              Visibility="{Binding IconData, Converter={StaticResource StringVisibilityConverter}}"
                                                              Fill="{DynamicResource ActionIconBrush}"
                                                              Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="Label" Text="{Binding Name}" 
                                                                   Foreground="{DynamicResource SecondaryTextBrush}" 
                                                                   FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"
                                                                   FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                        <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                                                        <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- GitHub Search Button -->
                        <Button Command="{Binding SearchOnGitHubCommand}"
                                ToolTip="在 GitHub 上搜索 (仅搜索此输入框内容)"
                                Margin="0,0,0,0"
                                Padding="6,4"
                                Cursor="Hand"
                                Background="Transparent"
                                BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path x:Name="Icon" 
                                                  Data="{StaticResource IconGitHub}"
                                                  Fill="{DynamicResource ActionIconBrush}"
                                                  Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="Label" Text="GitHub" 
                                                       Foreground="{DynamicResource SecondaryTextBrush}" 
                                                       FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"
                                                       FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                            <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                                            <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <!-- Copy Result Button -->
                    <Button Command="{Binding CopyCompiledTextCommand}"
                            ToolTip="复制最终结果 (Ctrl+C)"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,0"
                            Padding="6,4"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <Path x:Name="Icon" 
                                          Data="{StaticResource IconCopyThin}"
                                          Fill="{DynamicResource ActionIconBrush}"
                                          Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                        <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" BorderThickness="0">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasVariables}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding Variables}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name, StringFormat='{}{0}:'}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Top" Margin="0,6,10,0" HorizontalAlignment="Right" Foreground="{DynamicResource PrimaryTextBrush}" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                    <Border x:Name="InputBorder" Grid.Column="1" BorderThickness="0" Background="Transparent" CornerRadius="2,2,0,0">
                                        <TextBox x:Name="InputBox" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Padding="5" FontSize="14" ContextMenu="{DynamicResource Block4EditorContextMenu}" VerticalContentAlignment="Top" AcceptsReturn="True" TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" FontFamily="Segoe UI, Microsoft YaHei UI" Style="{x:Null}"/>
                                    </Border>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="InputBox" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="InputBorder" Property="Background" Value="{DynamicResource InputFocusBackgroundBrush}"/>
                                        <Setter TargetName="InputBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                        <Setter TargetName="InputBorder" Property="BorderThickness" Value="0,0,0,1"/>
                                    </Trigger>
                                    <Trigger SourceName="InputBox" Property="IsKeyboardFocused" Value="True">
                                        <Setter TargetName="InputBorder" Property="Background" Value="{DynamicResource InputFocusBackgroundBrush}"/>
                                        <Setter TargetName="InputBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                        <Setter TargetName="InputBorder" Property="BorderThickness" Value="0,0,0,1"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBox Grid.Row="1" Text="{Binding AdditionalInput, UpdateSourceTrigger=PropertyChanged}" 
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         CaretBrush="{DynamicResource PrimaryTextBrush}"
                         AcceptsReturn="True" 
                         TextWrapping="Wrap" 
                         Padding="10" 
                         BorderThickness="0" 
                         Background="Transparent" 
                         VerticalContentAlignment="Top" 
                         ContextMenu="{DynamicResource Block4EditorContextMenu}"
                         FontSize="14" 
                         FontFamily="Segoe UI, Microsoft YaHei UI">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasVariables}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
