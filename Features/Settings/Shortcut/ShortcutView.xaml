<UserControl x:Class="PromptMasterv6.Features.Settings.Shortcut.ShortcutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:behaviors="clr-namespace:PromptMasterv6.Infrastructure.Behaviors"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500">
    <StackPanel Margin="0,0,0,14">
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="完整窗口" Style="{StaticResource FieldLabelTextStyle}" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" 
                             Style="{StaticResource KeyRecorderStyle}"
                             Width="140"
                             IsReadOnly="True"
                             Cursor="Hand"
                             VerticalAlignment="Center"
                             behaviors:HotkeyCapture.Enabled="True"
                             behaviors:HotkeyCapture.Hotkey="{Binding Config.FullWindowHotkey, Mode=TwoWay}"
                             ToolTip="点击按下按键设置，按 Delete 清除"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="截图翻译" Style="{StaticResource FieldLabelTextStyle}"/>
                    </StackPanel>
                    <TextBox Grid.Row="0" Grid.Column="1" 
                             Style="{StaticResource KeyRecorderStyle}"
                             Width="140"
                             IsReadOnly="True"
                             Cursor="Hand"
                             VerticalAlignment="Center"
                             behaviors:HotkeyCapture.Enabled="True"
                             behaviors:HotkeyCapture.Hotkey="{Binding Config.ScreenshotTranslateHotkey, Mode=TwoWay}"
                             ToolTip="点击按下按键设置，按 Delete 清除"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="OCR 识别" Style="{StaticResource FieldLabelTextStyle}"/>
                    </StackPanel>
                    <TextBox Grid.Row="0" Grid.Column="1" 
                             Style="{StaticResource KeyRecorderStyle}"
                             Width="140"
                             IsReadOnly="True"
                             Cursor="Hand"
                             VerticalAlignment="Center"
                             behaviors:HotkeyCapture.Enabled="True"
                             behaviors:HotkeyCapture.Hotkey="{Binding Config.OcrHotkey, Mode=TwoWay}"
                             ToolTip="点击按下按键设置，按 Delete 清除"/>
                </Grid>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="贴图（截图）" Style="{StaticResource FieldLabelTextStyle}"/>
                    </StackPanel>
                    <TextBox Grid.Row="0" Grid.Column="1" 
                             Style="{StaticResource KeyRecorderStyle}"
                             Width="140"
                             IsReadOnly="True"
                             Cursor="Hand"
                             VerticalAlignment="Center"
                             behaviors:HotkeyCapture.Enabled="True"
                             behaviors:HotkeyCapture.Hotkey="{Binding Config.PinToScreenHotkey, Mode=TwoWay}"
                             ToolTip="点击按下按键设置，按 Delete 清除"/>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
