<UserControl x:Class="PromptMasterv6.Features.Settings.ApiCredentials.ApiCredentialsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="700">
    <UserControl.Resources>
        <Style x:Key="ProviderTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="0,0,0,2" 
                                BorderBrush="Transparent" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Selected">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="百度" Padding="12,6" Margin="0,0,8,0"
                    Command="{Binding SelectProviderTabCommand}" CommandParameter="0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ProviderTabButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedProviderTab}" Value="0">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="腾讯" Padding="12,6" Margin="0,0,8,0"
                    Command="{Binding SelectProviderTabCommand}" CommandParameter="1">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ProviderTabButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedProviderTab}" Value="1">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="有道" Padding="12,6" Margin="0,0,8,0"
                    Command="{Binding SelectProviderTabCommand}" CommandParameter="2">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ProviderTabButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedProviderTab}" Value="2">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Google" Padding="12,6" Margin="0,0,8,0"
                    Command="{Binding SelectProviderTabCommand}" CommandParameter="3">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ProviderTabButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedProviderTab}" Value="3">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Baidu Panel -->
                <StackPanel Grid.Row="0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedProviderTab}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="百度 OCR 配置" Style="{StaticResource SectionHeaderTextStyle}"/>
                            
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="API Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox Text="{Binding BaiduOcrApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Secret Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox Text="{Binding BaiduOcrSecretKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding BaiduOcrTestStatus}"
                                           Foreground="{Binding BaiduOcrTestStatusColor}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,10,0"/>
                                <Button Grid.Column="1"
                                        Content="测试连接"
                                        Command="{Binding TestBaiduOcrCommand}"
                                        Style="{StaticResource TextLinkButtonStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="百度翻译配置" Style="{StaticResource SectionHeaderTextStyle}"/>
                            
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="App ID" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox Text="{Binding BaiduTranslateAppId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Secret Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox Text="{Binding BaiduTranslateSecretKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding BaiduTranslateTestStatus}"
                                           Foreground="{Binding BaiduTranslateTestStatusColor}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,10,0"/>
                                <Button Grid.Column="1"
                                        Content="测试连接"
                                        Command="{Binding TestBaiduTranslateCommand}"
                                        Style="{StaticResource TextLinkButtonStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Tencent Panel -->
                <StackPanel Grid.Row="1">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedProviderTab}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="腾讯云 OCR 配置" Style="{StaticResource SectionHeaderTextStyle}"/>
                            
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Secret Id" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox Text="{Binding TencentOcrSecretId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Secret Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox Text="{Binding TencentOcrSecretKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding TencentOcrTestStatus}"
                                           Foreground="{Binding TencentOcrTestStatusColor}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,10,0"/>
                                <Button Grid.Column="1"
                                        Content="测试连接"
                                        Command="{Binding TestTencentOcrCommand}"
                                        Style="{StaticResource TextLinkButtonStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="腾讯云翻译配置" Style="{StaticResource SectionHeaderTextStyle}"/>
                            
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Secret Id" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox Text="{Binding TencentTranslateSecretId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Secret Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox Text="{Binding TencentTranslateSecretKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding TencentTranslateTestStatus}"
                                           Foreground="{Binding TencentTranslateTestStatusColor}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,10,0"/>
                                <Button Grid.Column="1"
                                        Content="测试连接"
                                        Command="{Binding TestTencentTranslateCommand}"
                                        Style="{StaticResource TextLinkButtonStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Youdao Panel -->
                <StackPanel Grid.Row="2">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedProviderTab}" Value="2">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="有道 OCR 配置" Style="{StaticResource SectionHeaderTextStyle}"/>
                            
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="App Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox Text="{Binding YoudaoOcrAppKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="App Secret" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox Text="{Binding YoudaoOcrAppSecret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="有道翻译配置" Style="{StaticResource SectionHeaderTextStyle}"/>
                            
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="App Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox Text="{Binding YoudaoTranslateAppKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="App Secret" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox Text="{Binding YoudaoTranslateAppSecret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding YoudaoTestStatus}"
                                           Foreground="{Binding YoudaoTestStatusColor}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,10,0"/>
                                <Button Grid.Column="1"
                                        Content="测试连接"
                                        Command="{Binding TestYoudaoCommand}"
                                        Style="{StaticResource TextLinkButtonStyle}"
                                        IsEnabled="False"/>
                            </Grid>

                            <TextBlock Text="注意：有道后端集成将在未来版本中实现。"
                                       Style="{StaticResource HintTextStyle}" Margin="0,10,0,0" Foreground="#FFA500"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Google Panel -->
                <StackPanel Grid.Row="3">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedProviderTab}" Value="3">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Google 翻译配置" Style="{StaticResource SectionHeaderTextStyle}"/>
                            
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="API Base URL (可选, 支持 Cloudflare 代理)" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox Text="{Binding GoogleBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"
                                         ToolTip="默认为 https://translation.googleapis.com。自定义地址示例：https://my-proxy.workers.dev"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="API Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                <TextBox Text="{Binding GoogleApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding GoogleTestStatus}"
                                           Foreground="{Binding GoogleTestStatusColor}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,10,0"/>
                                <Button Grid.Column="1"
                                        Content="测试连接"
                                        Command="{Binding TestGoogleCommand}"
                                        Style="{StaticResource TextLinkButtonStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
