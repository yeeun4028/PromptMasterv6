<Window x:Class="PromptMasterv6.Features.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PromptMasterv6.Features.Settings"
        Title="设置"
        Width="900" Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Closing="Window_Closing"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Auto">
    <Grid Background="#01000000" PreviewMouseRightButtonDown="Grid_PreviewMouseRightButtonDown" UseLayoutRounding="True">
        <views:SettingsView x:Name="SettingsViewContent"/>
    </Grid>
</Window>
