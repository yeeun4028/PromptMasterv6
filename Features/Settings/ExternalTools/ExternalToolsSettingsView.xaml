<UserControl x:Class="PromptMasterv6.Features.Settings.ExternalTools.ExternalToolsSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:PromptMasterv6.Infrastructure.Converters"
             xmlns:apiCredentials="clr-namespace:PromptMasterv6.Features.Settings.ApiCredentials"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="700">
    <UserControl.Resources>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="主界面" Padding="12,6" Margin="0,0,8,0" 
                    Command="{Binding SelectSubTabCommand}" CommandParameter="0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SubTabButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSubTab}" Value="0">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="API 配置" Padding="12,6" Margin="0,0,8,0"
                    Command="{Binding SelectSubTabCommand}" CommandParameter="1">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SubTabButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSubTab}" Value="1">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="AI 翻译配置" Padding="12,6" Margin="0,0,8,0"
                    Command="{Binding SelectSubTabCommand}" CommandParameter="2">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SubTabButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSubTab}" Value="2">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSubTab}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="OCR 识别引擎" Style="{StaticResource SectionHeaderTextStyle}"/>
                            
                            <ItemsControl ItemsSource="{Binding ExternalToolsVM.OcrProfiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <CheckBox IsChecked="{Binding IsEnabled}" 
                                                      Style="{StaticResource ToggleSwitchStyle}" 
                                                      Cursor="Hand" 
                                                      VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" 
                                                       VerticalAlignment="Center" 
                                                       Margin="12,0,0,0" 
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       FontSize="14"/>
                                            <TextBlock Text="{Binding ProviderDisplayName, StringFormat='({0})'}" 
                                                       VerticalAlignment="Center" 
                                                       Margin="8,0,0,0" 
                                                       Foreground="{DynamicResource TextSecondary}" 
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="翻译引擎" Style="{StaticResource SectionHeaderTextStyle}"/>
                            
                            <ItemsControl ItemsSource="{Binding ExternalToolsVM.TranslateProfiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <CheckBox IsChecked="{Binding IsEnabled}" 
                                                      Style="{StaticResource ToggleSwitchStyle}" 
                                                      Cursor="Hand" 
                                                      VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}" 
                                                       VerticalAlignment="Center" 
                                                       Margin="12,0,0,0" 
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       FontSize="14"/>
                                            <TextBlock Text="{Binding ProviderDisplayName, StringFormat='({0})'}" 
                                                       VerticalAlignment="Center" 
                                                       Margin="8,0,0,0" 
                                                       Foreground="{DynamicResource TextSecondary}" 
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="快捷设置" Style="{StaticResource SectionHeaderTextStyle}"/>
                            
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="翻译后自动复制结果" 
                                               VerticalAlignment="Center" 
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="14"/>
                                    <TextBlock Text="翻译完成后自动将结果复制到剪贴板" 
                                               VerticalAlignment="Center" 
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="12"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                
                                <CheckBox Grid.Column="1" 
                                          IsChecked="{Binding Config.AutoCopyTranslationResult}" 
                                          Style="{StaticResource ToggleSwitchStyle}" 
                                          Cursor="Hand" 
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <ContentControl Visibility="{Binding Config.SavedModels.Count, Converter={StaticResource CountToVisibilityConverter}}">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="AI 视觉翻译" Style="{StaticResource SectionHeaderTextStyle}"/>
                                
                                <TextBlock Text="启用后可跳过 OCR，直接发送图片给 AI 进行翻译" 
                                           Style="{StaticResource HintTextStyle}"
                                           Margin="0,0,0,15"
                                           TextWrapping="Wrap"/>
                                
                                <ItemsControl ItemsSource="{Binding Config.SavedModels}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <CheckBox IsChecked="{Binding IsEnableForScreenshotTranslate}" 
                                                          Style="{StaticResource ToggleSwitchStyle}" 
                                                          Cursor="Hand" 
                                                          VerticalAlignment="Center"
                                                          ToolTip="启用截图直译 (跳过 OCR，直接发送图片给 AI)"/>
                                                <TextBlock Text="{Binding DisplayName}" 
                                                           VerticalAlignment="Center" 
                                                           Margin="12,0,0,0" 
                                                           Foreground="{DynamicResource TextPrimary}" 
                                                           FontWeight="Medium"
                                                           FontSize="14"/>
                                                <TextBlock Text="[Vision-to-Text]" 
                                                           VerticalAlignment="Center" 
                                                           Margin="8,0,0,0" 
                                                           Foreground="{DynamicResource HintBrush}" 
                                                           FontSize="11"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </ContentControl>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSubTab}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <apiCredentials:ApiCredentialsView DataContext="{Binding ApiCredentialsVM}"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedSubTab}" Value="2">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="AI 翻译模型" Style="{StaticResource SectionHeaderTextStyle}"/>
                            
                            <ItemsControl ItemsSource="{Binding Config.SavedModels}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <CheckBox IsChecked="{Binding IsEnableForTranslation}" 
                                                      Style="{StaticResource ToggleSwitchStyle}" 
                                                      Cursor="Hand" 
                                                      VerticalAlignment="Center" 
                                                      ToolTip="启用翻译"/>
                                            <TextBlock Text="{Binding DisplayName}" 
                                                       VerticalAlignment="Center" 
                                                       Margin="12,0,0,0" 
                                                       Foreground="{DynamicResource TextPrimary}" 
                                                       FontWeight="Medium"
                                                       FontSize="14"/>
                                            <TextBlock Text="{Binding BaseUrl}" 
                                                       VerticalAlignment="Center" 
                                                       Margin="10,0,0,0" 
                                                       Foreground="{DynamicResource TextSecondary}" 
                                                       FontSize="11" 
                                                       Opacity="0.5" 
                                                       TextTrimming="CharacterEllipsis" 
                                                       MaxWidth="200"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Config.SavedModels.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="AI OCR 模型" Style="{StaticResource SectionHeaderTextStyle}"/>
                            
                            <TextBlock Text="需要支持 Vision 能力的模型" 
                                       Style="{StaticResource HintTextStyle}"
                                       Margin="0,0,0,15"
                                       TextWrapping="Wrap"/>
                            
                            <ItemsControl ItemsSource="{Binding Config.SavedModels}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <CheckBox IsChecked="{Binding IsEnableForOcr}" 
                                                      Style="{StaticResource ToggleSwitchStyle}" 
                                                      Cursor="Hand" 
                                                      VerticalAlignment="Center" 
                                                      ToolTip="启用 OCR (需支持 Vision 能力的模型)"/>
                                            <TextBlock Text="{Binding DisplayName}" 
                                                       VerticalAlignment="Center" 
                                                       Margin="12,0,0,0" 
                                                       Foreground="{DynamicResource TextPrimary}" 
                                                       FontWeight="Medium"
                                                       FontSize="14"/>
                                            <TextBlock Text="[需要视觉能力]" 
                                                       VerticalAlignment="Center" 
                                                       Margin="8,0,0,0" 
                                                       Foreground="{DynamicResource HintBrush}" 
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Config.SavedModels.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                            </ItemsControl>
                            
                            <TextBlock Text="暂无可用模型" 
                                       Foreground="{DynamicResource TextSecondary}" 
                                       FontStyle="Italic"
                                       Margin="0,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Config.SavedModels.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="预设提示词" Style="{StaticResource SectionHeaderTextStyle}"/>
                            
                            <StackPanel Margin="0,0,0,15">
                                <TextBlock Text="Prompt" Style="{StaticResource FieldLabelTextStyle}"/>
                                <ComboBox ItemsSource="{Binding FilesView}"
                                          DisplayMemberPath="Title"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding Config.AiTranslationPromptId, Mode=TwoWay}"
                                          Margin="0,0,0,0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                                <TextBlock Text="{Binding AiModelsVM.TranslationTestStatus}"
                                           Foreground="{Binding AiModelsVM.TranslationTestStatusColor}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,15,0"
                                           FontWeight="SemiBold"/>
                                <Button Content="测试勾选的模型"
                                        Command="{Binding AiModelsVM.TestAiTranslationConnectionCommand}"
                                        Width="150"
                                        Height="36"
                                        Style="{StaticResource PrimaryButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
