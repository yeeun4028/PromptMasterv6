<Window x:Class="PromptMasterv6.Features.Main.LaunchBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:PromptMasterv6.Features.Main"
        xmlns:converters="clr-namespace:PromptMasterv6.Infrastructure.Converters"
        mc:Ignorable="d"
        Title="LaunchBarWindow"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        Width="{Binding Config.LaunchBarWidth, Mode=OneWay}"
        Left="0"
        Loaded="Window_Loaded">
    <Window.Resources>
        <converters:HexToSolidColorBrushConverter x:Key="HexColorConverter"/>
        
        <!-- Style for the entire ItemsControl container to clip/manage size based on items -->
        <Style x:Key="LaunchBarStyle" TargetType="ItemsControl">
            <Setter Property="Width" Value="{Binding Config.LaunchBarWidth, Mode=OneWay}" />
        </Style>

        <!-- Style for individual launch bar segments -->
        <Style x:Key="LaunchBarItemStyle" TargetType="Border">
            <Setter Property="Width" Value="{Binding DataContext.Config.LaunchBarWidth, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Background" Value="{Binding ColorHex, Converter={StaticResource HexColorConverter}}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="{Binding Label}"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
            <Setter Property="ToolTipService.ShowDuration" Value="5000"/>
        </Style>

    </Window.Resources>

    <Grid Background="#01FFFFFF">
        <!-- We use an ItemsControl to display the segments -->
        <ItemsControl ItemsSource="{Binding Config.LaunchBarItems}" Style="{StaticResource LaunchBarStyle}">
            <!-- Use a UniformGrid to divide the height evenly among the items -->
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="1" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- A container grid covering the full window width for mouse hit testing -->
                    <Grid Background="#01FFFFFF" 
                          MouseEnter="Segment_MouseEnter"
                          Tag="{Binding}">
                        <Border Style="{StaticResource LaunchBarItemStyle}" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>

