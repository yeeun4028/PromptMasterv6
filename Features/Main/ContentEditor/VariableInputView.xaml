<UserControl x:Class="PromptMasterv6.Features.Main.ContentEditor.VariableInputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:behaviors="clr-namespace:PromptMasterv6.Infrastructure.Behaviors"
             xmlns:converters="clr-namespace:PromptMasterv6.Infrastructure.Converters"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="200">

    <UserControl.Resources>
        <converters:StringToVisibilityConverter x:Key="StringVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="{DynamicResource Block4Background}">
        <Grid Margin="20,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <ItemsControl ItemsSource="{Binding Config.WebDirectTargets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.OpenWebTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        ToolTip="{Binding Name}"
                                        Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,8,0"
                                        Padding="6,4"
                                        Cursor="Hand"
                                        Background="Transparent"
                                        BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path x:Name="Icon" 
                                                          Data="{Binding IconData, Converter={StaticResource StringToGeometryConverter}}"
                                                          Visibility="{Binding IconData, Converter={StaticResource StringVisibilityConverter}}"
                                                          Fill="{DynamicResource ActionIconBrush}"
                                                          Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="Label" Text="{Binding Name}" 
                                                               Foreground="{DynamicResource SecondaryTextBrush}" 
                                                               FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"
                                                               FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                    <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                                                    <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Command="{Binding SearchOnGitHubCommand}"
                            ToolTip="在 GitHub 上搜索 (仅搜索此输入框内容)"
                            Margin="0,0,0,0"
                            Padding="6,4"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path x:Name="Icon" 
                                              Data="{StaticResource IconGitHub}"
                                              Fill="{DynamicResource ActionIconBrush}"
                                              Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="Label" Text="GitHub" 
                                                   Foreground="{DynamicResource SecondaryTextBrush}" 
                                                   FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"
                                                   FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                        <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                                        <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Button Command="{Binding CopyCompiledTextCommand}"
                        ToolTip="复制最终结果 (Ctrl+C)"
                        HorizontalAlignment="Right"
                        Margin="0,0,0,0"
                        Padding="6,4"
                        Cursor="Hand"
                        Background="Transparent"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <Path x:Name="Icon" 
                                      Data="{StaticResource IconCopyThin}"
                                      Fill="{DynamicResource ActionIconBrush}"
                                      Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                    <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" BorderThickness="0">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasVariables}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding Variables}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name, StringFormat='{}{0}:'}" FontSize="14" VerticalAlignment="Top" Margin="0,6,10,0" HorizontalAlignment="Right" Foreground="{DynamicResource AccentColor}" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                <Border x:Name="InputBorder" Grid.Column="1" BorderThickness="1" BorderBrush="{DynamicResource DividerBrush}" Background="{DynamicResource InputFocusBackgroundBrush}" CornerRadius="4">
                                    <TextBox x:Name="InputBox" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Padding="8,6" FontSize="14" ContextMenu="{DynamicResource UnifiedEditorContextMenu}" VerticalContentAlignment="Top" AcceptsReturn="True" TextWrapping="Wrap" Foreground="{DynamicResource PrimaryTextBrush}" FontFamily="Segoe UI, Microsoft YaHei UI" Style="{x:Null}">
                                        <b:Interaction.Behaviors>
                                            <behaviors:DoubleEnterSendBehavior 
                                                Command="{Binding DataContext.SendDefaultWebTargetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                EnableDoubleEnterSend="{Binding DataContext.Config.EnableDoubleEnterSend, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        </b:Interaction.Behaviors>
                                    </TextBox>
                                </Border>
                            </Grid>
                            <DataTemplate.Triggers>
                                <Trigger SourceName="InputBox" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="InputBorder" Property="BorderBrush" Value="{DynamicResource SecondaryTextBrush}"/>
                                </Trigger>
                                <Trigger SourceName="InputBox" Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="InputBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBox Grid.Row="1" Text="{Binding AdditionalInput, UpdateSourceTrigger=PropertyChanged}" 
                     Foreground="{DynamicResource PrimaryTextBrush}"
                     CaretBrush="{DynamicResource PrimaryTextBrush}"
                     AcceptsReturn="True" 
                     TextWrapping="Wrap" 
                     Padding="10" 
                     BorderThickness="0" 
                     Background="Transparent" 
                     VerticalContentAlignment="Top" 
                     ContextMenu="{DynamicResource UnifiedEditorContextMenu}"
                     FontSize="14" 
                     FontFamily="Segoe UI, Microsoft YaHei UI">
                <b:Interaction.Behaviors>
                    <behaviors:AutoNumberListBehavior 
                        Command="{Binding SendDefaultWebTargetCommand}"
                        EnableDoubleEnterSend="{Binding Config.EnableDoubleEnterSend}"/>
                </b:Interaction.Behaviors>
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasVariables}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
        </Grid>
    </Border>
</UserControl>
