<Window x:Class="PromptMasterv6.Features.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="clr-namespace:System.Windows.Input;assembly=PresentationCore"
        xmlns:md="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
        xmlns:dd="urn:gong-wpf-dragdrop"
        xmlns:models="clr-namespace:PromptMasterv6.Features.Shared.Models"
        xmlns:utils="clr-namespace:PromptMasterv6.Infrastructure.Converters"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:PromptMasterv6.Infrastructure.Behaviors"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:converters="clr-namespace:PromptMasterv6.Infrastructure.Converters"
        xmlns:components="clr-namespace:PromptMasterv6.Features.Main.Components"
        xmlns:contextMenu="clr-namespace:PromptMasterv6.Features.Main.ContextMenus"
        mc:Ignorable="d"
        Title="PromptMaster v6" 
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        Activated="Window_Activated"
        Deactivated="Window_Deactivated">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="8" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="GitHubBlue" Color="#4183C4"/>
        <utils:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <utils:StringToGeometryConverter x:Key="StringToGeometryConverter"/>
        <utils:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringVisibilityConverter"/>

        <ContextMenu x:Key="TrayMenu" Style="{StaticResource ModernContextMenuStyle}">
              <MenuItem Header="显示/隐藏窗口"
                        Style="{StaticResource TrayMenuItemStyle}"
                        Click="Tray_ToggleVisibility_Click"/>
              <MenuItem Header="云端同步" 
                        Style="{StaticResource TrayMenuItemStyle}"
                        Command="{Binding ManualBackupCommand}"/>
              <MenuItem Header="配置中心" 
                        Style="{StaticResource TrayMenuItemStyle}"
                        Command="{Binding OpenSettingsCommand}"/>
              <MenuItem Header="退出" 
                        Style="{StaticResource TrayMenuItemStyle}"
                        Click="Tray_Exit_Click"/>
        </ContextMenu>
    </Window.Resources>

    <Grid UseLayoutRounding="True" SnapsToDevicePixels="True">
        <!-- Growl Toast Notification Host -->
        <StackPanel hc:Growl.GrowlParent="True"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,20,20,0" Panel.ZIndex="10000" IsHitTestVisible="False"/>

        <Grid x:Name="FullModeContainer"
              Visibility="{Binding IsFullMode, Converter={StaticResource BoolToVis}}"
              Background="Transparent">

            <Border Background="{DynamicResource ShellBackground}" CornerRadius="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding LocalConfig.Block1Width, Mode=TwoWay, Converter={StaticResource DoubleToGridLengthConverter}}" MinWidth="20"/>
                        <ColumnDefinition Width="{Binding LocalConfig.Block2Width, Mode=TwoWay, Converter={StaticResource DoubleToGridLengthConverter}}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <components:SidebarView Grid.Column="0"/>

                    <GridSplitter Grid.Column="0" 
                                  Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True"/>

                    <components:FileListView Grid.Column="1"/>
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True"/>
                    <Border Grid.Column="1" Width="1" HorizontalAlignment="Right" Background="{DynamicResource DividerBrush}" IsHitTestVisible="False"/>

                    <Border Grid.Column="2" Background="{DynamicResource Block3Background}" CornerRadius="0,5,5,0">
                        <Grid>
                            <Grid.Resources>
                                <Style TargetType="ScrollBar">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Grid Background="Transparent"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                                    <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
                                </Style>
                            </Grid.Resources>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="7*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="3*"/>
                            </Grid.RowDefinitions>

                            <!-- 空状态占位提示 -->
                            <TextBlock Grid.Row="0"
                                       Text="请在左侧选择或新建提示词"
                                       FontSize="16"
                                       Foreground="{DynamicResource PlaceholderTextBrush}"
                                       FontFamily="Segoe UI, Microsoft YaHei UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FileManagerVM.SelectedFile}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Grid Grid.Row="0" Margin="20,0,4,0" TextElement.Foreground="{DynamicResource Block3EditorTextBrush}" TextElement.FontFamily="Segoe UI, Microsoft YaHei UI">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FileManagerVM.SelectedFile}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid Height="40" VerticalAlignment="Top" Background="Transparent">
                                    <b:Interaction.Behaviors>
                                        <behaviors:WindowDragBehavior/>
                                    </b:Interaction.Behaviors>
                                </Grid>

                                <Grid>
                                    <TextBox x:Name="Block3ContentEditor"
                                             Margin="0,40,0,0"
                                             ContextMenu="{DynamicResource UnifiedEditorContextMenu}"
                                             Text="{Binding FileManagerVM.SelectedFile.Content, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalContentAlignment="Top"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{DynamicResource Block3EditorTextBrush}"
                                             CaretBrush="{DynamicResource Block3EditorCaretBrush}"
                                             SelectionBrush="{DynamicResource Block3EditorSelectionBrush}"
                                             SelectionOpacity="1"
                                             FontSize="13"
                                             TextOptions.TextFormattingMode="Ideal"
                                             TextOptions.TextRenderingMode="ClearType"
                                             Padding="5"
                                             FontFamily="Segoe UI, Microsoft YaHei UI"
                                             PreviewKeyDown="TextBox_PreviewKeyDown"
                                             LostFocus="Block3ContentEditor_LostFocus"
                                             hc:InfoElement.Placeholder="在此处键入提示词内容...">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ContentEditorVM.IsEditMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                </Grid>

                                <md:MarkdownViewer Margin="0,40,0,0"
                                                  contextMenu:MarkdownViewerContextMenuBehavior.Attach="True"
                                                  ContextMenu="{DynamicResource UnifiedEditorContextMenu}"
                                                  Markdown="{Binding ContentEditorVM.PreviewContent}"
                                                  Pipeline="{Binding ContentEditorVM.Pipeline}"
                                                  xml:lang="zh-CN"
                                                  Background="{DynamicResource Block3Background}">
                                    <md:MarkdownViewer.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#4A89DC"/>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#B8BFC6"/>

                                        <Style TargetType="FlowDocumentScrollViewer">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>

                                        <!-- 抹平富文本内置段落间距 -->
                                        <Style x:Key="{x:Static md:Styles.ParagraphStyleKey}" TargetType="{x:Type Paragraph}">
                                            <Setter Property="LineHeight" Value="30"/>
                                            <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
                                            <Setter Property="Margin" Value="0,0,0,12"/>
                                        </Style>

                                        <Style x:Key="{x:Static md:Styles.DocumentStyleKey}" TargetType="{x:Type FlowDocument}">
                                            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Block3EditorTextBrush}"/>
                                            <Setter Property="TextAlignment" Value="Left"/>
                                            <Setter Property="PagePadding" Value="30,0,30,50"/>
                                            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
                                            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Style>
                                    </md:MarkdownViewer.Resources>
                                    <md:MarkdownViewer.Style>
                                        <Style TargetType="md:MarkdownViewer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ContentEditorVM.IsEditMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </md:MarkdownViewer.Style>
                                </md:MarkdownViewer>
                                <TextBlock Margin="5,25,5,5"
                                           Text="在此处键入内容..."
                                           Foreground="{DynamicResource PlaceholderTextBrush}"
                                           FontFamily="Segoe UI, Microsoft YaHei UI"
                                           FontSize="14"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Top">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ContentEditorVM.IsEditMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FileManagerVM.SelectedFile.Content}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FileManagerVM.SelectedFile.Content}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <Border Grid.Row="1" Height="1" Background="{DynamicResource DividerBrush}" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent" ResizeBehavior="PreviousAndNext" ShowsPreview="True"/>

                            <components:VariableInputView Grid.Row="2"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
