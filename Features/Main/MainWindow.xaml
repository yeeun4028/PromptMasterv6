<Window x:Class="PromptMasterv6.Features.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="clr-namespace:System.Windows.Input;assembly=PresentationCore"
        xmlns:md="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
        xmlns:dd="urn:gong-wpf-dragdrop"
        xmlns:models="clr-namespace:PromptMasterv6.Features.Shared.Models"
        xmlns:utils="clr-namespace:PromptMasterv6.Infrastructure.Converters"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:PromptMasterv6.Infrastructure.Behaviors"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:converters="clr-namespace:PromptMasterv6.Infrastructure.Converters"
        mc:Ignorable="d"
        Title="PromptMaster v6" 
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        Activated="Window_Activated"
        Deactivated="Window_Deactivated">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="8" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="GitHubBlue" Color="#4183C4"/>
        <utils:InverseBoolConverter x:Key="InverseBoolConverter"/>
        <utils:StringToGeometryConverter x:Key="StringToGeometryConverter"/>
        <utils:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringVisibilityConverter"/>

        <ContextMenu x:Key="TrayMenu" Style="{StaticResource ModernContextMenuStyle}">
              <MenuItem Header="显示/隐藏窗口"
                        Style="{StaticResource TrayMenuItemStyle}"
                        Click="Tray_ToggleVisibility_Click"/>
              <MenuItem Header="云端同步" 
                        Style="{StaticResource TrayMenuItemStyle}"
                        Command="{Binding ManualBackupCommand}"/>
              <MenuItem Header="配置中心" 
                        Style="{StaticResource TrayMenuItemStyle}"
                        Command="{Binding OpenSettingsCommand}"/>
              <MenuItem Header="退出" 
                        Style="{StaticResource TrayMenuItemStyle}"
                        Click="Tray_Exit_Click"/>
        </ContextMenu>
    </Window.Resources>

    <Grid UseLayoutRounding="True" SnapsToDevicePixels="True">
        <!-- Growl Toast Notification Host -->
        <StackPanel hc:Growl.GrowlParent="True"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,20,20,0" Panel.ZIndex="10000" IsHitTestVisible="False"/>

        <Grid x:Name="FullModeContainer"
              Visibility="{Binding IsFullMode, Converter={StaticResource BoolToVis}}"
              Background="Transparent">

            <Border Background="{DynamicResource ShellBackground}" CornerRadius="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding LocalConfig.Block1Width, Mode=TwoWay, Converter={StaticResource DoubleToGridLengthConverter}}" MinWidth="20"/>
                        <ColumnDefinition Width="{Binding LocalConfig.Block2Width, Mode=TwoWay, Converter={StaticResource DoubleToGridLengthConverter}}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Height="40" VerticalAlignment="Top" Background="Transparent">
                        <b:Interaction.Behaviors>
                            <behaviors:WindowDragBehavior/>
                        </b:Interaction.Behaviors>
                    </Border>

                    <Border Grid.Column="0" 
                            Background="{DynamicResource Block1Background}" 
                            CornerRadius="5,0,0,5">
                        <Grid>
                            <ListBox ItemsSource="{Binding FileManagerVM.Folders}" 
                                     SelectedItem="{Binding FileManagerVM.SelectedFolder}"
                                     ItemContainerStyle="{StaticResource FolderListBoxItemStyle}" 
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                                     VerticalAlignment="Top" 
                                     Margin="0,15,0,0"
                                     dd:DragDrop.IsDragSource="True" 
                                     dd:DragDrop.IsDropTarget="True"
                                     dd:DragDrop.DropHandler="{Binding FileManagerVM.FolderDropHandler}"/>

                            <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,20">
                                <Button Style="{StaticResource ActionBtnStyle}" Content="新建文档" Command="{Binding FileManagerVM.CreateFileCommand}">
                                    <Button.ContextMenu>
                                        <ContextMenu Style="{StaticResource ModernContextMenuStyle}">
                                            <MenuItem Header="设置图标"
                                                      Style="{StaticResource ModernMenuItemStyle}"
                                                      Command="{Binding PlacementTarget.DataContext.ChangeActionIconCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="CreateFile"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="新建文档"/>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Path Data="{Binding DataContext.LocalConfig.ActionIcons[CreateFile], RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringToGeometryConverter}, FallbackValue={StaticResource IconNewDoc}}" Style="{StaticResource ActionIconPathStyle}"/>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button Style="{StaticResource ActionBtnStyle}" Content="新建文件夹" Command="{Binding FileManagerVM.CreateFolderCommand}">
                                    <Button.ContextMenu>
                                        <ContextMenu Style="{StaticResource ModernContextMenuStyle}">
                                            <MenuItem Header="设置图标"
                                                      Style="{StaticResource ModernMenuItemStyle}"
                                                      Command="{Binding PlacementTarget.DataContext.ChangeActionIconCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="CreateFolder"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="新建文件夹"/>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Path Data="{Binding DataContext.LocalConfig.ActionIcons[CreateFolder], RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringToGeometryConverter}, FallbackValue={StaticResource IconNewFolder}}" Style="{StaticResource ActionIconPathStyle}"/>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button Style="{StaticResource ActionBtnStyle}" Content="导入" Command="{Binding FileManagerVM.ImportMarkdownFilesCommand}">
                                    <Button.ContextMenu>
                                        <ContextMenu Style="{StaticResource ModernContextMenuStyle}">
                                            <MenuItem Header="设置图标"
                                                      Style="{StaticResource ModernMenuItemStyle}"
                                                      Command="{Binding PlacementTarget.DataContext.ChangeActionIconCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="Import"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="导入 Markdown 文件"/>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Path Data="{Binding DataContext.LocalConfig.ActionIcons[Import], RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringToGeometryConverter}, FallbackValue={StaticResource IconImport}}" Style="{StaticResource ActionIconPathStyle}"/>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button Style="{StaticResource ActionBtnStyle}" Content="设置" Command="{Binding OpenSettingsCommand}">
                                    <Button.ContextMenu>
                                        <ContextMenu Style="{StaticResource ModernContextMenuStyle}">
                                            <MenuItem Header="设置图标"
                                                      Style="{StaticResource ModernMenuItemStyle}"
                                                      Command="{Binding PlacementTarget.DataContext.ChangeActionIconCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="Settings"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="设置"/>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Path Data="{Binding DataContext.LocalConfig.ActionIcons[Settings], RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringToGeometryConverter}, FallbackValue={StaticResource IconSettings}}" Style="{StaticResource ActionIconPathStyle}"/>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button Command="{Binding ContentEditorVM.ToggleEditModeCommand}" Style="{StaticResource ActionBtnStyle}">
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource Block1ToolTipStyle}">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ContentEditorVM.IsEditMode}" Value="True">
                                                                <Setter Property="Text" Value="点击锁定并保存"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ContentEditorVM.IsEditMode}" Value="False">
                                                                <Setter Property="Text" Value="点击解锁编辑"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </ToolTip>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Path Data="{StaticResource IconLockOpenThin}">
                                                    <Path.Style>
                                                        <Style TargetType="Path" BasedOn="{StaticResource ActionIconPathStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.ContentEditorVM.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                                <Path Data="{StaticResource IconLockClosedThin}">
                                                    <Path.Style>
                                                        <Style TargetType="Path" BasedOn="{StaticResource ActionIconPathStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.ContentEditorVM.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Grid>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button Command="{Binding ManualBackupCommand}" Style="{StaticResource ActionBtnStyle}">
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="备份到云端"/>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Path x:Name="IconPath" 
                                                  Data="{StaticResource IconCloudUpload}"
                                                  Style="{StaticResource ActionIconPathStyle}"/>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.FileManagerVM.IsDirty, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter TargetName="IconPath" Property="Fill" Value="#E53935"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>


                            </StackPanel>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="0" 
                                  Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True"/>

                    <Border Grid.Column="1" Background="{DynamicResource Block2Background}">
                        <Grid>
                            <Grid Height="40" VerticalAlignment="Top" Background="Transparent">
                                <b:Interaction.Behaviors>
                                    <behaviors:WindowDragBehavior/>
                                </b:Interaction.Behaviors>
                            </Grid>

                            <ListBox ItemsSource="{Binding FileManagerVM.FilesView}"
                                      SelectedItem="{Binding FileManagerVM.SelectedFile}"
                                      ItemContainerStyle="{StaticResource FileListBoxItemStyle}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Margin="10,23,5,10"
                                      dd:DragDrop.IsDragSource="True"
                                      dd:DragDrop.IsDropTarget="True">
                                <ListBox.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource Block2ScrollBarStyle}"/>
                                </ListBox.Resources>

                                <ListBox.InputBindings>
                                    <KeyBinding Key="Delete" Command="{Binding FileManagerVM.DeleteFileCommand}" CommandParameter="{Binding FileManagerVM.SelectedFile}"/>
                                </ListBox.InputBindings>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <TextBlock Text="{Binding Title}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontFamily="Segoe UI, Microsoft YaHei UI" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBox x:Name="InlineRenameTextBox" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" 
                                                     Background="{DynamicResource InputFocusBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" 
                                                     BorderBrush="{StaticResource GitHubBlue}" BorderThickness="0,0,0,1" 
                                                     FontSize="13" FontFamily="Segoe UI, Microsoft YaHei UI" Padding="0"
                                                     VerticalAlignment="Center"
                                                     Loaded="FileInlineEditor_Loaded" PreviewKeyDown="FileInlineEditor_KeyDown" LostFocus="FileInlineEditor_LostFocus">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True"/>
                    <Border Grid.Column="1" Width="1" HorizontalAlignment="Right" Background="{DynamicResource DividerBrush}" IsHitTestVisible="False"/>

                    <Border Grid.Column="2" Background="{DynamicResource Block3Background}" CornerRadius="0,5,5,0">
                        <Grid>
                            <Grid.Resources>
                                <Style TargetType="ScrollBar">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Grid Background="Transparent"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                                    <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
                                </Style>
                            </Grid.Resources>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="7*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="3*"/>
                            </Grid.RowDefinitions>

                            <!-- 空状态占位提示 -->
                            <TextBlock Grid.Row="0"
                                       Text="请在左侧选择或新建提示词"
                                       FontSize="16"
                                       Foreground="{DynamicResource PlaceholderTextBrush}"
                                       FontFamily="Segoe UI, Microsoft YaHei UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FileManagerVM.SelectedFile}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Grid Grid.Row="0" Margin="20,0,4,0" TextElement.Foreground="{DynamicResource Block3EditorTextBrush}" TextElement.FontFamily="Segoe UI, Microsoft YaHei UI">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FileManagerVM.SelectedFile}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid Height="40" VerticalAlignment="Top" Background="Transparent">
                                    <b:Interaction.Behaviors>
                                        <behaviors:WindowDragBehavior/>
                                    </b:Interaction.Behaviors>
                                </Grid>

                                <Grid>
                                    <TextBox x:Name="Block3ContentEditor"
                                             Margin="0,40,0,0"
                                             ContextMenu="{DynamicResource UnifiedEditorContextMenu}"
                                             Text="{Binding FileManagerVM.SelectedFile.Content, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalContentAlignment="Top"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{DynamicResource Block3EditorTextBrush}"
                                             CaretBrush="{DynamicResource Block3EditorCaretBrush}"
                                             SelectionBrush="{DynamicResource Block3EditorSelectionBrush}"
                                             SelectionOpacity="1"
                                             FontSize="13"
                                             TextOptions.TextFormattingMode="Ideal"
                                             TextOptions.TextRenderingMode="ClearType"
                                             Padding="5"
                                             FontFamily="Segoe UI, Microsoft YaHei UI"
                                             PreviewKeyDown="TextBox_PreviewKeyDown"
                                             LostFocus="Block3ContentEditor_LostFocus"
                                             hc:InfoElement.Placeholder="在此处键入提示词内容...">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ContentEditorVM.IsEditMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                </Grid>

                                <md:MarkdownViewer Margin="0,40,0,0"
                                                  Loaded="MarkdownViewer_Loaded"
                                                  ContextMenu="{DynamicResource UnifiedEditorContextMenu}"
                                                  Markdown="{Binding ContentEditorVM.PreviewContent}"
                                                  Pipeline="{Binding ContentEditorVM.Pipeline}"
                                                  xml:lang="zh-CN"
                                                  Background="{DynamicResource Block3Background}">
                                    <md:MarkdownViewer.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#4A89DC"/>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#B8BFC6"/>

                                        <Style TargetType="FlowDocumentScrollViewer">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>

                                        <!-- 抹平富文本内置段落间距 -->
                                        <Style x:Key="{x:Static md:Styles.ParagraphStyleKey}" TargetType="{x:Type Paragraph}">
                                            <Setter Property="LineHeight" Value="30"/>
                                            <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
                                            <Setter Property="Margin" Value="0,0,0,12"/>
                                        </Style>

                                        <Style x:Key="{x:Static md:Styles.DocumentStyleKey}" TargetType="{x:Type FlowDocument}">
                                            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Block3EditorTextBrush}"/>
                                            <Setter Property="TextAlignment" Value="Left"/>
                                            <Setter Property="PagePadding" Value="30,0,30,50"/>
                                            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
                                            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Style>
                                    </md:MarkdownViewer.Resources>
                                    <md:MarkdownViewer.Style>
                                        <Style TargetType="md:MarkdownViewer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ContentEditorVM.IsEditMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </md:MarkdownViewer.Style>
                                </md:MarkdownViewer>
                                <TextBlock Margin="5,25,5,5"
                                           Text="在此处键入内容..."
                                           Foreground="{DynamicResource PlaceholderTextBrush}"
                                           FontFamily="Segoe UI, Microsoft YaHei UI"
                                           FontSize="14"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Top">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ContentEditorVM.IsEditMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FileManagerVM.SelectedFile.Content}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FileManagerVM.SelectedFile.Content}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <Border Grid.Row="1" Height="1" Background="{DynamicResource DividerBrush}" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent" ResizeBehavior="PreviousAndNext" ShowsPreview="True"/>

                            <Border Grid.Row="2" Background="{DynamicResource Block4Background}">
                                <Border.Resources>
                                    <Style x:Key="Block4MenuItemStyle" TargetType="MenuItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Padding" Value="12,4"/>
                                        <Setter Property="Margin" Value="0,0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="MenuItem">
                                                    <Border x:Name="Bd" 
                                                            Background="{TemplateBinding Background}" 
                                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                                            BorderThickness="{TemplateBinding BorderThickness}" 
                                                            Padding="{TemplateBinding Padding}" 
                                                            CornerRadius="6"
                                                            SnapsToDevicePixels="True">
                                                        <ContentPresenter x:Name="ContentPresenter" 
                                                                          Content="{TemplateBinding Header}" 
                                                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                                          ContentStringFormat="{TemplateBinding HeaderStringFormat}"
                                                                          RecognizesAccessKey="True" 
                                                                          VerticalAlignment="Center" 
                                                                          HorizontalAlignment="Left"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsHighlighted" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemSelectedBackgroundBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>

                                    <Style x:Key="Block4EditorContextMenuStyle" TargetType="ContextMenu">
                                        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        <Setter Property="Padding" Value="0,4"/>
                                        <Setter Property="ItemContainerStyle" Value="{StaticResource Block4MenuItemStyle}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContextMenu">
                                                    <Border x:Name="Bd" 
                                                            Background="{TemplateBinding Background}" 
                                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8"
                                                            Padding="{TemplateBinding Padding}">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="12" Opacity="0.3"/>
                                                        </Border.Effect>
                                                        <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>

                                    <ContextMenu x:Key="Block4EditorContextMenu" x:Shared="False" Style="{StaticResource Block4EditorContextMenuStyle}">
                                        <MenuItem Command="ApplicationCommands.Cut" Header="剪切" InputGestureText=""/>
                                        <MenuItem Command="ApplicationCommands.Copy" Header="复制" InputGestureText=""/>
                                        <MenuItem Command="ApplicationCommands.Paste" Header="粘贴" InputGestureText=""/>
                                        <Separator Style="{StaticResource NoIconSeparatorStyle}"/>
                                        <MenuItem Command="ApplicationCommands.SelectAll" Header="全选" InputGestureText=""/>
                                    </ContextMenu>
                                </Border.Resources>
                                <Grid Margin="20,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- ★★★ Web Direct Targets (Block4 顶部) ★★★ -->
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <ItemsControl ItemsSource="{Binding Config.WebDirectTargets}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.ContentEditorVM.OpenWebTargetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="{Binding Name}"
                                                            Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}"
                                                            Margin="0,0,8,0"
                                                            Padding="6,4"
                                                            Cursor="Hand"
                                                            Background="Transparent"
                                                            BorderThickness="0">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Path x:Name="Icon" 
                                                                              Data="{Binding IconData, Converter={StaticResource StringToGeometryConverter}}"
                                                                              Visibility="{Binding IconData, Converter={StaticResource StringVisibilityConverter}}"
                                                                              Fill="{DynamicResource ActionIconBrush}"
                                                                              Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                                                                        <TextBlock x:Name="Label" Text="{Binding Name}" 
                                                                                   Foreground="{DynamicResource SecondaryTextBrush}" 
                                                                                   FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"
                                                                                   FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                                                    </StackPanel>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                                        <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                                                                        <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- GitHub Search Button -->
                                        <Button Command="{Binding ContentEditorVM.SearchOnGitHubCommand}"
                                                ToolTip="在 GitHub 上搜索 (仅搜索此输入框内容)"
                                                Margin="0,0,0,0"
                                                Padding="6,4"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Path x:Name="Icon" 
                                                                  Data="{StaticResource IconGitHub}"
                                                                  Fill="{DynamicResource ActionIconBrush}"
                                                                  Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                                                            <TextBlock x:Name="Label" Text="GitHub" 
                                                                       Foreground="{DynamicResource SecondaryTextBrush}" 
                                                                       FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"
                                                                       FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                            <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                                                            <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        </StackPanel>

                                        <!-- Copy Result Button (Far Right) -->
                                        <Button Command="{Binding ContentEditorVM.CopyCompiledTextCommand}"
                                                ToolTip="复制最终结果 (Ctrl+C)"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,0,0"
                                                Padding="6,4"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <Path x:Name="Icon" 
                                                              Data="{StaticResource IconCopyThin}"
                                                              Fill="{DynamicResource ActionIconBrush}"
                                                              Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                            <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" BorderThickness="0">
                                        <ScrollViewer.Style>
                                            <Style TargetType="ScrollViewer">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ContentEditorVM.HasVariables}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ScrollViewer.Style>
                                        <ItemsControl ItemsSource="{Binding ContentEditorVM.Variables}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name, StringFormat='{}{0}:'}" FontSize="14" VerticalAlignment="Top" Margin="0,6,10,0" HorizontalAlignment="Right" Foreground="{DynamicResource AccentColor}" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                                        <Border x:Name="InputBorder" Grid.Column="1" BorderThickness="1" BorderBrush="{DynamicResource DividerBrush}" Background="{DynamicResource InputFocusBackgroundBrush}" CornerRadius="4">
                                                            <TextBox x:Name="InputBox" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Padding="8,6" FontSize="14" ContextMenu="{DynamicResource UnifiedEditorContextMenu}" VerticalContentAlignment="Top" AcceptsReturn="True" TextWrapping="Wrap" PreviewKeyDown="TextBox_PreviewKeyDown" Foreground="{DynamicResource PrimaryTextBrush}" FontFamily="Segoe UI, Microsoft YaHei UI" Style="{x:Null}"/>
                                                        </Border>
                                                    </Grid>
                                                    <DataTemplate.Triggers>
                                                        <Trigger SourceName="InputBox" Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="InputBorder" Property="BorderBrush" Value="{DynamicResource SecondaryTextBrush}"/>
                                                        </Trigger>
                                                        <Trigger SourceName="InputBox" Property="IsKeyboardFocused" Value="True">
                                                            <Setter TargetName="InputBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                                        </Trigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <TextBox Grid.Row="1" Text="{Binding ContentEditorVM.AdditionalInput, UpdateSourceTrigger=PropertyChanged}" 
                                             Foreground="{DynamicResource PrimaryTextBrush}"
                                             CaretBrush="{DynamicResource PrimaryTextBrush}"
                                             PreviewKeyDown="AdditionalInputBox_PreviewKeyDown"
                                             AcceptsReturn="True" 
                                             TextWrapping="Wrap" 
                                             Padding="10" 
                                             BorderThickness="0" 
                                             Background="Transparent" 
                                             VerticalContentAlignment="Top" 
                                             ContextMenu="{DynamicResource UnifiedEditorContextMenu}"
                                             FontSize="14" 
                                             FontFamily="Segoe UI, Microsoft YaHei UI">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ContentEditorVM.HasVariables}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
