<ContextMenu x:Class="PromptMasterv6.Features.Main.Tray.TrayMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Style="{StaticResource ModernContextMenuStyle}">
    
    <MenuItem Header="显示/隐藏窗口"
              Style="{StaticResource TrayMenuItemStyle}"
              Command="{Binding ToggleVisibilityCommand}"/>
    <MenuItem Header="云端同步"
              Style="{StaticResource TrayMenuItemStyle}"
              Command="{Binding ManualBackupCommand}"/>
    <MenuItem Header="配置中心"
              Style="{StaticResource TrayMenuItemStyle}"
              Command="{Binding OpenSettingsCommand}"/>
    <MenuItem Header="退出"
              Style="{StaticResource TrayMenuItemStyle}"
              Command="{Binding ExitCommand}"/>
</ContextMenu>
