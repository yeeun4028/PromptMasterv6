<Window x:Class="PromptMasterv6.Features.ExternalTools.Dialogs.OcrNotConfiguredDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="未配置 OCR" Height="220" Width="400"
        WindowStartupLocation="CenterOwner"
        Style="{DynamicResource ModernDialogWindowStyle}"
        Background="Transparent" AllowsTransparency="True" WindowStyle="None">

    <Grid>
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" Y="10"/>
        </Grid.RenderTransform>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                        <DoubleAnimation Storyboard.TargetName="SlideTransform" Storyboard.TargetProperty="Y" From="10" To="0" Duration="0:0:0.2">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Text="未配置 OCR 服务" Style="{StaticResource SectionHeaderTextStyle}"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Viewbox Width="24" Height="24" Margin="0,0,12,0" VerticalAlignment="Top">
                    <Path Data="M19.43,12.98C19.47,12.66 19.5,12.34 19.5,12C19.5,11.66 19.47,11.34 19.43,11.02L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.65 15.48,5.32 14.87,5.07L14.49,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.51,2.42L9.13,5.07C8.52,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11.02C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.66 4.57,12.98L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.52,18.68 9.13,18.93L9.51,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.49,21.58L14.87,18.93C15.48,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.98M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5Z" 
                          Fill="#3B82F6" Stretch="Uniform"/>
                </Viewbox>
                <TextBlock Text="请先在设置中勾选至少一个 OCR 服务商，或者启用 AI 截图翻译模型。"
                           Style="{StaticResource FieldLabelTextStyle}"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="14"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Width="300"
                           LineHeight="20"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="取消" IsCancel="True" Click="Cancel_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,12,0"/>
            <Button Content="前往设置" IsDefault="True" Click="GoToSettings_Click" Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
