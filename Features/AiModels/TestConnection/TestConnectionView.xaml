<UserControl x:Class="PromptMasterv6.Features.AiModels.TestConnection.TestConnectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shared="clr-namespace:PromptMasterv6.Features.AiModels.Shared">
    <UserControl.Resources>
        <shared:ConnectionTestStatusToColorConverter x:Key="StatusToColorConverter"/>
    </UserControl.Resources>
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedModel, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
        <TextBlock Text="{Binding ConnectionTestMessage}" 
                   Foreground="{Binding ConnectionTestStatus, Converter={StaticResource StatusToColorConverter}}" 
                   VerticalAlignment="Center" 
                   Margin="0,0,15,0" 
                   FontWeight="SemiBold"/>
        <Button Content="测试连接" 
                Command="{Binding TestConnectionCommand}" 
                CommandParameter="{Binding SelectedModel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Style="{StaticResource TextLinkButtonStyle}" 
                Foreground="{DynamicResource TextSecondary}" 
                Margin="0,0,15,0"/>
    </StackPanel>
</UserControl>
