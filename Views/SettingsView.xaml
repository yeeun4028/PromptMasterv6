<UserControl x:Class="PromptMasterv5.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dd="urn:gong-wpf-dragdrop"
             xmlns:models="clr-namespace:PromptMasterv5.Core.Models"
             xmlns:converters="clr-namespace:PromptMasterv5.Converters"
             xmlns:utils="clr-namespace:PromptMasterv5.Utils"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="750">
    <UserControl.Resources>
        <converters:ApiKeyMaskConverter x:Key="ApiKeyMaskConverter"/>
        <converters:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
        <Color x:Key="AccentColorValue">#4183C4</Color>
        <SolidColorBrush x:Key="AccentColor" Color="{StaticResource AccentColorValue}"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E53935"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#C62828"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <utils:InverseBoolConverter x:Key="InverseBoolConverter"/>

        <!-- Icons -->
        <Geometry x:Key="IconShortcut">M19,3H5C3.89,3 3,3.89 3,5V19C3,20.11 3.89,21 5,21H19C20.11,21 21,20.11 21,19V5C21,3.89 20.11,3 19,3M19,19H5V5H19V19M11,17H13V15H11V17M15,17H17V15H15V17M7,17H9V15H7V17M11,13H13V11H11V13M15,13H17V11H15V13M7,13H9V11H7V13M11,9H13V7H11V9M15,9H17V7H15V9M7,9H9V7H7V9Z</Geometry>
        <Geometry x:Key="IconModel">M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6M12,8A4,4 0 0,0 8,12A4,4 0 0,0 12,16A4,4 0 0,0 16,12A4,4 0 0,0 12,8Z</Geometry>
        <Geometry x:Key="IconMiniWindow">M19,13H5V11H19V13Z</Geometry>

        <!-- Tab Button Style -->
        <Style x:Key="ModernTabBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="15,0">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ListItemSelectedBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.03" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Fade In Animation -->
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="10" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style x:Key="FadeInContentStyle" TargetType="StackPanel">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource FadeInAnimation}"/>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="{DynamicResource ShellBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource InputTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource InputFocusBackgroundBrush}"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource AccentColorValue}" Opacity="0.2" BlurRadius="4" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ApiKeyTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ModernTextBoxStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"/>
                                <!-- 遮罩层：当失去焦点且文本不为空时显示 -->
                                <TextBlock x:Name="MaskText"
                                           Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource ApiKeyMaskConverter}}"
                                           Margin="12,8"
                                           VerticalAlignment="Top"
                                           Foreground="#DEDEDE"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource InputFocusBackgroundBrush}"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource AccentColorValue}" Opacity="0.2" BlurRadius="4" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                                <!-- 聚焦时：隐藏遮罩，显示原始内容 -->
                                <Setter TargetName="MaskText" Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Foreground" Value="#DEDEDE"/> 
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsFocused" Value="False"/>
                                    <!-- 这里简单处理：只要没聚焦就显示遮罩，并将原始内容变透明 -->
                                </MultiTrigger.Conditions>
                                <Setter TargetName="MaskText" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="Transparent"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="{DynamicResource ShellBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#DEDEDE"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource InputFocusBackgroundBrush}"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource AccentColorValue}" Opacity="0.2" BlurRadius="4" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource HintBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TextLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="LinkText"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="13"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LinkText" Property="TextDecorations" Value="Underline"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="LinkText" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerLinkButtonStyle" TargetType="Button" BasedOn="{StaticResource TextLinkButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="LinkText"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="13"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LinkText" Property="TextDecorations" Value="Underline"/>
                                <Setter TargetName="LinkText" Property="Foreground" Value="{StaticResource DangerHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="LinkText" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                BorderThickness="0,0,0,2" 
                                BorderBrush="Transparent" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Selected">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Border x:Name="Border"
                                    Width="40" Height="22"
                                    CornerRadius="11"
                                    Background="{DynamicResource DividerBrush}"
                                    BorderBrush="{DynamicResource DividerBrush}"
                                    BorderThickness="1">
                                <Ellipse x:Name="Dot"
                                         Width="16" Height="16"
                                         Fill="White"
                                         HorizontalAlignment="Left"
                                         Margin="2,0,0,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="2" ShadowDepth="1"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="Dot" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Dot" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBar" TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsFlicksEnabled" Value="false" />
            <Setter Property="Foreground" Value="{DynamicResource AppBackground}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="GridRoot" Width="1" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" Focusable="false">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Background="{TemplateBinding Foreground}" 
                                           Style="{DynamicResource ScrollBarThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton x:Name="PageUp" Command="ScrollBar.PageDownCommand" 
                                                  Opacity="0" Focusable="false" />
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton x:Name="PageDown" Command="ScrollBar.PageUpCommand" 
                                                  Opacity="0" Focusable="false" />
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="rectangle"
                                Width="1"
                                Height="{TemplateBinding Height}"
                                SnapsToDevicePixels="True"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollViewer}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid x:Name="Grid" Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter" CanContentScroll="{TemplateBinding CanContentScroll}" Grid.Column="0" Grid.Row="0" Margin="{TemplateBinding Padding}" Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" CanHorizontallyScroll="False" CanVerticallyScroll="False"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" AutomationProperties.AutomationId="VerticalScrollBar" Cursor="Arrow" Grid.Column="1" Maximum="{TemplateBinding ScrollableHeight}" Minimum="0" Grid.Row="0" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" ViewportSize="{TemplateBinding ViewportHeight}" Style="{StaticResource ModernScrollBar}"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar" AutomationProperties.AutomationId="HorizontalScrollBar" Cursor="Arrow" Grid.Column="0" Maximum="{TemplateBinding ScrollableWidth}" Minimum="0" Orientation="Horizontal" Grid.Row="1" Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}" ViewportSize="{TemplateBinding ViewportWidth}" Style="{StaticResource ModernScrollBar}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <!-- Modal Overlay -->
        <Border Background="#66000000">
            <!-- Main Settings Window -->
            <Border Width="750" Height="500" Background="{DynamicResource AppBackground}" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="25" ShadowDepth="0"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Sidebar -->
                    <Border Background="{DynamicResource SidebarBackground}" CornerRadius="12,0,0,12" BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,1,0">
                        <StackPanel Margin="15,25">
                            <!-- Tab Buttons -->
                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="16" Height="16" Margin="0,1,12,1">
                                        <Path Data="{StaticResource IconShortcut}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                    </Viewbox>
                                    <TextBlock Text="快捷键" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="1">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="16" Height="16" Margin="0,1,12,1">
                                        <TextBlock Text="⚡" FontSize="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Viewbox>
                                    <TextBlock Text="发送方式" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="2">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="16" Height="16" Margin="0,1,12,1">
                                        <Path Data="{StaticResource IconModel}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                    </Viewbox>
                                    <TextBlock Text="模型" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="3">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="16" Height="16" Margin="0,1,12,1">
                                        <TextBlock Text="☁️" FontSize="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Viewbox>
                                    <TextBlock Text="同步" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="4">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="4">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="16" Height="16" Margin="0,1,12,1">
                                        <Path Data="{StaticResource IconMiniWindow}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                    </Viewbox>
                                    <TextBlock Text="极简窗口" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="5">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="5">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="16" Height="16" Margin="0,1,12,1">
                                        <TextBlock Text="🛠️" FontSize="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Viewbox>
                                    <TextBlock Text="外部工具" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Right Content Area -->
                    <Grid Grid.Column="1" Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header with Close Button -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Button Command="{Binding SaveSettingsCommand}" 
                                    Content="✕" FontSize="18" Foreground="{DynamicResource TextSecondary}"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Tab Contents -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                            <Grid>
                                <!-- Tab 0: Shortcut -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Row 1: Double Ctrl -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,20">
                                            <TextBlock Text="双击 Ctrl 键唤醒" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,4"/>
                                        </StackPanel>
                                        <CheckBox Grid.Row="0" Grid.Column="1" 
                                                  IsChecked="{Binding Config.EnableDoubleCtrl}" 
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  Cursor="Hand"
                                                  VerticalAlignment="Center"/>

                                        <!-- Row 2: Full Window -->
                                        <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,20">
                                            <TextBlock Text="完整窗口" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,4"/>
                                        </StackPanel>
                                        <TextBox Grid.Row="1" Grid.Column="1" 
                                                 Text="{Binding Config.FullWindowHotkey}" 
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Width="140"
                                                 IsReadOnly="True"
                                                 Cursor="IBeam"
                                                 VerticalAlignment="Center"
                                                 PreviewKeyDown="FullWindowHotkeyTextBox_PreviewKeyDown"
                                                 ToolTip="点击按下按键设置，按 Delete 清除"/>

                                        <!-- Row 3: Mini Window -->
                                        <StackPanel Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,20">
                                            <TextBlock Text="迷你窗口" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,4"/>
                                        </StackPanel>
                                        <TextBox Grid.Row="2" Grid.Column="1" 
                                                 Text="{Binding Config.MiniWindowHotkey}"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Width="140"
                                                 IsReadOnly="True"
                                                 Cursor="IBeam"
                                                 VerticalAlignment="Center"
                                                 PreviewKeyDown="MiniWindowHotkeyTextBox_PreviewKeyDown"
                                                 ToolTip="点击按下按键设置，按 Delete 清除"/>

                                        <!-- Row 4: Screenshot Translate -->
                                        <StackPanel Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,20">
                                            <TextBlock Text="截图翻译" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,4"/>
                                        </StackPanel>
                                        <TextBox Grid.Row="3" Grid.Column="1" 
                                                 x:Name="ScreenshotTranslateHotkeyTextBox" 
                                                 Text="{Binding Config.ScreenshotTranslateHotkey, Mode=TwoWay}"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Width="140"
                                                 IsReadOnly="True"
                                                 Cursor="IBeam"
                                                 VerticalAlignment="Center"
                                                 PreviewKeyDown="ScreenshotTranslateHotkeyTextBox_PreviewKeyDown"
                                                 ToolTip="点击按下按键设置，按 Delete 清除"/>

                                        <!-- Row 5: Selected Text Translate -->
                                        <StackPanel Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,20">
                                            <TextBlock Text="划词翻译" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,4"/>
                                        </StackPanel>
                                        <TextBox Grid.Row="4" Grid.Column="1" 
                                                 x:Name="SelectedTextTranslateHotkeyTextBox"
                                                 Text="{Binding Config.SelectedTextTranslateHotkey, Mode=TwoWay}"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Width="140"
                                                 IsReadOnly="True"
                                                 Cursor="IBeam"
                                                 VerticalAlignment="Center"
                                                 PreviewKeyDown="SelectedTextTranslateHotkeyTextBox_PreviewKeyDown"
                                                 ToolTip="点击按下按键设置，按 Delete 清除"/>

                                        <!-- Row 6: OCR -->
                                        <StackPanel Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,20">
                                            <TextBlock Text="OCR 识别" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,4"/>
                                        </StackPanel>
                                        <TextBox Grid.Row="5" Grid.Column="1" 
                                                 x:Name="OcrHotkeyTextBox" 
                                                 Text="{Binding Config.OcrHotkey, Mode=TwoWay}"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Width="140"
                                                 IsReadOnly="True"
                                                 Cursor="IBeam"
                                                 VerticalAlignment="Center"
                                                 PreviewKeyDown="OcrHotkeyTextBox_PreviewKeyDown"
                                                 ToolTip="点击按下按键设置，按 Delete 清除"/>

                                        <!-- Row 7: Quick Action (Selected Text Extension) -->
                                        <StackPanel Grid.Row="6" Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="划词扩展" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,4"/>
                                        </StackPanel>
                                        <TextBox Grid.Row="6" Grid.Column="1" 
                                                 x:Name="QuickActionHotkeyTextBox" 
                                                 Text="{Binding Config.QuickActionHotkey, Mode=TwoWay}"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Width="140"
                                                 IsReadOnly="True"
                                                 Cursor="IBeam"
                                                 VerticalAlignment="Center"
                                                 PreviewKeyDown="QuickActionHotkeyTextBox_PreviewKeyDown"
                                                 ToolTip="点击按下按键设置，按 Delete 清除"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Tab 1: Automation -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <StackPanel Margin="0,0,0,14">
                                        <TextBlock Text="Ctrl+Enter：软件隐藏 → 焦点 → 上一个活动窗口 → 发送内容"
                                                   Style="{StaticResource HintTextStyle}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                        
                                        <TextBlock Text="坐标点击模式：软件隐藏后，强制点击屏幕上的指定位置来激活输入框。"
                                                   Style="{StaticResource HintTextStyle}" Margin="0,0,0,10" TextWrapping="Wrap"/>

                                        <StackPanel Margin="20,6,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </Style>
                                            </StackPanel.Style>
                                            <ItemsControl ItemsSource="{Binding LocalConfig.CoordinateRules}" AlternationCount="1000">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="15"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="15"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel>
                                                                <TextBlock Text="X 坐标" Style="{StaticResource FieldLabelTextStyle}"/>
                                                                <TextBox Text="{Binding X}"
                                                                         Width="80"
                                                                         Style="{StaticResource ModernTextBoxStyle}"
                                                                         Tag="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                                                         GotFocus="CoordinateRuleField_GotFocus"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Y 坐标" Style="{StaticResource FieldLabelTextStyle}"/>
                                                                <TextBox Text="{Binding Y}"
                                                                         Width="80"
                                                                         Style="{StaticResource ModernTextBoxStyle}"
                                                                         Tag="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                                                         GotFocus="CoordinateRuleField_GotFocus"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="4">
                                                                <TextBlock Text="网址包含关键字" Style="{StaticResource FieldLabelTextStyle}"/>
                                                                <TextBox Text="{Binding UrlContains}"
                                                                         Style="{StaticResource ModernTextBoxStyle}"
                                                                         Tag="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                                                         GotFocus="CoordinateRuleField_GotFocus"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,6">
                                                <Button Content="+" Click="AddCoordinateRule_Click" Style="{StaticResource TextLinkButtonStyle}" VerticalAlignment="Center"/>
                                                
                                                <Button Content="⏱️ 3秒后拾取"
                                                        Click="PickCoordinate_Click"
                                                        Style="{StaticResource TextLinkButtonStyle}"
                                                        HorizontalAlignment="Left"
                                                        Margin="20,0,0,0"
                                                        VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Tab 2: AI Models -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <!-- AI Sub-Tab Navigation -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Button x:Name="BtnAiMainTab" Content="主界面" Padding="12,6" Margin="0,0,8,0" Click="AiSubTab_Click" Tag="Selected" Style="{StaticResource SubTabButtonStyle}"/>
                                        <Button x:Name="BtnAiMiniTab" Content="迷你" Padding="12,6" Margin="0,0,8,0" Click="AiSubTab_Click" Tag="1" Style="{StaticResource SubTabButtonStyle}"/>
                                        <Button x:Name="BtnAiTranslateTab" Content="翻译" Padding="12,6" Margin="0,0,8,0" Click="AiSubTab_Click" Tag="2" Style="{StaticResource SubTabButtonStyle}"/>
                                        <Button x:Name="BtnAiQuickActionTab" Content="划词助手" Padding="12,6" Margin="0,0,8,0" Click="AiSubTab_Click" Tag="3" Style="{StaticResource SubTabButtonStyle}"/>
                                    </StackPanel>

                                    <!-- Sub-Tab Content Container -->
                                    <StackPanel>
                                        <!-- 1. 主界面 Tab: Model Management -->
                                        <StackPanel x:Name="AiMainTab" Visibility="Visible">
                                            <StackPanel Margin="0,0,0,14">
                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="API 地址 (Base URL)" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding Config.AiBaseUrl}" Style="{StaticResource ModernTextBoxStyle}"/>
                                                </StackPanel>

                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="API Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding Config.AiApiKey}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                                </StackPanel>

                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="模型名称" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding Config.AiModel}" Style="{StaticResource ModernTextBoxStyle}"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <TextBlock x:Name="TestStatusText"
                                                               Text=""
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,10,0"
                                                               Style="{StaticResource HintTextStyle}"/>
                                                    <Button Content="测试连接" Click="TestAiConnection_Click" Style="{StaticResource TextLinkButtonStyle}" Foreground="{DynamicResource TextSecondary}" Margin="0,0,14,0"/>
                                                    <Button Content="保存模型" Command="{Binding AddAiModelCommand}" Style="{StaticResource TextLinkButtonStyle}" Foreground="{DynamicResource TextSecondary}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <TextBlock Text="已保存的模型" Style="{StaticResource FieldLabelTextStyle}" Margin="0,6,0,10"/>

                                            <ListBox ItemsSource="{Binding Config.SavedModels}"
                                                     SelectedValue="{Binding Config.ActiveModelId}"
                                                     SelectedValuePath="Id"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     SelectionMode="Single"
                                                     SelectionChanged="AiModelList_SelectionChanged">
                                                <ListBox.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ListBox.ItemsPanel>
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <Border x:Name="Chip"
                                                                            Background="{DynamicResource ShellBackground}"
                                                                            BorderBrush="{DynamicResource DividerBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="6"
                                                                            Padding="12,10"
                                                                            Margin="0,0,10,10"
                                                                            Width="180"
                                                                            Cursor="Hand"
                                                                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <Border Width="16" Height="16" CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource DividerColor}" Margin="0,0,10,0" VerticalAlignment="Center">
                                                                                <Path x:Name="CheckMark" Data="M2,5 L5,8 L10,2" Stroke="{StaticResource AccentColor}" StrokeThickness="2" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <TextBlock Grid.Column="1" Text="{Binding ModelName}" FontSize="14" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                                                                        </Grid>

                                                                        <Border.ContextMenu>
                                                                            <ContextMenu>
                                                                                <MenuItem Header="删除" Command="{Binding PlacementTarget.Tag.SettingsVM.DeleteAiModelCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                                            </ContextMenu>
                                                                        </Border.ContextMenu>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsSelected" Value="True">
                                                                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                                            <Setter TargetName="Chip" Property="Background" Value="{DynamicResource ListItemSelectedBackgroundBrush}"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Chip" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                            </ListBox>
                                        </StackPanel>

                                        <!-- 2. 迷你 Tab: Mini Window Model Selection -->
                                        <StackPanel x:Name="AiMiniTab" Visibility="Collapsed">
                                            <TextBlock Text="迷你窗口 AI 模型" Style="{StaticResource FieldLabelTextStyle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                            <TextBlock Text="选择迷你窗口使用的 AI 模型。留空则使用主界面的默认模型。" Style="{StaticResource HintTextStyle}" Margin="0,0,0,12"/>
                                            
                                            <ComboBox ItemsSource="{Binding Config.SavedModels}"
                                                      SelectedValuePath="Id"
                                                      SelectedValue="{Binding Config.MiniWindowModelId, Mode=TwoWay}"
                                                      DisplayMemberPath="ModelName"
                                                      Height="32"
                                                      MinWidth="250"/>
                                        </StackPanel>

                                        <!-- 3. 翻译 Tab: Translation Model Selection -->
                                        <StackPanel x:Name="AiTranslateTab" Visibility="Collapsed">
                                            <TextBlock Text="翻译功能 AI 模型" Style="{StaticResource FieldLabelTextStyle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                            <TextBlock Text="选择翻译功能使用的 AI 模型。留空则使用主界面的默认模型。" Style="{StaticResource HintTextStyle}" Margin="0,0,0,12"/>
                                            
                                            <ComboBox ItemsSource="{Binding Config.SavedModels}"
                                                      SelectedValuePath="Id"
                                                      SelectedValue="{Binding Config.TranslationModelId, Mode=TwoWay}"
                                                      DisplayMemberPath="ModelName"
                                                      Height="32"
                                                      MinWidth="250"
                                                      Margin="0,0,0,12"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                                <Button Content="测试翻译连接" Click="TestAiTranslationConnection_Click" HorizontalAlignment="Left" Style="{StaticResource TextLinkButtonStyle}" Margin="0,0,10,0"/>
                                                <TextBlock x:Name="TestAiTranslationStatusText" VerticalAlignment="Center" FontSize="13"/>
                                            </StackPanel>

                                            <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,0,0,20"/>

                                            <TextBlock Text="AI 翻译提示词" Style="{StaticResource FieldLabelTextStyle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                            
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <ComboBox Grid.Column="0" x:Name="AiTranslationPromptCombo2" 
                                                          ItemsSource="{Binding FilesView}"
                                                          SelectedValuePath="Id"
                                                          SelectedValue="{Binding Config.AiTranslationPromptId, Mode=TwoWay}"
                                                          DisplayMemberPath="Title"
                                                          Height="32"/>
                                                
                                                <Button Grid.Column="1" Content="跳转编辑" Margin="10,0,0,0" Padding="12,6"
                                                        Click="JumpToEditPrompt_Click"
                                                        Style="{StaticResource TextLinkButtonStyle}"/>
                                            </Grid>
                                        </StackPanel>

                                        <!-- 4. 划词 Tab: Quick Actions with Model Selection -->
                                        <StackPanel x:Name="AiQuickActionTab" Visibility="Collapsed">
                                            <TextBlock Text="划词助手配置" Style="{StaticResource FieldLabelTextStyle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                            <TextBlock Text="添加 BLOCK2 提示词到划词菜单，并为每个提示词指定专用模型。留空则使用主界面的默认模型。" Style="{StaticResource HintTextStyle}" Margin="0,0,0,16"/>
                                            
                                            <TextBlock Text="添加提示词" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <ComboBox Grid.Column="0" x:Name="QuickActionCandidateCombo" 
                                                          ItemsSource="{Binding FilesView}"
                                                          SelectedValuePath="Id"
                                                          DisplayMemberPath="Title"
                                                          Height="32"/>
                                                
                                                <Button Grid.Column="1" Content="添加" Margin="10,0,0,0" Padding="12,6"
                                                        Click="AddQuickAction_Click"
                                                        Style="{StaticResource TextLinkButtonStyle}"/>
                                            </Grid>

                                            <TextBlock Text="已配置的划词指令" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,10"/>
                                            
                                            <ListBox x:Name="QuickActionsListBox"
                                                     ItemsSource="{Binding LocalConfig.QuickActionPrompts}"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     SelectionMode="Single">
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <Border Background="{DynamicResource CardBackground}" 
                                                                            CornerRadius="6" 
                                                                            Padding="12,10" 
                                                                            Margin="0,0,0,8" 
                                                                            BorderBrush="{DynamicResource DividerColor}" 
                                                                            BorderThickness="1">
                                                                        <ContentPresenter/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="150"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                                            
                                                            <!-- Model Selector for each quick action -->
                                                            <ComboBox Grid.Column="1" 
                                                                      ItemsSource="{Binding DataContext.Config.SavedModels, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      SelectedValuePath="Id"
                                                                      SelectedValue="{Binding BoundModelId, Mode=TwoWay}"
                                                                      DisplayMemberPath="ModelName"
                                                                      SelectionChanged="QuickActionModel_SelectionChanged"
                                                                      Margin="10,0"
                                                                      VerticalAlignment="Center"
                                                                      ToolTip="选择专用模型 (留空则使用全局默认)"/>
                                                            
                                                            <Button Grid.Column="2" Content="移除" 
                                                                    Click="RemoveQuickAction_Click"
                                                                    Tag="{Binding}"
                                                                    Style="{StaticResource DangerLinkButtonStyle}"
                                                                    FontSize="12"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Tab 3: Sync -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="WebDAV 网址" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox Text="{Binding Config.WebDavUrl}" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="账号 (邮箱)" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox Text="{Binding Config.UserName}" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="应用密码" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <PasswordBox x:Name="WebDavPasswordBox"
                                                         PasswordChar="●"
                                                         Style="{StaticResource ModernPasswordBoxStyle}"
                                                         PasswordChanged="WebDavPasswordBox_PasswordChanged"
                                                         Loaded="WebDavPasswordBox_Loaded"/>
                                        </StackPanel>

                                        <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,6,0,14"/>

                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="从云端强制恢复数据"
                                                    Command="{Binding ShowRestoreConfirmCommand}"
                                                    ToolTip="注意：此操作将使用云端数据覆盖本地所有数据"
                                                    HorizontalAlignment="Left">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource DangerLinkButtonStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRestoreConfirmVisible}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>

                                            <Button Content="本地恢复数据"
                                                    Command="{Binding ManualLocalRestoreCommand}"
                                                    ToolTip="从本地历史备份中恢复数据"
                                                    HorizontalAlignment="Left"
                                                    Margin="20,0,0,0">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource TextLinkButtonStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRestoreConfirmVisible}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>

                                        <Border Margin="0,10,0,0"
                                                Background="#FFF7F7"
                                                BorderBrush="#F2C7C7"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRestoreConfirmVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="确定要覆盖吗？" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                    <Button Content="取消"
