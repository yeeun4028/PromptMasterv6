                                                               Text="点击提示词展示：点击后填入完整内容（关闭则组合发送）" 
                                                               VerticalAlignment="Center" 
                                                               Foreground="{DynamicResource TextPrimary}"/>
                                                    <CheckBox Grid.Column="2"
                                                              IsChecked="{Binding LocalConfig.MiniPinnedPromptClickShowsFullContent}"
                                                              Style="{StaticResource ToggleSwitchStyle}"
                                                              Cursor="Hand"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <!-- [热键] 标签页内容 -->
                                    <StackPanel x:Name="MiniWindowHotkeyTab" Visibility="Collapsed">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="260"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- AI查询设置 -->
                                            <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" 
                                                           Text="AI查询（默认聊天；前缀触发提示词匹配）"
                                                           Style="{StaticResource FieldLabelTextStyle}"
                                                           VerticalAlignment="Center"/>
                                                <CheckBox Grid.Column="2"
                                                          IsChecked="{Binding LocalConfig.MiniAiOnlyChatEnabled}"
                                                          Style="{StaticResource ToggleSwitchStyle}"
                                                          Content="启用"
                                                          Cursor="Hand"/>
                                            </Grid>

                                            <!-- 提示词匹配前缀 -->
                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                       Text="提示词匹配前缀"
                                                       Style="{StaticResource FieldLabelTextStyle}"
                                                       Margin="0,0,0,0"
                                                       VerticalAlignment="Center"/>
