                                                             IsEnabled="{Binding LocalConfig.MiniUseDefaultSize}"
                                                             Width="80"
                                                             Background="#2E3033"
                                                             Style="{StaticResource ModernTextBoxStyle}"/>
                                                    <TextBlock Text="/" Margin="8,0" VerticalAlignment="Center" Foreground="{DynamicResource PlaceholderTextBrush}"/>
