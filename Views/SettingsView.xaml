                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                                    <CheckBox IsChecked="{Binding IsEnableForScreenshotTranslate}" 
                                                                              Style="{StaticResource ToggleSwitchStyle}" 
                                                                              Cursor="Hand" 
                                                                              VerticalAlignment="Center"
                                                                              ToolTip="启用截图直译 (跳过 OCR，直接发送图片给 AI)"/>
                                                                    <TextBlock Text="{Binding DisplayName}" 
                                                                               VerticalAlignment="Center" 
                                                                               Margin="12,0,0,0" 
                                                                               Foreground="{DynamicResource TextPrimary}" 
                                                                               FontWeight="Medium"
                                                                               FontSize="14"/>
                                                                    <TextBlock Text="[Vision-to-Text]" 
                                                                               VerticalAlignment="Center" 
                                                                               Margin="8,0,0,0" 
                                                                               Foreground="{DynamicResource HintBrush}" 
                                                                               FontSize="11"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                        </ContentControl>
                                    </StackPanel>

                                    <!-- Sub-Tab Content: Baidu -->
                                    <StackPanel x:Name="ExternalToolsBaiduTab" Visibility="Collapsed">
