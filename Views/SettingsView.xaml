                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="ListBoxItem">
                                                                            <Border x:Name="Chip"
                                                                                    Background="{DynamicResource ShellBackground}"
                                                                                    BorderBrush="{DynamicResource DividerBrush}"
                                                                                    BorderThickness="1"
                                                                                    CornerRadius="6"
                                                                                    Padding="12,10"
                                                                                    Margin="0,0,0,8"
                                                                                    Cursor="Hand"
                                                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <Border Width="16" Height="16" CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource DividerColor}" Margin="0,0,10,0" VerticalAlignment="Center">
                                                                                        <Path x:Name="CheckMark" Data="M2,5 L5,8 L10,2" Stroke="{StaticResource AccentColor}" StrokeThickness="2" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                    </Border>
                                                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontSize="14" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                                                                                </Grid>

                                                                                <Border.ContextMenu>
                                                                                    <ContextMenu>
                                                                                        <MenuItem Header="重命名" Command="{Binding PlacementTarget.Tag.SettingsVM.RenameAiModelCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                                                        <MenuItem Header="删除" Command="{Binding PlacementTarget.Tag.SettingsVM.DeleteAiModelCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding}"/>
                                                                                    </ContextMenu>
                                                                                </Border.ContextMenu>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsSelected" Value="True">
                                                                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                                                    <Setter TargetName="Chip" Property="Background" Value="{DynamicResource ListItemSelectedBackgroundBrush}"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="Chip" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                    </ListBox>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <!-- 2. 迷你 Tab: Mini Window Model Selection -->
                                        <StackPanel x:Name="AiMiniTab" Visibility="Collapsed">
                                            <Border Style="{StaticResource CardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="迷你窗口 AI 模型" Style="{StaticResource FieldLabelTextStyle}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                                    
                                                    <TextBlock Text="选择迷你窗口使用的 AI 模型。留空则使用主界面的默认模型。" Style="{StaticResource HintTextStyle}" Margin="0,0,0,12"/>
                                                    
                                                    <ComboBox ItemsSource="{Binding Config.SavedModels}"
                                                              SelectedValuePath="Id"
                                                              SelectedValue="{Binding Config.MiniWindowModelId, Mode=TwoWay}"
                                                              DisplayMemberPath="DisplayName"
                                                              Style="{StaticResource ModernComboBoxStyle}"
                                                              HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>



                                        <!-- 4. 划词 Tab: Quick Actions with Model Selection -->
                                        <StackPanel x:Name="AiQuickActionTab" Visibility="Collapsed">
                                            <Border Style="{StaticResource CardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="划词助手配置" Style="{StaticResource FieldLabelTextStyle}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                                    <TextBlock Text="添加 BLOCK2 提示词到划词菜单，并为每个提示词指定专用模型。留空则使用主界面的默认模型。" Style="{StaticResource HintTextStyle}" Margin="0,0,0,20"/>
                                                    
                                                    <TextBlock Text="添加提示词" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,8"/>
                                                    <Grid Margin="0,0,0,20">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <ComboBox Grid.Column="0" x:Name="QuickActionCandidateCombo" 
                                                                  ItemsSource="{Binding FilesView}"
                                                                  SelectedValuePath="Id"
                                                                  DisplayMemberPath="Title"
                                                                  Style="{StaticResource ModernComboBoxStyle}"/>
                                                        
                                                        <Button Grid.Column="1" Content="添加" Margin="10,0,0,0" Padding="15,6"
                                                                Click="AddQuickAction_Click"
                                                                Style="{StaticResource TextLinkButtonStyle}"/>
                                                    </Grid>

                                                    <TextBlock Text="已配置的划词指令" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,10"/>
                                                    
                                                    <ListBox x:Name="QuickActionsListBox"
                                                             ItemsSource="{Binding LocalConfig.QuickActionPrompts}"
                                                             BorderThickness="0"
                                                             Background="Transparent"
                                                             SelectionMode="Single"
                                                             Margin="0,0,0,20">
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="ListBoxItem">
                                                                            <Border Background="{DynamicResource ShellBackground}" 
                                                                                    CornerRadius="6" 
                                                                                    Padding="12,10" 
                                                                                    Margin="0,0,0,8" 
                                                                                    BorderBrush="{DynamicResource DividerColor}" 
                                                                                    BorderThickness="1">
                                                                                <ContentPresenter/>
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="180"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                                                                    
                                                                    <!-- Model Selector for each quick action -->
                                                                    <ComboBox Grid.Column="1" 
                                                                              ItemsSource="{Binding DataContext.Config.SavedModels, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              SelectedValuePath="Id"
                                                                              SelectedValue="{Binding BoundModelId, Mode=TwoWay}"
                                                                              DisplayMemberPath="DisplayName"
                                                                              SelectionChanged="QuickActionModel_SelectionChanged"
                                                                              Style="{StaticResource ModernComboBoxStyle}"
                                                                              Margin="10,0"
                                                                              VerticalAlignment="Center"
                                                                              ToolTip="选择专用模型 (留空则使用全局默认)"/>
                                                                    
                                                                    <Button Grid.Column="2" Content="移除" 
                                                                            Click="RemoveQuickAction_Click"
                                                                            Tag="{Binding}"
                                                                            Style="{StaticResource DangerLinkButtonStyle}"
                                                                            FontSize="12"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                    
                                                    <!-- QuickAction Display Settings -->
                                                    <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,0,0,20"/>
                                                    
                                                    <TextBlock Text="显示设置" Style="{StaticResource FieldLabelTextStyle}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                                    
                                                    <StackPanel>
                                                        <TextBlock Text="提示词按钮显示方式" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,8"/>
                                                        <StackPanel Orientation="Horizontal">
                                                            <RadioButton GroupName="QuickActionDisplayMode" 
                                                                        Content="文本" 
                                                                        IsChecked="{Binding Config.QuickActionShowText}"
                                                                        Margin="0,0,20,0"
                                                                        Cursor="Hand"/>
                                                            
                                                            <RadioButton GroupName="QuickActionDisplayMode" 
                                                                        Content="仅图标"
                                                                        IsChecked="{Binding Config.QuickActionShowText, Converter={StaticResource InverseBoolConverter}}"
                                                                        Cursor="Hand"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Tab 3: Sync -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="云端同步" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="WebDAV 网址" Style="{StaticResource FieldLabelTextStyle}"/>
                                                <TextBox Text="{Binding Config.WebDavUrl}" Style="{StaticResource ModernTextBoxStyle}"/>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="账号 (邮箱)" Style="{StaticResource FieldLabelTextStyle}"/>
                                                <TextBox Text="{Binding Config.UserName}" Style="{StaticResource ModernTextBoxStyle}"/>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="应用密码" Style="{StaticResource FieldLabelTextStyle}"/>
                                                <PasswordBox x:Name="WebDavPasswordBox"
                                                             PasswordChar="●"
                                                             Style="{StaticResource ModernPasswordBoxStyle}"
                                                             PasswordChanged="WebDavPasswordBox_PasswordChanged"
                                                             Loaded="WebDavPasswordBox_Loaded"/>
                                            </StackPanel>

                                            <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,10,0,20"/>

                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="从云端强制恢复数据"
                                                        Command="{Binding ShowRestoreConfirmCommand}"
                                                        ToolTip="注意：此操作将使用云端数据覆盖本地所有数据"
                                                        HorizontalAlignment="Left">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource DangerLinkButtonStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRestoreConfirmVisible}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <Button Content="本地恢复数据"
                                                        Command="{Binding ManualLocalRestoreCommand}"
                                                        ToolTip="从本地历史备份中恢复数据"
                                                        HorizontalAlignment="Left"
                                                        Margin="20,0,0,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource TextLinkButtonStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRestoreConfirmVisible}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>


                                        <Border Margin="0,10,0,0"
                                                Background="#FFF7F7"
                                                BorderBrush="#F2C7C7"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRestoreConfirmVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="确定要覆盖吗？" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                    <Button Content="取消"
                                                            Command="{Binding CancelRestoreConfirmCommand}"
                                                            Style="{StaticResource TextLinkButtonStyle}"
                                                            Foreground="{DynamicResource TextSecondary}"
                                                            Margin="14,0,0,0"/>
                                                    <Button Content="确认覆盖"
                                                            Command="{Binding ManualRestoreCommand}"
                                                            Style="{StaticResource DangerLinkButtonStyle}"
                                                            Margin="14,0,0,0"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>

                                        <TextBlock Text="恢复操作会完全覆盖本地文件，请谨慎操作。"
                                                   Margin="0,10,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource HintTextStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRestoreConfirmVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Border Background="{DynamicResource CardBackground}"
                                                BorderBrush="{DynamicResource DividerColor}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,8"
                                                Margin="0,12,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RestoreStatus}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RestoreStatus}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding RestoreStatus}"
                                                       Foreground="{Binding RestoreStatusColor}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                        </Border>

                                        <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,20,0,14"/>

                                        <!-- Config Export/Import -->
                                        <TextBlock Text="配置迁移" 
                                                   Style="{StaticResource FieldLabelTextStyle}" 
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,10"/>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <Button Content="导出配置"
                                                    Command="{Binding SettingsVM.ExportConfigCommand}"
                                                    ToolTip="导出当前配置到文件 (config.json + local_settings.json)"
                                                    Style="{StaticResource TextLinkButtonStyle}"
                                                    Margin="0,0,20,0"/>

                                            <Button Content="导入配置"
                                                    Command="{Binding SettingsVM.ImportConfigCommand}"
                                                    ToolTip="从配置文件恢复设置 (覆盖当前配置)"
                                                    Style="{StaticResource TextLinkButtonStyle}"
                                                    Margin="0,0,0,0"/>
                                        </StackPanel>

                                        <TextBlock Text="仅导出配置信息 (Keys, URL, 快捷键等)，不包含提示词库。"
                                                   Style="{StaticResource HintTextStyle}"
                                                   Margin="0,10,0,0"/>

                                        <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,20,0,14"/>

                                        <!-- Log Management Section -->
                                        <TextBlock Text="日志管理" 
                                                   Style="{StaticResource FieldLabelTextStyle}" 
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,10"/>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <Button Content="打开日志文件夹"
                                                    Command="{Binding OpenLogFolderCommand}"
                                                    Style="{StaticResource TextLinkButtonStyle}"
                                                    Foreground="{DynamicResource TextSecondary}"
                                                    Margin="0,0,14,0"/>
                                            <Button Content="清除所有日志"
                                                    Command="{Binding ClearLogsCommand}"
                                                    Style="{StaticResource DangerLinkButtonStyle}"/>
                                        </StackPanel>

                                        <TextBlock Text="日志文件存储在 AppData\Local\PromptMasterv5\Logs 目录中"
                                                   Style="{StaticResource HintTextStyle}"
                                                   Margin="0,10,0,0"/>
                                    </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Tab 4: Mini Window -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="4">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <!-- Sub-Tab Navigation -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                        <Button x:Name="BtnMiniPromptTab" Content="提示词" Padding="12,6" Margin="0,0,8,0" Click="MiniWindowSubTab_Click" Tag="Selected" Style="{StaticResource SubTabButtonStyle}"/>
                                        <Button x:Name="BtnMiniHotkeyTab" Content="热键" Padding="12,6" Margin="0,0,8,0" Click="MiniWindowSubTab_Click" Tag="1" Style="{StaticResource SubTabButtonStyle}"/>
                                        <Button x:Name="BtnMiniLocationTab" Content="位置" Padding="12,6" Margin="0,0,8,0" Click="MiniWindowSubTab_Click" Tag="2" Style="{StaticResource SubTabButtonStyle}"/>
                                    </StackPanel>

                                    <!-- [提示词] 标签页内容 -->
                                    <StackPanel x:Name="MiniWindowPromptTab">
                                        <Border Style="{StaticResource CardStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="260"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="预选提示词"
                                                           FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                                                           VerticalAlignment="Center"/>
                                                <Grid Grid.Row="0" Grid.Column="1" Margin="10,0,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox Grid.Column="0"
                                                              x:Name="MiniPinnedPromptCandidateCombo"
                                                              ItemsSource="{Binding FilesView}"
                                                              SelectedValuePath="Id"
                                                              SelectedValue="{Binding LocalConfig.MiniPinnedPromptCandidateId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              DisplayMemberPath="Title"
                                                              Style="{StaticResource ModernComboBoxStyle}"/>
                                                    <Button Grid.Column="1"
                                                            Width="34"
                                                            Height="28"
                                                            Margin="8,0,0,0"
                                                            Content="+"
                                                            Click="AddMiniPinnedPrompt_Click"/>
                                                </Grid>

                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="已添加提示词（可拖拽排序）"
                                                           Style="{StaticResource FieldLabelTextStyle}"
                                                           Margin="0,12,0,0"
                                                           VerticalAlignment="Top"/>
                                                <ListBox Grid.Row="1" Grid.Column="1"
                                                         ItemsSource="{Binding ChatVM.MiniPinnedPrompts}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Margin="10,12,0,0"
                                                         dd:DragDrop.IsDragSource="True"
                                                         dd:DragDrop.IsDropTarget="True"
                                                         dd:DragDrop.DropHandler="{Binding MiniPinnedPromptDropHandler}">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding Title}"
                                                                           Foreground="{DynamicResource TextPrimary}"
                                                                           FontSize="13"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <Button Grid.Column="1"
                                                                        Content="删除"
                                                                        Margin="10,0,0,0"
                                                                        Command="{Binding DataContext.RemoveMiniPinnedPromptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>

                                                <!-- 底部显示提示词方式 -->
                                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,20,0,0">
                                                    <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,0,0,20"/>
                                                    <TextBlock Text="外观与行为"
                                                               FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                                                               Margin="0,0,0,15"
                                                               VerticalAlignment="Center"/>
                                                    
                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="底部显示图标" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                                                        <CheckBox Grid.Column="2"
                                                                  IsChecked="{Binding LocalConfig.MiniPinnedPromptShowIcons}"
                                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                                  Cursor="Hand"/>
                                                    </Grid>

                                                    <Grid Margin="0,0,0,12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="底部显示名称" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                                                        <CheckBox Grid.Column="2"
                                                                  IsChecked="{Binding LocalConfig.MiniPinnedPromptShowIcons, Converter={StaticResource InverseBoolConverter}}"
                                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                                  Cursor="Hand"/>
                                                    </Grid>

                                                    <!-- 点击提示词展示 -->
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Grid.Column="0" 
                                                                       Text="点击提示词仅填入不发送" 
                                                                       VerticalAlignment="Center" 
                                                                       Foreground="{DynamicResource TextPrimary}"/>
                                                            <TextBlock Text="（关闭则自动发送）" Margin="5,0,0,0" VerticalAlignment="Center" Style="{StaticResource HintTextStyle}"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="2"
                                                                  IsChecked="{Binding LocalConfig.MiniPinnedPromptClickShowsFullContent}"
                                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                                  Cursor="Hand"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <!-- [热键] 标签页内容 -->
                                    <StackPanel x:Name="MiniWindowHotkeyTab" Visibility="Collapsed">
                                        <Border Style="{StaticResource CardStyle}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="260"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- AI查询设置 -->
                                                <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Grid.Column="0" 
                                                                   Text="启用 AI 查询模式"
                                                                   FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="默认聊天模式；支持前缀触发提示词匹配" Style="{StaticResource HintTextStyle}" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                    <CheckBox Grid.Column="2"
                                                              IsChecked="{Binding LocalConfig.MiniAiOnlyChatEnabled}"
                                                              Style="{StaticResource ToggleSwitchStyle}"
                                                              Content="启用"
                                                              Cursor="Hand"/>
                                                </Grid>

                                                <Border Grid.Row="0" Grid.ColumnSpan="2" Height="1" Background="{DynamicResource DividerColor}" Margin="0,10,0,20" VerticalAlignment="Bottom"/>

                                                <!-- 提示词匹配前缀 -->
                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="提示词匹配前缀"
                                                           Style="{StaticResource FieldLabelTextStyle}"
                                                           Margin="0,0,0,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBox Grid.Row="1" Grid.Column="1"
