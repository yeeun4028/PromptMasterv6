                                                    <TextBlock Text="默认 AI 模型 (Default Model)" Style="{StaticResource FieldLabelTextStyle}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>
                                                    
                                                    <StackPanel Margin="0,0,0,20">
                                                        <ComboBox ItemsSource="{Binding Config.SavedModels}"
                                                                  SelectedValue="{Binding Config.ActiveModelId}"
                                                                  SelectedValuePath="Id"
                                                                  DisplayMemberPath="DisplayName"
                                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                                  HorizontalAlignment="Stretch"/>
                                                        <TextBlock Text="全系统默认使用的模型。个别功能（如截图翻译）可单独配置覆盖此设置。" Style="{StaticResource HintTextStyle}" Margin="0,6,0,0"/>
