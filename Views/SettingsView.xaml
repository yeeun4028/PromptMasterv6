                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Row 0: Screenshot Translate -->
                                                    <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,20">
                                                        <TextBlock Text="截图翻译" Style="{StaticResource FieldLabelTextStyle}"/>
                                                        <TextBlock Text="截取屏幕区域进行识别和翻译" Style="{StaticResource HintTextStyle}"/>
                                                    </StackPanel>
                                                    <TextBox Grid.Row="0" Grid.Column="1" 
                                                             x:Name="ScreenshotTranslateHotkeyTextBox" 
                                                             Text="{Binding Config.ScreenshotTranslateHotkey, Mode=TwoWay}"
                                                             Style="{StaticResource KeyRecorderStyle}"
                                                             Width="140"
                                                             IsReadOnly="True"
                                                             Cursor="Hand"
                                                             VerticalAlignment="Center"
                                                             PreviewKeyDown="ScreenshotTranslateHotkeyTextBox_PreviewKeyDown"
                                                             ToolTip="点击按下按键设置，按 Delete 清除"/>

                                                    <!-- Row 1: Selected Text Translate -->
                                                    <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="划词翻译" Style="{StaticResource FieldLabelTextStyle}"/>
                                                        <TextBlock Text="获取选中的文本进行翻译" Style="{StaticResource HintTextStyle}"/>
                                                    </StackPanel>
                                                    <TextBox Grid.Row="1" Grid.Column="1" 
                                                             x:Name="SelectedTextTranslateHotkeyTextBox"
                                                             Text="{Binding Config.SelectedTextTranslateHotkey, Mode=TwoWay}"
                                                             Style="{StaticResource KeyRecorderStyle}"
                                                             Width="140"
                                                             IsReadOnly="True"
                                                             Cursor="Hand"
                                                             VerticalAlignment="Center"
                                                             PreviewKeyDown="SelectedTextTranslateHotkeyTextBox_PreviewKeyDown"
                                                             ToolTip="点击按下按键设置，按 Delete 清除"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Group 3: Tools -->
                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="工具" Style="{StaticResource SectionHeaderTextStyle}"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Row 0: OCR -->
                                                    <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,20">
                                                        <TextBlock Text="OCR 识别" Style="{StaticResource FieldLabelTextStyle}"/>
                                                        <TextBlock Text="识别屏幕区域的文字" Style="{StaticResource HintTextStyle}"/>
                                                    </StackPanel>
                                                    <TextBox Grid.Row="0" Grid.Column="1" 
                                                             x:Name="OcrHotkeyTextBox" 
                                                             Text="{Binding Config.OcrHotkey, Mode=TwoWay}"
                                                             Style="{StaticResource KeyRecorderStyle}"
                                                             Width="140"
                                                             IsReadOnly="True"
                                                             Cursor="Hand"
                                                             VerticalAlignment="Center"
                                                             PreviewKeyDown="OcrHotkeyTextBox_PreviewKeyDown"
                                                             ToolTip="点击按下按键设置，按 Delete 清除"/>

                                                    <!-- Row 1: Quick Action -->
                                                    <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="划词扩展" Style="{StaticResource FieldLabelTextStyle}"/>
                                                        <TextBlock Text="对选中文本执行自定义扩展操作" Style="{StaticResource HintTextStyle}"/>
                                                    </StackPanel>
                                                    <TextBox Grid.Row="1" Grid.Column="1" 
                                                             x:Name="QuickActionHotkeyTextBox" 
                                                             Text="{Binding Config.QuickActionHotkey, Mode=TwoWay}"
                                                             Style="{StaticResource KeyRecorderStyle}"
                                                             Width="140"
                                                             IsReadOnly="True"
                                                             Cursor="Hand"
                                                             VerticalAlignment="Center"
                                                             PreviewKeyDown="QuickActionHotkeyTextBox_PreviewKeyDown"
                                                             ToolTip="点击按下按键设置，按 Delete 清除"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Tab 6: Launcher -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="6">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <StackPanel Margin="0,0,0,14">
                                        <!-- Card 1: General -->
                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="通用" Style="{StaticResource SectionHeaderTextStyle}"/>
                                                
                                                <Grid Margin="0,0,0,20">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="唤醒快捷键" Style="{StaticResource FieldLabelTextStyle}"/>
                                                        <TextBlock Text="全局呼出启动面板" Style="{StaticResource HintTextStyle}"/>
                                                    </StackPanel>
                                                    <TextBox Grid.Column="1" 
                                                             x:Name="LauncherHotkeyTextBox"
                                                             Text="{Binding Config.LauncherHotkey, Mode=TwoWay}" 
                                                             Style="{StaticResource KeyRecorderStyle}" 
                                                             Width="140" 
                                                             HorizontalAlignment="Right"
                                                             IsReadOnly="True"
                                                             Cursor="Hand"
                                                             PreviewKeyDown="LauncherHotkeyTextBox_PreviewKeyDown"
                                                             ToolTip="点击按下按键设置，按 Delete 清除"/>
                                                </Grid>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="管理员权限" Style="{StaticResource FieldLabelTextStyle}"/>
                                                        <TextBlock Text="以管理员身份运行所有启动项" Style="{StaticResource HintTextStyle}"/>
                                                    </StackPanel>
                                                    <CheckBox Grid.Column="1" IsChecked="{Binding Config.LauncherRunAsAdmin}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Card 2: Search Paths -->
                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="搜索文件夹" Style="{StaticResource SectionHeaderTextStyle}"/>
                                                <TextBlock Text="自动扫描以下文件夹内的快捷方式 (.lnk) 和脚本" Style="{StaticResource HintTextStyle}" Margin="0,0,0,15"/>

                                                <Border Background="{DynamicResource ShellBackground}" CornerRadius="6" Padding="8" Margin="0,0,0,15">
                                                    <ItemsControl ItemsSource="{Binding Config.LauncherSearchPaths}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border x:Name="ItemBorder" CornerRadius="4" Padding="10,8" Background="Transparent" Margin="0,0,0,2">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                                         <Button Grid.Column="1" Command="{Binding DataContext.SettingsVM.RemoveLauncherSearchPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                                 CommandParameter="{Binding}" 
                                                                                 Content="删除" 
                                                                                 Style="{StaticResource DangerLinkButtonStyle}" 
                                                                                 Margin="10,0,0,0"
                                                                                 Visibility="Hidden" 
                                                                                 x:Name="DeleteButton"/>
                                                                    </Grid>
                                                                </Border>
                                                                <DataTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                                        <Setter TargetName="DeleteButton" Property="Visibility" Value="Visible"/>
                                                                    </Trigger>
                                                                </DataTemplate.Triggers>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Border>

                                                 <Button Command="{Binding SettingsVM.AddLauncherSearchPathCommand}" Content="+ 添加文件夹" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Tab 1: Automation -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <StackPanel Margin="0,0,0,14">
                                        <!-- Coordinate Click Mode Card -->
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                                            <StackPanel>
                                                <TextBlock Text="坐标点击模式" Style="{StaticResource SectionHeaderTextStyle}"/>
                                                <TextBlock Text="软件隐藏后，强制点击屏幕上的指定位置来激活输入框。"
                                                           Style="{StaticResource HintTextStyle}" Margin="0,0,0,15" TextWrapping="Wrap"/>

                                                <ItemsControl ItemsSource="{Binding LocalConfig.CoordinateRules}" AlternationCount="1000">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,0,0,12">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="15"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="15"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <StackPanel>
                                                                    <TextBlock Text="X 坐标" Style="{StaticResource FieldLabelTextStyle}"/>
                                                                    <TextBox Text="{Binding X}"
                                                                             Width="80"
                                                                             Style="{StaticResource ModernTextBoxStyle}"
                                                                             Tag="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                                                             GotFocus="CoordinateRuleField_GotFocus"/>
                                                                </StackPanel>

                                                                <StackPanel Grid.Column="2">
                                                                    <TextBlock Text="Y 坐标" Style="{StaticResource FieldLabelTextStyle}"/>
                                                                    <TextBox Text="{Binding Y}"
                                                                             Width="80"
                                                                             Style="{StaticResource ModernTextBoxStyle}"
                                                                             Tag="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                                                             GotFocus="CoordinateRuleField_GotFocus"/>
                                                                </StackPanel>

                                                                <StackPanel Grid.Column="4">
                                                                    <TextBlock Text="网址包含关键字" Style="{StaticResource FieldLabelTextStyle}"/>
                                                                    <TextBox Text="{Binding UrlContains}"
                                                                             Style="{StaticResource ModernTextBoxStyle}"
                                                                             Tag="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                                                             GotFocus="CoordinateRuleField_GotFocus"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                    <Button Content="+" Click="AddCoordinateRule_Click" Style="{StaticResource TextLinkButtonStyle}" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                                                    
                                                    <Button Content="⏱️ 3秒后拾取"
                                                            Click="PickCoordinate_Click"
                                                            Style="{StaticResource TextLinkButtonStyle}"
                                                            HorizontalAlignment="Left"
                                                            Margin="20,0,0,0"
                                                            VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Default Web Target & Shortcuts Card -->
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                                            <StackPanel>
                                                <TextBlock Text="默认网页与发送" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,15"/>
                                                
                                                <StackPanel Margin="0,0,0,20">
                                                    <TextBlock Text="默认网页 AI (快捷键目标)" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,8"/>
                                                    <ComboBox ItemsSource="{Binding Config.WebDirectTargets}"
                                                              SelectedValue="{Binding Config.DefaultWebTargetName}"
                                                              SelectedValuePath="Name"
                                                              DisplayMemberPath="Name"
                                                              Style="{StaticResource ModernComboBoxStyle}"
                                                              HorizontalAlignment="Stretch"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                     <CheckBox IsChecked="{Binding Config.EnableDoubleEnterSend}" Style="{StaticResource ToggleSwitchStyle}" Cursor="Hand" VerticalAlignment="Center"/>
                                                    <TextBlock Text="启用双击回车发送消息" Style="{StaticResource FieldLabelTextStyle}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Block4 Icons Visibility Card -->
                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="BLOCK4 快捷图标显示" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,15"/>
                                                <TextBlock Text="选择在主界面 BLOCK4 区域显示的快捷图标。" Style="{StaticResource HintTextStyle}" Margin="0,0,0,15"/>

                                                <ItemsControl ItemsSource="{Binding Config.WebDirectTargets}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{DynamicResource ShellBackground}"
                                                                    BorderBrush="{DynamicResource DividerBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    Padding="10,6"
                                                                    Margin="0,0,10,10">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <CheckBox IsChecked="{Binding IsEnabled}" Style="{StaticResource ToggleSwitchStyle}" Cursor="Hand" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Tab 2: AI Models -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

