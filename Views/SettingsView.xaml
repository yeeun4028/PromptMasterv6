                                                    <TextBox Text="{Binding SettingsVM.BaiduOcrSecretKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                                </StackPanel>

                                                <Grid>
