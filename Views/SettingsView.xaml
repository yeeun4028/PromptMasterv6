<UserControl x:Class="PromptMasterv5.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dd="urn:gong-wpf-dragdrop"
             xmlns:models="clr-namespace:PromptMasterv5.Core.Models"
             xmlns:converters="clr-namespace:PromptMasterv5.Converters"
             xmlns:utils="clr-namespace:PromptMasterv5.Utils"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="750">
    <UserControl.Resources>
        <Color x:Key="AccentColorValue">#4183C4</Color>
        <SolidColorBrush x:Key="AccentColor" Color="{StaticResource AccentColorValue}"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#E53935"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#C62828"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <utils:InverseBoolConverter x:Key="InverseBoolConverter"/>

        <!-- Icons -->
        <Geometry x:Key="IconShortcut">M19,3H5C3.89,3 3,3.89 3,5V19C3,20.11 3.89,21 5,21H19C20.11,21 21,20.11 21,19V5C21,3.89 20.11,3 19,3M19,19H5V5H19V19M11,17H13V15H11V17M15,17H17V15H15V17M7,17H9V15H7V17M11,13H13V11H11V13M15,13H17V11H15V13M7,13H9V11H7V13M11,9H13V7H11V9M15,9H17V7H15V9M7,9H9V7H7V9Z</Geometry>
        <Geometry x:Key="IconModel">M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6M12,8A4,4 0 0,0 8,12A4,4 0 0,0 12,16A4,4 0 0,0 16,12A4,4 0 0,0 12,8Z</Geometry>
        <Geometry x:Key="IconMiniWindow">M19,13H5V11H19V13Z</Geometry>

        <!-- Tab Button Style -->
        <Style x:Key="ModernTabBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="15,0">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ListItemSelectedBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.03" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Fade In Animation -->
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="10" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style x:Key="FadeInContentStyle" TargetType="StackPanel">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource FadeInAnimation}"/>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="{DynamicResource ShellBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource InputFocusBackgroundBrush}"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource AccentColorValue}" Opacity="0.2" BlurRadius="4" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="{DynamicResource ShellBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource InputFocusBackgroundBrush}"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource AccentColorValue}" Opacity="0.2" BlurRadius="4" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="HintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource HintBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="TextLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="LinkText"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="13"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LinkText" Property="TextDecorations" Value="Underline"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="LinkText" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerLinkButtonStyle" TargetType="Button" BasedOn="{StaticResource TextLinkButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="LinkText"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="13"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LinkText" Property="TextDecorations" Value="Underline"/>
                                <Setter TargetName="LinkText" Property="Foreground" Value="{StaticResource DangerHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="LinkText" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Border x:Name="Border"
                                    Width="40" Height="22"
                                    CornerRadius="11"
                                    Background="{DynamicResource DividerBrush}"
                                    BorderBrush="{DynamicResource DividerBrush}"
                                    BorderThickness="1">
                                <Ellipse x:Name="Dot"
                                         Width="16" Height="16"
                                         Fill="White"
                                         HorizontalAlignment="Left"
                                         Margin="2,0,0,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0.1" BlurRadius="2" ShadowDepth="1"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="Dot" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Dot" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <!-- Modal Overlay -->
        <Border Background="#66000000">
            <!-- Main Settings Window -->
            <Border Width="750" Height="500" Background="{DynamicResource AppBackground}" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="25" ShadowDepth="0"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Sidebar -->
                    <Border Background="{DynamicResource SidebarBackground}" CornerRadius="12,0,0,12" BorderBrush="{DynamicResource DividerColor}" BorderThickness="0,0,1,0">
                        <StackPanel Margin="15,25">
                            <!-- Tab Buttons -->
                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="16" Height="16" Margin="0,1,12,1">
                                        <Path Data="{StaticResource IconShortcut}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                    </Viewbox>
                                    <TextBlock Text="快捷键" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="1">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="16" Height="16" Margin="0,1,12,1">
                                        <TextBlock Text="⚡" FontSize="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Viewbox>
                                    <TextBlock Text="自动化" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="2">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="16" Height="16" Margin="0,1,12,1">
                                        <Path Data="{StaticResource IconModel}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                    </Viewbox>
                                    <TextBlock Text="模型" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="3">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="16" Height="16" Margin="0,1,12,1">
                                        <TextBlock Text="☁️" FontSize="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Viewbox>
                                    <TextBlock Text="同步" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="4">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="4">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="16" Height="16" Margin="0,1,12,1">
                                        <Path Data="{StaticResource IconMiniWindow}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
                                    </Viewbox>
                                    <TextBlock Text="极简窗口" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="5">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="5">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="16" Height="16" Margin="0,1,12,1">
                                        <TextBlock Text="🛠️" FontSize="16" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Viewbox>
                                    <TextBlock Text="外部工具" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Right Content Area -->
                    <Grid Grid.Column="1" Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header with Close Button -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="{Binding SelectedSettingsTabName}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                            <Button Command="{Binding SaveSettingsCommand}" 
                                    Content="✕" FontSize="18" Foreground="#999"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Tab Contents -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                            <Grid>
                                <!-- Tab 0: Shortcut -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Row 1: Double Ctrl -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,20">
                                            <TextBlock Text="双击 Ctrl 键唤醒" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,4"/>
                                            <TextBlock Text="即使窗口最小化，也能立即唤醒。" Style="{StaticResource HintTextStyle}"/>
                                        </StackPanel>
                                        <CheckBox Grid.Row="0" Grid.Column="1" 
                                                  IsChecked="{Binding Config.EnableDoubleCtrl}" 
                                                  Style="{StaticResource ToggleSwitchStyle}"
                                                  Cursor="Hand"
                                                  VerticalAlignment="Center"/>

                                        <!-- Row 2: Full Window -->
                                        <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,20">
                                            <TextBlock Text="完整窗口" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,4"/>
                                            <TextBlock Text="支持单键或组合键；按下后强制唤出完整窗口，再按一次隐藏。" Style="{StaticResource HintTextStyle}"/>
                                        </StackPanel>
                                        <TextBox Grid.Row="1" Grid.Column="1" 
                                                 Text="{Binding Config.FullWindowHotkey}" 
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Width="140"
                                                 IsReadOnly="True"
                                                 Cursor="IBeam"
                                                 VerticalAlignment="Center"
                                                 PreviewKeyDown="FullWindowHotkeyTextBox_PreviewKeyDown"
                                                 ToolTip="点击按下按键设置，按 Delete 清除"/>

                                        <!-- Row 3: Mini Window -->
                                        <StackPanel Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="迷你窗口" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,4"/>
                                            <TextBlock Text="支持单键或组合键；按下后强制唤出迷你窗口，再按一次隐藏。" Style="{StaticResource HintTextStyle}"/>
                                        </StackPanel>
                                        <TextBox Grid.Row="2" Grid.Column="1" 
                                                 Text="{Binding Config.MiniWindowHotkey}"
                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                 Width="140"
                                                 IsReadOnly="True"
                                                 Cursor="IBeam"
                                                 VerticalAlignment="Center"
                                                 PreviewKeyDown="MiniWindowHotkeyTextBox_PreviewKeyDown"
                                                 ToolTip="点击按下按键设置，按 Delete 清除"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Tab 1: Automation -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <StackPanel Margin="0,0,0,14">
                                        <TextBlock Text="输入发送模式" Style="{StaticResource FieldLabelTextStyle}"/>

                                        <RadioButton GroupName="InputMode"
                                                     IsChecked="{Binding LocalConfig.Mode, Converter={converters:EnumToBoolConverter}, ConverterParameter=SmartFocus}"
                                                     Content="智能回退模式 (推荐)"
                                                     FontSize="14" Cursor="Hand" Margin="0,0,0,5" VerticalContentAlignment="Center"/>
                                        <TextBlock Text="软件隐藏后，自动将焦点还给上一个活动的窗口 (如浏览器输入框)，然后发送内容。"
                                                   Style="{StaticResource HintTextStyle}" Margin="20,0,0,12"/>

                                        <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,4,0,12"/>

                                        <RadioButton GroupName="InputMode"
                                                     IsChecked="{Binding LocalConfig.Mode, Converter={converters:EnumToBoolConverter}, ConverterParameter=CoordinateClick}"
                                                     Content="坐标点击模式"
                                                     FontSize="14" Cursor="Hand" Margin="0,0,0,5" VerticalContentAlignment="Center"/>
                                        <TextBlock Text="软件隐藏后，强制点击屏幕上的指定位置来激活输入框。"
                                                   Style="{StaticResource HintTextStyle}" Margin="20,0,0,10"/>

                                        <StackPanel Margin="20,6,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LocalConfig.Mode}" Value="CoordinateClick">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <ItemsControl ItemsSource="{Binding LocalConfig.CoordinateRules}" AlternationCount="1000">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="15"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="15"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel>
                                                                <TextBlock Text="X 坐标" Style="{StaticResource FieldLabelTextStyle}"/>
                                                                <TextBox Text="{Binding X}"
                                                                         Width="80"
                                                                         Style="{StaticResource ModernTextBoxStyle}"
                                                                         Tag="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                                                         GotFocus="CoordinateRuleField_GotFocus"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Y 坐标" Style="{StaticResource FieldLabelTextStyle}"/>
                                                                <TextBox Text="{Binding Y}"
                                                                         Width="80"
                                                                         Style="{StaticResource ModernTextBoxStyle}"
                                                                         Tag="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                                                         GotFocus="CoordinateRuleField_GotFocus"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="4">
                                                                <TextBlock Text="网址包含关键字" Style="{StaticResource FieldLabelTextStyle}"/>
                                                                <TextBox Text="{Binding UrlContains}"
                                                                         Style="{StaticResource ModernTextBoxStyle}"
                                                                         Tag="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                                                         GotFocus="CoordinateRuleField_GotFocus"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,6">
                                                <Button Content="+" Click="AddCoordinateRule_Click" Style="{StaticResource TextLinkButtonStyle}" VerticalAlignment="Center"/>
                                                <TextBlock Text="新增一行坐标规则（网址包含关键字为空时表示通用坐标）"
                                                           Style="{StaticResource HintTextStyle}"
                                                           Margin="10,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <Button Content="⏱️ 3秒后拾取"
                                                    Click="PickCoordinate_Click"
                                                    Style="{StaticResource TextLinkButtonStyle}"
                                                    HorizontalAlignment="Left"/>
                                            <TextBlock Text="* 点击拾取后请迅速移动鼠标到目标位置，等待3秒自动记录到当前焦点所在行。"
                                                       Style="{StaticResource HintTextStyle}"
                                                       Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Tab 2: AI Models -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <StackPanel Margin="0,0,0,14">
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="API 地址 (Base URL)" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox Text="{Binding Config.AiBaseUrl}" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="API Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox Text="{Binding Config.AiApiKey}" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="模型名称" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox Text="{Binding Config.AiModel}" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock x:Name="TestStatusText"
                                                       Text=""
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"
                                                       Style="{StaticResource HintTextStyle}"/>
                                            <Button Content="测试连接" Click="TestAiConnection_Click" Style="{StaticResource TextLinkButtonStyle}" Foreground="{DynamicResource TextSecondary}" Margin="0,0,14,0"/>
                                            <Button Content="保存模型" Command="{Binding AddAiModelCommand}" Style="{StaticResource TextLinkButtonStyle}" Foreground="{DynamicResource TextSecondary}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Text="已保存的模型" Style="{StaticResource FieldLabelTextStyle}" Margin="0,6,0,10"/>

                                    <ListBox ItemsSource="{Binding Config.SavedModels}"
                                             SelectedValue="{Binding Config.ActiveModelId}"
                                             SelectedValuePath="Id"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             SelectionMode="Single"
                                             SelectionChanged="AiModelList_SelectionChanged">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="Chip"
                                                                    Background="{DynamicResource ShellBackground}"
                                                                    BorderBrush="{DynamicResource DividerBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="6"
                                                                    Padding="12,10"
                                                                    Margin="0,0,10,10"
                                                                    Width="180"
                                                                    Cursor="Hand">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Width="16" Height="16" CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource DividerColor}" Margin="0,0,10,0" VerticalAlignment="Center">
                                                                        <Path x:Name="CheckMark" Data="M2,5 L5,8 L10,2" Stroke="{StaticResource AccentColor}" StrokeThickness="2" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <TextBlock Grid.Column="1" Text="{Binding ModelName}" FontSize="14" Foreground="{DynamicResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                                                                </Grid>

                                                                <Border.ContextMenu>
                                                                    <ContextMenu>
                                                                        <MenuItem Header="删除" Command="{Binding DataContext.DeleteAiModelCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                                                    </ContextMenu>
                                                                </Border.ContextMenu>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                                    <Setter TargetName="Chip" Property="Background" Value="{DynamicResource ListItemSelectedBackgroundBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Chip" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </StackPanel>

                                <!-- Tab 3: Sync -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="WebDAV 网址" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox Text="{Binding Config.WebDavUrl}" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="账号 (邮箱)" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox Text="{Binding Config.UserName}" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="应用密码" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <PasswordBox x:Name="WebDavPasswordBox"
                                                         PasswordChar="●"
                                                         Style="{StaticResource ModernPasswordBoxStyle}"
                                                         PasswordChanged="WebDavPasswordBox_PasswordChanged"
                                                         Loaded="WebDavPasswordBox_Loaded"/>
                                        </StackPanel>

                                        <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,6,0,14"/>

                                        <Button Content="从云端强制恢复数据"
                                                Command="{Binding ShowRestoreConfirmCommand}"
                                                ToolTip="注意：此操作将使用云端数据覆盖本地所有数据"
                                                HorizontalAlignment="Left">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource DangerLinkButtonStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRestoreConfirmVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <Border Margin="0,10,0,0"
                                                Background="#FFF7F7"
                                                BorderBrush="#F2C7C7"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRestoreConfirmVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="确定要覆盖吗？" Foreground="{StaticResource DangerBrush}" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                                    <Button Content="取消"
                                                            Command="{Binding CancelRestoreConfirmCommand}"
                                                            Style="{StaticResource TextLinkButtonStyle}"
                                                            Foreground="{DynamicResource TextSecondary}"
                                                            Margin="14,0,0,0"/>
                                                    <Button Content="确认覆盖"
                                                            Command="{Binding ManualRestoreCommand}"
                                                            Style="{StaticResource DangerLinkButtonStyle}"
                                                            Margin="14,0,0,0"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>

                                        <TextBlock Text="恢复操作会完全覆盖本地文件，请谨慎操作。"
                                                   Margin="0,10,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource HintTextStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRestoreConfirmVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Border Background="{DynamicResource CardBackground}"
                                                BorderBrush="{DynamicResource DividerColor}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="10,8"
                                                Margin="0,12,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RestoreStatus}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RestoreStatus}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding RestoreStatus}"
                                                       Foreground="{Binding RestoreStatusColor}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Tab 4: Mini Window -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="4">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <StackPanel Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="260"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="强制窗口置顶"
                                                       Style="{StaticResource FieldLabelTextStyle}"
                                                       VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="0" Grid.Column="1"
                                                     Text="{Binding LocalConfig.MiniAlwaysOnTopHotkeyPrefix, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="14"
                                                     Margin="10,0,0,0"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                       Text="AI查询（默认聊天；前缀触发提示词匹配）"
                                                       Style="{StaticResource FieldLabelTextStyle}"
                                                       Margin="0,12,0,0"
                                                       VerticalAlignment="Center"/>
                                            <CheckBox Grid.Row="1" Grid.Column="1"
                                                      IsChecked="{Binding LocalConfig.MiniAiOnlyChatEnabled}"
                                                      Content="启用"
                                                      Margin="10,12,0,0"
                                                      Cursor="Hand"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0"
                                                       Text="提示词匹配前缀"
                                                       Style="{StaticResource FieldLabelTextStyle}"
                                                       Margin="0,12,0,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="2" Grid.Column="1"
                                                     Text="{Binding LocalConfig.MiniPatternPrefix, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="14"
                                                     Margin="10,12,0,0"/>
                                        </Grid>

                                        <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,16,0,16"/>

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="260"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0"
                                                       Text="使用默认位置（忽略上次记忆）"
                                                       Style="{StaticResource FieldLabelTextStyle}"
                                                       VerticalAlignment="Center"/>
                                            <CheckBox Grid.Row="0" Grid.Column="1"
                                                      IsChecked="{Binding LocalConfig.MiniUseDefaultPosition}"
                                                      Content="启用"
                                                      Margin="10,0,0,0"
                                                      Cursor="Hand"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0"
                                                       Text="默认左下角坐标（Left / Bottom）"
                                                       Style="{StaticResource FieldLabelTextStyle}"
                                                       Margin="0,12,0,0"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="10,12,0,0">
                                                <TextBox Text="{Binding LocalConfig.MiniDefaultLeft}"
                                                         Width="70"
                                                         Style="{StaticResource ModernTextBoxStyle}"/>
                                                <TextBlock Text="/" Margin="6,0" VerticalAlignment="Center" Foreground="{DynamicResource PlaceholderTextBrush}"/>
                                                <TextBox Text="{Binding LocalConfig.MiniDefaultBottom}"
                                                         Width="70"
                                                         Style="{StaticResource ModernTextBoxStyle}"/>
                                                <Button Content="⏱️3秒拾取"
                                                        Click="PickMiniWindowDefaultPosition_Click"
                                                        Style="{StaticResource TextLinkButtonStyle}"
                                                        Margin="10,0,0,0"
                                                        VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <TextBlock Grid.Row="2" Grid.Column="0"
                                                       Text="默认宽度×高度 / 展开宽度"
                                                       Style="{StaticResource FieldLabelTextStyle}"
                                                       Margin="0,12,0,0"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="10,12,0,0">
                                                <TextBox Text="{Binding LocalConfig.MiniDefaultWidth}"
                                                         Width="70"
                                                         Style="{StaticResource ModernTextBoxStyle}"/>
                                                <TextBlock Text="×" Margin="6,0" VerticalAlignment="Center" Foreground="{DynamicResource PlaceholderTextBrush}"/>
                                                <TextBox Text="{Binding LocalConfig.MiniDefaultHeight}"
                                                         Width="70"
                                                         Style="{StaticResource ModernTextBoxStyle}"/>
                                                <TextBlock Text="/" Margin="6,0" VerticalAlignment="Center" Foreground="{DynamicResource PlaceholderTextBrush}"/>
                                                <TextBox Text="{Binding LocalConfig.MiniExpandedWidth}"
                                                         Width="70"
                                                         Style="{StaticResource ModernTextBoxStyle}"/>
                                            </StackPanel>

                                            <TextBlock Grid.Row="3" Grid.Column="0"
                                                       Text="预选提示词（BLOCK2 列表）"
                                                       Style="{StaticResource FieldLabelTextStyle}"
                                                       Margin="0,12,0,0"
                                                       VerticalAlignment="Center"/>
                                            <Grid Grid.Row="3" Grid.Column="1" Margin="10,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox Grid.Column="0"
                                                          x:Name="MiniPinnedPromptCandidateCombo"
                                                          ItemsSource="{Binding FilesView}"
                                                          SelectedValuePath="Id"
                                                          SelectedValue="{Binding LocalConfig.MiniPinnedPromptCandidateId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          DisplayMemberPath="Title"/>
                                                <Button Grid.Column="1"
                                                        Width="34"
                                                        Height="28"
                                                        Margin="8,0,0,0"
                                                        Content="+"
                                                        Click="AddMiniPinnedPrompt_Click"/>
                                            </Grid>

                                            <TextBlock Grid.Row="4" Grid.Column="0"
                                                       Text="已添加提示词（可拖拽排序）"
                                                       Style="{StaticResource FieldLabelTextStyle}"
                                                       Margin="0,12,0,0"
                                                       VerticalAlignment="Top"/>
                                            <ListBox Grid.Row="4" Grid.Column="1"
                                                     ItemsSource="{Binding ChatVM.MiniPinnedPrompts}"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Margin="10,12,0,0"
                                                     dd:DragDrop.IsDragSource="True"
                                                     dd:DragDrop.IsDropTarget="True"
                                                     dd:DragDrop.DropHandler="{Binding MiniPinnedPromptDropHandler}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Title}"
                                                                       Foreground="{DynamicResource TextPrimary}"
                                                                       FontSize="13"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <Button Grid.Column="1"
                                                                    Content="删除"
                                                                    Margin="10,0,0,0"
                                                                    Command="{Binding DataContext.RemoveMiniPinnedPromptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>

                                            <TextBlock Grid.Row="5" Grid.Column="0"
                                                       Text="迷你窗口底部显示提示词方式"
                                                       Style="{StaticResource FieldLabelTextStyle}"
                                                       Margin="0,12,0,0"
                                                       VerticalAlignment="Center"/>
                                            <CheckBox Grid.Row="5" Grid.Column="1"
                                                      IsChecked="{Binding LocalConfig.MiniPinnedPromptShowIcons}"
                                                      Content="显示图标（关闭则显示名称）"
                                                      Margin="10,12,0,0"
                                                      Cursor="Hand"/>

                                            <TextBlock Grid.Row="6" Grid.Column="0"
                                                       Text="点击提示词展示"
                                                       Style="{StaticResource FieldLabelTextStyle}"
                                                       Margin="0,12,0,0"
                                                       VerticalAlignment="Center"/>
                                            <CheckBox Grid.Row="6" Grid.Column="1"
                                                      IsChecked="{Binding LocalConfig.MiniPinnedPromptClickShowsFullContent}"
                                                      Content="点击后填入完整内容（关闭则组合发送）"
                                                      Margin="10,12,0,0"
                                                      Cursor="Hand"/>

                                            <TextBlock Grid.Row="7" Grid.Column="0"
                                                       Text="AI回复后输入清空"
                                                       Style="{StaticResource FieldLabelTextStyle}"
                                                       Margin="0,12,0,0"
                                                       VerticalAlignment="Center"/>
                                            <CheckBox Grid.Row="7" Grid.Column="1"
                                                      IsChecked="{Binding LocalConfig.MiniClearAiResultOnTyping}"
                                                      Content="输入新内容时清空AI回复（保留本次输入）"
                                                      Margin="10,12,0,0"
                                                      Cursor="Hand"/>
                                        </Grid>

                                        <TextBlock Text="说明：Enter=AI查询/匹配提示词（AI关闭时 Enter=发送到网页输入框）；Shift+Enter=换行；Ctrl+Enter/双击Enter=发送到网页输入框"
                                                   Style="{StaticResource HintTextStyle}"
                                                   Margin="0,10,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Tab 5: External Tools (OCR/Translate) -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="5">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <StackPanel Margin="0,0,0,14">
                                        <TextBlock Text="快捷键设置" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,8"/>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="150"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="截图 OCR (复制到剪贴板)" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                            <TextBox Grid.Row="0" Grid.Column="1"
                                                     Text="{Binding LocalConfig.OcrHotkey}"
                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                     IsReadOnly="True"
                                                     PreviewKeyDown="OcrHotkeyTextBox_PreviewKeyDown"
                                                     Margin="0,0,0,10"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="截图 翻译 (显示结果)" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBox Grid.Row="1" Grid.Column="1"
                                                     Text="{Binding LocalConfig.TranslateHotkey}"
                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                     IsReadOnly="True"
                                                     PreviewKeyDown="TranslateHotkeyTextBox_PreviewKeyDown"/>
                                        </Grid>

                                        <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,8,0,14"/>

                                        <!-- 功能绑定区域 -->
                                        <TextBlock Text="功能绑定 (选择下方列表中的配置)" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,8"/>
                                        <Grid Margin="0,0,0,16">
                                        <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="OCR 识别使用：" VerticalAlignment="Center" Margin="0,0,10,10"/>
                                        <ComboBox Grid.Row="0" Grid.Column="1" 
                                                  ItemsSource="{Binding Config.ApiProfiles}" 
                                                  SelectedValue="{Binding Config.OcrProfileId}"
                                                  SelectedValuePath="Id"
                                                  DisplayMemberPath="Name"
                                                  Margin="0,0,0,10"
                                                  Height="30"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="截图翻译使用：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <ComboBox Grid.Row="1" Grid.Column="1" 
                                                  ItemsSource="{Binding Config.ApiProfiles}" 
                                                  SelectedValue="{Binding Config.TranslateProfileId}"
                                                  SelectedValuePath="Id"
                                                  DisplayMemberPath="Name"
                                                  Height="30"/>
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,0,0,14"/>

                                    <!-- 配置列表区域 -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="API 配置列表" Style="{StaticResource FieldLabelTextStyle}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Button Content="+ 新增配置" Command="{Binding AddApiProfileCommand}" Style="{StaticResource TextLinkButtonStyle}"/>
                                    </StackPanel>

                                    <ListBox ItemsSource="{Binding Config.ApiProfiles}" 
                                             Background="Transparent" 
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource CardBackground}" CornerRadius="6" Padding="10" Margin="0,0,0,10" BorderBrush="{DynamicResource DividerColor}" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="名称：" FontSize="12" Foreground="#999" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,5"/>

                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Key1：" FontSize="12" Foreground="#999" VerticalAlignment="Center" Margin="0,0,5,0" ToolTip="OCR填API Key，翻译填AppID"/>
                                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Key1, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,5"/>

                                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Key2：" FontSize="12" Foreground="#999" VerticalAlignment="Center" Margin="0,0,5,0" ToolTip="Secret Key"/>
                                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Key2, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,5"/>
                                                        
                                                        <Button Grid.Row="3" Grid.Column="1" Content="删除此配置" 
                                                                Command="{Binding DataContext.DeleteApiProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource DangerLinkButtonStyle}" HorizontalAlignment="Right" FontSize="11"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    
                                    <TextBlock Text="提示：Key1 对应 OCR 的 API Key 或翻译的 AppID；Key2 对应 Secret Key。请创建两份配置分别用于 OCR 和 翻译，并在上方进行绑定。" 
                                               Style="{StaticResource HintTextStyle}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
