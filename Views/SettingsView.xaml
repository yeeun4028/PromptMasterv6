                                                <TextBlock Text="腾讯云 OCR 配置" Style="{StaticResource SectionHeaderTextStyle}"/>
                                                
                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="Secret Id" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding SettingsVM.TencentOcrSecretId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                                </StackPanel>

                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="Secret Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding SettingsVM.TencentOcrSecretKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                                </StackPanel>

