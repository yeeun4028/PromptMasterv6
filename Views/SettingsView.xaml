                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding SettingsVM.BaiduTranslateTestStatus}"
                                                               Foreground="{Binding SettingsVM.BaiduTranslateTestStatusColor}"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,10,0"/>
                                                    <Button Grid.Column="1"
                                                            Content="测试连接"
                                                            Command="{Binding SettingsVM.TestBaiduTranslateCommand}"
                                                            Style="{StaticResource TextLinkButtonStyle}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Sub-Tab Content: Tencent Cloud -->
                                    <StackPanel x:Name="ExternalToolsTencentTab" Visibility="Collapsed">
