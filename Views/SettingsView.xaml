                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding SettingsVM.TencentTranslateTestStatus}"
                                                               Foreground="{Binding SettingsVM.TencentTranslateTestStatusColor}"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,10,0"/>
