                                                    <TextBlock Text="Secret Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding SettingsVM.BaiduTranslateSecretKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                                </StackPanel>

