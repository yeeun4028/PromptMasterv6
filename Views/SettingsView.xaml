<UserControl x:Class="PromptMasterv5.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:models="clr-namespace:PromptMasterv5.Models"
             xmlns:utils="clr-namespace:PromptMasterv5.Utils"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="750">
    <UserControl.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="AppBackground" Color="#F1F1EF"/>
        <SolidColorBrush x:Key="SidebarBackground" Color="#F7F7F7"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="AccentColor" Color="#4183C4"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#333333"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#666666"/>
        <SolidColorBrush x:Key="DividerColor" Color="#E5E5E5"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <utils:InverseBoolConverter x:Key="InverseBoolConverter"/>

        <!-- Icons -->
        <Geometry x:Key="IconShortcut">M19,3H5C3.89,3 3,3.89 3,5V19C3,20.11 3.89,21 5,21H19C20.11,21 21,20.11 21,19V5C21,3.89 20.11,3 19,3M19,19H5V5H19V19M11,17H13V15H11V17M15,17H17V15H15V17M7,17H9V15H7V17M11,13H13V11H11V13M15,13H17V11H15V13M7,13H9V11H7V13M11,9H13V7H11V9M15,9H17V7H15V9M7,9H9V7H7V9Z</Geometry>
        <Geometry x:Key="IconModel">M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6M12,8A4,4 0 0,0 8,12A4,4 0 0,0 12,16A4,4 0 0,0 16,12A4,4 0 0,0 12,8Z</Geometry>
        <Geometry x:Key="IconMiniWindow">M19,13H5V11H19V13Z</Geometry>

        <!-- Tab Button Style -->
        <Style x:Key="ModernTabBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="15,0">
                            <Grid>
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <Border x:Name="Indicator" Width="4" Height="20" Background="{StaticResource AccentColor}" 
                                        HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-15,0,0,0"
                                        CornerRadius="0,2,2,0" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EAEAEA"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="border" Property="Background" Value="#E6EEF5"/>
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="8" ShadowDepth="1" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <!-- Modal Overlay -->
        <Border Background="#66000000">
            <!-- Main Settings Window -->
            <Border Width="750" Height="500" Background="{StaticResource AppBackground}" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.15" BlurRadius="25" ShadowDepth="0"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Sidebar -->
                    <Border Background="{StaticResource SidebarBackground}" CornerRadius="12,0,0,12" BorderBrush="{StaticResource DividerColor}" BorderThickness="0,0,1,0">
                        <StackPanel Margin="15,25">
                            <TextBlock Text="Settings" FontWeight="Bold" FontSize="20" Margin="10,0,0,25" Foreground="{StaticResource TextPrimary}"/>
                            
                            <!-- Tab Buttons -->
                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconShortcut}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="快捷键" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="1">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="16" Width="16" TextAlignment="Center" Margin="0,0,12,0" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="自动化" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="2">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconModel}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="模型" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="3">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="☁️" FontSize="16" Width="16" TextAlignment="Center" Margin="0,0,12,0" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <TextBlock Text="同步" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="4">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ModernTabBtnStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="4">
                                                <Setter Property="Tag" Value="Selected"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconMiniWindow}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="极简窗口" FontSize="14" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Right Content Area -->
                    <Grid Grid.Column="1" Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header with Close Button -->
                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="{Binding SelectedSettingsTabName}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            <Button Command="{Binding SaveSettingsCommand}" 
                                    Content="✕" FontSize="18" Foreground="#999"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="5">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Tab Contents -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                            <Grid>
                                <!-- Tab 0: Shortcut -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <CheckBox IsChecked="{Binding Config.EnableDoubleCtrl}" Cursor="Hand" Margin="0,0,0,10">
                                                <CheckBox.Content>
                                                    <TextBlock Text="双击 Ctrl 键唤醒/隐藏窗口" FontSize="15" Foreground="{StaticResource TextPrimary}" Margin="5,0,0,0"/>
                                                </CheckBox.Content>
                                            </CheckBox>
                                            <TextBlock Text="即使窗口最小化，按下此快捷键也能立即唤醒/隐藏程序。" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="24,0,0,0" FontSize="13"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="全局唤醒热键" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{StaticResource TextPrimary}"/>
                                            <TextBox Text="{Binding Config.GlobalHotkey}"
                                                     Style="{StaticResource ModernTextBoxStyle}"
                                                     IsReadOnly="True"
                                                     Cursor="IBeam"
                                                     PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                                     ToolTip="点击此处并按下键盘组合键来修改"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Tab 1: Automation -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="输入发送模式" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                                    
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <RadioButton GroupName="InputMode"
                                                         IsChecked="{Binding LocalConfig.Mode, Converter={models:EnumToBoolConverter}, ConverterParameter=SmartFocus}"
                                                         Content="智能回退模式 (推荐)"
                                                         FontSize="14" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,5"/>
                                            <TextBlock Text="软件隐藏后，自动将焦点还给上一个活动的窗口 (如浏览器输入框)，然后发送内容。"
                                                       Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="20,0,0,15" TextWrapping="Wrap"/>

                                            <Separator Background="{StaticResource DividerColor}" Margin="0,0,0,15"/>

                                            <RadioButton GroupName="InputMode"
                                                         IsChecked="{Binding LocalConfig.Mode, Converter={models:EnumToBoolConverter}, ConverterParameter=CoordinateClick}"
                                                         Content="坐标点击模式"
                                                         FontSize="14" FontWeight="SemiBold" Cursor="Hand" Margin="0,0,0,5"/>
                                            <TextBlock Text="软件隐藏后，强制点击屏幕上的指定位置来激活输入框。"
                                                       Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="20,0,0,10" TextWrapping="Wrap"/>

                                            <!-- Coordinate Settings -->
                                            <StackPanel Margin="20,10,0,0">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LocalConfig.Mode}" Value="CoordinateClick">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="15"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="X 坐标" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,5"/>
                                                        <TextBox Text="{Binding LocalConfig.ClickX}" Width="80" Style="{StaticResource ModernTextBoxStyle}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Y 坐标" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,5"/>
                                                        <TextBox Text="{Binding LocalConfig.ClickY}" Width="80" Style="{StaticResource ModernTextBoxStyle}"/>
                                                    </StackPanel>

                                                    <Button Grid.Column="4" Content="⏱️ 3秒后拾取" Click="PickCoordinate_Click"
                                                            Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Bottom"/>
                                                </Grid>
                                                <TextBlock Text="* 点击按钮后请迅速移动鼠标到目标位置，等待3秒自动记录。" Foreground="#999" FontSize="11" Margin="0,10,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Tab 2: AI Models -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="API 设置" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="{StaticResource TextPrimary}"/>
                                            
                                            <TextBlock Text="API 地址 (Base URL)" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Config.AiBaseUrl}" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15" ToolTip="例如: https://api.deepseek.com"/>

                                            <TextBlock Text="API Key" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Config.AiApiKey}" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

                                            <TextBlock Text="模型名称" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Config.AiModel}" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15" ToolTip="例如: deepseek-chat, qwen-turbo"/>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <TextBlock x:Name="TestStatusText" Text="" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{StaticResource TextSecondary}"/>
                                                <Button Content="测试连接" Click="TestAiConnection_Click" Background="#E0E0E0" Foreground="{StaticResource TextPrimary}" Padding="15,6" Margin="0,0,10,0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Content="保存模型" Command="{Binding AddAiModelCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="已保存的模型" FontWeight="Bold" Margin="0,10,0,10" Foreground="{StaticResource TextPrimary}"/>
                                    
                                    <ListBox ItemsSource="{Binding Config.SavedModels}"
                                             SelectedValue="{Binding Config.ActiveModelId}"
                                             SelectedValuePath="Id"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             SelectionMode="Single"
                                             SelectionChanged="AiModelList_SelectionChanged">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border Background="{StaticResource CardBackground}" 
                                                                    CornerRadius="8" 
                                                                    Padding="15,12" 
                                                                    Margin="0,0,10,10"
                                                                    Width="180"
                                                                    Cursor="Hand">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="Black" Opacity="0.03" BlurRadius="5" ShadowDepth="1" Direction="270"/>
                                                                </Border.Effect>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Width="16" Height="16" CornerRadius="8" BorderThickness="1" BorderBrush="{StaticResource DividerColor}" Margin="0,0,10,0" VerticalAlignment="Center">
                                                                         <Path x:Name="CheckMark" Data="M2,5 L5,8 L10,2" Stroke="{StaticResource AccentColor}" StrokeThickness="2" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <TextBlock Grid.Column="1" Text="{Binding ModelName}" FontSize="14" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                                                </Grid>
                                                                
                                                                <Border.ContextMenu>
                                                                    <ContextMenu>
                                                                        <MenuItem Header="删除" Command="{Binding DataContext.DeleteAiModelCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                                                    </ContextMenu>
                                                                </Border.ContextMenu>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Opacity" Value="0.8"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </StackPanel>

                                <!-- Tab 3: Sync -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="WebDAV 配置" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="{StaticResource TextPrimary}"/>
                                            
                                            <TextBlock Text="WebDAV 网址" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Config.WebDavUrl}" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

                                            <TextBlock Text="账号 (邮箱)" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Config.UserName}" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

                                            <TextBlock Text="应用密码" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                                            <PasswordBox x:Name="WebDavPasswordBox"
                                                         PasswordChar="●"
                                                         Padding="10,8"
                                                         Margin="0,0,0,20"
                                                         Background="#FAFAFA"
                                                         BorderBrush="#E0E0E0"
                                                         BorderThickness="1"
                                                         PasswordChanged="WebDavPasswordBox_PasswordChanged"
                                                         Loaded="WebDavPasswordBox_Loaded">
                                                <PasswordBox.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                    </Style>
                                                </PasswordBox.Resources>
                                            </PasswordBox>

                                            <Button Content="📥 从云端强制恢复数据" 
                                                    Command="{Binding ManualRestoreCommand}"
                                                    Background="#E53935" 
                                                    Foreground="White" 
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    HorizontalAlignment="Left"
                                                    ToolTip="注意：此操作将使用云端数据覆盖本地所有数据"/>
                                            
                                            <TextBlock Text="* 恢复操作会完全覆盖本地文件，请谨慎操作。" Foreground="#999" FontSize="12" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Tab 4: Mini Window -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="4">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="AI 助手行为" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="{StaticResource TextPrimary}"/>
                                            
                                            <CheckBox IsChecked="{Binding LocalConfig.MiniWindowUseAi}" Cursor="Hand" Margin="0,0,0,15">
                                                <CheckBox.Content>
                                                    <StackPanel>
                                                        <TextBlock Text="极简窗口默认使用 AI 查询" FontSize="14" Foreground="{StaticResource TextPrimary}" Margin="5,0,0,0"/>
                                                        <TextBlock Text="勾选后，无需使用 &quot;ai&quot; 前缀，直接输入即可" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="5,2,0,0"/>
                                                    </StackPanel>
                                                </CheckBox.Content>
                                            </CheckBox>

                                            <Separator Background="{StaticResource DividerColor}" Margin="0,0,0,15"/>

                                            <TextBlock Text="回车键 (Enter) 行为" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{StaticResource TextPrimary}"/>
                                            
                                            <RadioButton GroupName="MiniEnterMode"
                                                         IsChecked="{Binding LocalConfig.MiniEnterForAi}"
                                                         Content="Enter = AI 查询"
                                                         FontSize="14" Margin="0,0,0,8" Cursor="Hand"/>
                                            
                                            <RadioButton GroupName="MiniEnterMode"
                                                         IsChecked="{Binding LocalConfig.MiniEnterForAi, Converter={StaticResource InverseBoolConverter}}"
                                                         Content="Enter = 普通发送"
                                                         FontSize="14" Cursor="Hand"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>