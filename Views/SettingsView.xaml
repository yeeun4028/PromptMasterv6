                                                    <TextBlock Text="Secret Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding SettingsVM.TencentTranslateSecretKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
