                                                    </StackPanel>
                                                    <TextBox Grid.Row="1" Grid.Column="1" 
                                                             Text="{Binding Config.FullWindowHotkey}" 
                                                             Style="{StaticResource KeyRecorderStyle}"
                                                             Width="140"
                                                             IsReadOnly="True"
                                                             Cursor="Hand"
                                                             VerticalAlignment="Center"
                                                             PreviewKeyDown="FullWindowHotkeyTextBox_PreviewKeyDown"
                                                             ToolTip="点击按下按键设置，按 Delete 清除"/>

                                                    <!-- Row 2: Mini Window -->
                                                    <StackPanel Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="迷你窗口" Style="{StaticResource FieldLabelTextStyle}"/>
                                                        <TextBlock Text="显示精简的悬浮对话窗口" Style="{StaticResource HintTextStyle}"/>
                                                    </StackPanel>
                                                    <TextBox Grid.Row="2" Grid.Column="1" 
                                                             Text="{Binding Config.MiniWindowHotkey}"
                                                             Style="{StaticResource KeyRecorderStyle}"
                                                             Width="140"
                                                             IsReadOnly="True"
                                                             Cursor="Hand"
                                                             VerticalAlignment="Center"
                                                             PreviewKeyDown="MiniWindowHotkeyTextBox_PreviewKeyDown"
                                                             ToolTip="点击按下按键设置，按 Delete 清除"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- Group 2: Translation -->
                                        <Border Style="{StaticResource CardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="翻译" Style="{StaticResource SectionHeaderTextStyle}"/>
