                                                    <CheckBox Grid.Column="2"
                                                              IsChecked="{Binding LocalConfig.MiniPinnedPromptShowIcons, Converter={StaticResource InverseBoolConverter}}"
                                                              Style="{StaticResource ToggleSwitchStyle}"
