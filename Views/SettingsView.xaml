                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="Secret Id" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding SettingsVM.TencentTranslateSecretId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
