                                                            Style="{StaticResource TextLinkButtonStyle}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Sub-Tab Content: Youdao -->
                                    <StackPanel x:Name="ExternalToolsYoudaoTab" Visibility="Collapsed">
                                        <!-- Youdao OCR Card -->
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                                            <StackPanel>
                                                <TextBlock Text="有道 OCR 配置" Style="{StaticResource SectionHeaderTextStyle}"/>
                                                
                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="App Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding SettingsVM.YoudaoOcrAppKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                                                </StackPanel>

                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="App Secret" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding SettingsVM.YoudaoOcrAppSecret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Youdao Translate Card -->
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="有道翻译配置" Style="{StaticResource SectionHeaderTextStyle}"/>
                                                
                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="App Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding SettingsVM.YoudaoTranslateAppKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                                                </StackPanel>

                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="App Secret" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding SettingsVM.YoudaoTranslateAppSecret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                                </StackPanel>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding SettingsVM.YoudaoTestStatus}"
                                                               Foreground="{Binding SettingsVM.YoudaoTestStatusColor}"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,10,0"/>
                                                    <Button Grid.Column="1"
                                                            Content="测试连接"
                                                            Command="{Binding SettingsVM.TestYoudaoCommand}"
                                                            Style="{StaticResource TextLinkButtonStyle}"
                                                            IsEnabled="False"/>
                                                </Grid>

                                                <TextBlock Text="注意：有道后端集成将在未来版本中实现。"
                                                           Style="{StaticResource HintTextStyle}" Margin="0,10,0,0" Foreground="#FFA500"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Sub-Tab Content: Google -->
                                    <StackPanel x:Name="ExternalToolsGoogleTab" Visibility="Collapsed">
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Google 翻译配置" Style="{StaticResource SectionHeaderTextStyle}"/>
                                                
                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="API Base URL (可选, 支持 Cloudflare 代理)" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding SettingsVM.GoogleBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"
                                                             ToolTip="默认为 https://translation.googleapis.com。自定义地址示例：https://my-proxy.workers.dev"/>
                                                </StackPanel>

                                                <StackPanel Margin="0,0,0,12">
                                                    <TextBlock Text="API Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBox Text="{Binding SettingsVM.GoogleApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                                </StackPanel>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding SettingsVM.GoogleTestStatus}"
                                                               Foreground="{Binding SettingsVM.GoogleTestStatusColor}"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,10,0"/>
                                                    <Button Grid.Column="1"
                                                            Content="测试连接"
                                                            Command="{Binding SettingsVM.TestGoogleCommand}"
                                                            Style="{StaticResource TextLinkButtonStyle}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- 6. AI 翻译配置 Tab -->
                                    <StackPanel x:Name="ExternalToolsAiTranslateTab" Visibility="Collapsed">
                                        <!-- AI Translation Models Card -->
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                                            <StackPanel>
                                                <TextBlock Text="AI 翻译模型" Style="{StaticResource SectionHeaderTextStyle}"/>
                                                
                                                <ItemsControl ItemsSource="{Binding Config.SavedModels}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                                <CheckBox IsChecked="{Binding IsEnableForTranslation}" 
                                                                          Style="{StaticResource ToggleSwitchStyle}" 
                                                                          Cursor="Hand" 
                                                                          VerticalAlignment="Center" 
                                                                          ToolTip="启用翻译"/>
                                                                <TextBlock Text="{Binding DisplayName}" 
                                                                           VerticalAlignment="Center" 
                                                                           Margin="12,0,0,0" 
                                                                           Foreground="{DynamicResource TextPrimary}" 
                                                                           FontWeight="Medium"
                                                                           FontSize="14"/>
                                                                <TextBlock Text="{Binding BaseUrl}" 
                                                                           VerticalAlignment="Center" 
                                                                           Margin="10,0,0,0" 
                                                                           Foreground="{DynamicResource TextSecondary}" 
                                                                           FontSize="11" 
                                                                           Opacity="0.5" 
                                                                           TextTrimming="CharacterEllipsis" 
                                                                           MaxWidth="200"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                    <ItemsControl.Style>
                                                        <Style TargetType="ItemsControl">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Config.SavedModels.Count}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ItemsControl.Style>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <!-- AI OCR Models Card -->
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                                            <StackPanel>
                                                <TextBlock Text="AI OCR 模型" Style="{StaticResource SectionHeaderTextStyle}"/>
                                                
                                                <TextBlock Text="需要支持 Vision 能力的模型" 
                                                           Style="{StaticResource HintTextStyle}"
                                                           Margin="0,0,0,15"
                                                           TextWrapping="Wrap"/>
                                                
                                                <ItemsControl ItemsSource="{Binding Config.SavedModels}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                                <CheckBox IsChecked="{Binding IsEnableForOcr}" 
                                                                          Style="{StaticResource ToggleSwitchStyle}" 
                                                                          Cursor="Hand" 
                                                                          VerticalAlignment="Center" 
                                                                          ToolTip="启用 OCR (需支持 Vision 能力的模型)"/>
                                                                <TextBlock Text="{Binding DisplayName}" 
                                                                           VerticalAlignment="Center" 
                                                                           Margin="12,0,0,0" 
                                                                           Foreground="{DynamicResource TextPrimary}" 
                                                                           FontWeight="Medium"
                                                                           FontSize="14"/>
                                                                <TextBlock Text="[需要视觉能力]" 
                                                                           VerticalAlignment="Center" 
                                                                           Margin="8,0,0,0" 
                                                                           Foreground="{DynamicResource HintBrush}" 
                                                                           FontSize="11"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                    <ItemsControl.Style>
                                                        <Style TargetType="ItemsControl">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Config.SavedModels.Count}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ItemsControl.Style>
                                                </ItemsControl>
                                                
                                                <TextBlock Text="暂无可用模型" 
                                                           Foreground="{DynamicResource TextSecondary}" 
                                                           FontStyle="Italic"
                                                           Margin="0,0,0,0"
                                                           Style="{StaticResource EmptyModelHintStyle}"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Prompt Settings Card -->
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="预设提示词" Style="{StaticResource SectionHeaderTextStyle}"/>
                                                
                                                <StackPanel Margin="0,0,0,15">
                                                    <TextBlock Text="Prompt" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <ComboBox ItemsSource="{Binding FilesView}"
                                                              DisplayMemberPath="Title"
                                                              SelectedValuePath="Id"
                                                              SelectedValue="{Binding Config.AiTranslationPromptId, Mode=TwoWay}"
                                                              Margin="0,0,0,0"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
                                                    <TextBlock Text="{Binding SettingsVM.TranslationTestStatus}"
                                                               Foreground="{Binding SettingsVM.TranslationTestStatusColor}"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,15,0"
                                                               FontWeight="SemiBold"/>
                                                    <Button Content="测试勾选的模型"
                                                            Command="{Binding SettingsVM.TestAiTranslationConnectionCommand}"
                                                            Width="150"
                                                            Height="36"
                                                            Style="{StaticResource PrimaryButtonStyle}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>


                                </StackPanel>
                                <!-- Tab 9: Launch Bar -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="9">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <!-- Launch Bar Settings Card -->
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>


                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="启用屏幕左侧启动条" Style="{StaticResource FieldLabelTextStyle}" VerticalAlignment="Center"/>
                                                <CheckBox Grid.Column="1" 
                                                          IsChecked="{Binding Config.EnableLaunchBar}" 
                                                          Style="{StaticResource ToggleSwitchStyle}"
                                                          VerticalAlignment="Center"/>
                                            </Grid>

                                            <!-- Launch Bar Width Setting -->
                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="启动条宽度" Style="{StaticResource FieldLabelTextStyle}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBox Text="{Binding Config.LaunchBarWidth, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                                                             Style="{StaticResource ModernTextBoxStyle}"
                                                             Width="80"
                                                             HorizontalContentAlignment="Center"
                                                             VerticalAlignment="Center"
                                                             Height="30"
                                                             Padding="5,4"/>
                                                    <TextBlock Text="px" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource TextSecondary}"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Toggle Launch Bar Hotkey -->
                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="显示/隐藏启动条快捷键" Style="{StaticResource FieldLabelTextStyle}" VerticalAlignment="Center"/>
                                                <TextBox Grid.Column="1" 
                                                         x:Name="LaunchBarHotkeyTextBox"
                                                         Text="{Binding Config.LaunchBarHotkey, Mode=TwoWay}" 
                                                         Style="{StaticResource KeyRecorderStyle}"
                                                         Width="140"
                                                         IsReadOnly="True"
                                                         Cursor="Hand"
                                                         VerticalAlignment="Center"
                                                         PreviewKeyDown="LaunchBarHotkeyTextBox_PreviewKeyDown"
                                                         ToolTip="点击按下按键设置，按 Delete 清除"/>
                                            </Grid>



                                            <TextBlock Text="启动分段配置" Style="{StaticResource FieldLabelTextStyle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <TextBlock Text="颜色请使用 HEX 格式 (如 #FF4183C4)。" Style="{StaticResource HintTextStyle}" Margin="0,0,0,15"/>

                                            <Grid Margin="15,0,25,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"/>  <!-- Color Preview -->
                                                    <ColumnDefinition Width="100"/> <!-- Color Hex -->
                                                    <ColumnDefinition Width="105"/> <!-- Action Type -->
                                                    <ColumnDefinition Width="160"/> <!-- Action Target -->
                                                    <ColumnDefinition Width="*"/>   <!-- Label -->
                                                    <ColumnDefinition Width="90"/> <!-- Buttons -->
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="颜色" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="5,0"/>
                                                <TextBlock Grid.Column="2" Text="操作类型" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="5,0"/>
                                                <TextBlock Grid.Column="3" Text="执行目标" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="5,0"/>
                                                <TextBlock Grid.Column="4" Text="提示文字" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="5,0"/>
                                                <TextBlock Grid.Column="5" Text="操作" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Config.LaunchBarItems}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource ShellBackground}" BorderBrush="{DynamicResource DividerColor}" BorderThickness="1" CornerRadius="6" Padding="10,5" Margin="0,0,0,8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="30"/>  <!-- Color Preview -->
                                                                    <ColumnDefinition Width="100"/> <!-- Color Hex -->
                                                                    <ColumnDefinition Width="105"/> <!-- Action Type -->
                                                                    <ColumnDefinition Width="160"/> <!-- Action Target -->
                                                                    <ColumnDefinition Width="*"/>   <!-- Label -->
                                                                    <ColumnDefinition Width="90"/> <!-- Buttons -->
                                                                </Grid.ColumnDefinitions>
                                                                
                                                                <!-- Color Preview -->
                                                                <Rectangle Grid.Column="0" Width="10" Height="28" RadiusX="2" RadiusY="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,0">
                                                                    <Rectangle.Fill>
                                                                        <Binding Path="ColorHex">
                                                                            <Binding.Converter>
                                                                                <converters:HexToSolidColorBrushConverter/>
                                                                            </Binding.Converter>
                                                                        </Binding>
                                                                    </Rectangle.Fill>
                                                                </Rectangle>

                                                                <!-- Color Hex -->
                                                                <TextBox Grid.Column="1" Text="{Binding ColorHex, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Margin="5,0" VerticalAlignment="Center" Height="30" Padding="5,4"/>

                                                                <!-- Action Type -->
                                                                <ComboBox Grid.Column="2" SelectedValue="{Binding ActionType}" SelectedValuePath="Tag" Style="{StaticResource ModernComboBoxStyle}" Margin="5,0" VerticalAlignment="Center" Height="30" Padding="5,4,20,4">
                                                                    <ComboBoxItem Tag="{x:Static models:LaunchBarActionType.BuiltIn}" Content="内置功能"/>
                                                                    <ComboBoxItem Tag="{x:Static models:LaunchBarActionType.CustomApp}" Content="外部程序"/>
                                                                </ComboBox>

                                                                <!-- Action Target -->
                                                                <Grid Grid.Column="3" Margin="5,0" VerticalAlignment="Center">
                                                                    <TextBox Text="{Binding ActionTarget, UpdateSourceTrigger=PropertyChanged}" Height="30" Padding="5,4" ToolTip="外部程序绝对路径或命令">
                                                                        <TextBox.Style>
                                                                            <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBoxStyle}">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding ActionType}" Value="{x:Static models:LaunchBarActionType.CustomApp}">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBox.Style>
                                                                    </TextBox>
                                                                    <ComboBox SelectedValue="{Binding ActionTarget, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag" Height="30" Padding="5,4,20,4" ToolTip="请选择内置功能指令">
                                                                        <ComboBox.Style>
                                                                            <Style TargetType="ComboBox" BasedOn="{StaticResource ModernComboBoxStyle}">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding ActionType}" Value="{x:Static models:LaunchBarActionType.BuiltIn}">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </ComboBox.Style>
                                                                        <ComboBoxItem Tag="ToggleWindow" Content="主界面显示/隐藏"/>
                                                                        <ComboBoxItem Tag="Launcher" Content="快捷启动器"/>
                                                                        <ComboBoxItem Tag="Translate" Content="截图翻译"/>
                                                                        <ComboBoxItem Tag="Ocr" Content="截图文字识别"/>
                                                                        <ComboBoxItem Tag="PinImage" Content="贴图"/>
                                                                    </ComboBox>
                                                                </Grid>

                                                                <!-- Label -->
                                                                <TextBox Grid.Column="4" Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Margin="5,0" VerticalAlignment="Center" Height="30" Padding="5,4" ToolTip="鼠标悬停时显示的提示文字"/>

                                                                <!-- Buttons -->
                                                                <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <Button Command="{Binding DataContext.SettingsVM.MoveLaunchBarItemUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Width="28" Height="28" Margin="0,0,4,0" Style="{StaticResource IconButtonStyle}" ToolTip="上移">
                                                                        <Path Data="{StaticResource IconMoveUp}" Fill="{DynamicResource TextSecondary}" Stretch="Uniform" Width="14" Height="14"/>
                                                                    </Button>
                                                                    <Button Command="{Binding DataContext.SettingsVM.MoveLaunchBarItemDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Width="28" Height="28" Margin="0,0,4,0" Style="{StaticResource IconButtonStyle}" ToolTip="下移">
                                                                        <Path Data="{StaticResource IconMoveDown}" Fill="{DynamicResource TextSecondary}" Stretch="Uniform" Width="14" Height="14"/>
                                                                    </Button>
                                                                    <Button Command="{Binding DataContext.SettingsVM.RemoveLaunchBarItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Width="28" Height="28" Style="{StaticResource IconButtonStyle}" ToolTip="删除">
                                                                        <Path Data="{StaticResource IconDelete}" Fill="{StaticResource DangerBrush}" Stretch="Uniform" Width="14" Height="14"/>
                                                                    </Button>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Button Content="+ 添加新分段" 
                                                    Command="{Binding SettingsVM.AddLaunchBarItemCommand}"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,15,0,0"
                                                    Width="150" Height="36"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Tab 10: Proxy -->
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel" BasedOn="{StaticResource FadeInContentStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="10">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <!-- Proxy Settings Card -->
                                    <Border Style="{StaticResource CardStyle}">
                                        <StackPanel>
                                            <TextBlock Text="🌐 网络与代理设置" Style="{StaticResource SectionHeaderTextStyle}"/>
                                            
                                            <Grid Margin="0,0,0,15">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="全局 VPN 代理地址" Style="{StaticResource FieldLabelTextStyle}"/>
                                                    <TextBlock Text="例如 v2rayN 默认值为 http://127.0.0.1:10808。此地址仅对配置为【走VPN代理】的模型生效。" 
                                                               Style="{StaticResource HintTextStyle}" 
                                                               Margin="0,2,0,0"
                                                               TextWrapping="Wrap"
                                                               MaxWidth="400"/>
                                                </StackPanel>
                                                <TextBox Grid.Column="1" 
                                                         Text="{Binding SettingsVM.ProxyAddress, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                                                         Style="{StaticResource ModernTextBoxStyle}"
                                                         Width="250"
                                                         VerticalAlignment="Center"
                                                         Height="30"
                                                         Padding="8,4"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
    </Grid>
</UserControl>
