                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                                    </Trigger>
                                                                    <Trigger Property="Tag" Value="Selected">
                                                                        <Setter TargetName="border" Property="Background" Value="{StaticResource AccentColor}"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button x:Name="BtnYoudaoTab" Content="有道" Padding="12,6" Margin="0,0,8,0" Click="ExternalToolsSubTab_Click" Tag="3">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="border" Background="{TemplateBinding Background}" 
                                                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                                                        BorderThickness="{TemplateBinding BorderThickness}" 
                                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                                    </Trigger>
                                                                    <Trigger Property="Tag" Value="Selected">
                                                                        <Setter TargetName="border" Property="Background" Value="{StaticResource AccentColor}"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button x:Name="BtnGoogleTab" Content="Google" Padding="12,6" Margin="0,0,8,0" Click="ExternalToolsSubTab_Click" Tag="4">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="border" Background="{TemplateBinding Background}" 
                                                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                                                        BorderThickness="{TemplateBinding BorderThickness}" 
                                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                                    </Trigger>
                                                                    <Trigger Property="Tag" Value="Selected">
                                                                        <Setter TargetName="border" Property="Background" Value="{StaticResource AccentColor}"/>
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                        <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>

                                    <!-- Sub-Tab Content: Main Interface -->
                                    <StackPanel x:Name="ExternalToolsMainTab">
                                        <TextBlock Text="启用的供应商（同时控制翻译 + OCR）" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,12"/>
                                        
                                        <Grid Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Row 1 -->
                                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,12">
                                                <CheckBox IsChecked="{Binding Config.EnableBaidu}" Style="{StaticResource ToggleSwitchStyle}" Cursor="Hand" VerticalAlignment="Center"/>
                                                <TextBlock Text="百度" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                                                <CheckBox IsChecked="{Binding Config.EnableTencentCloud}" Style="{StaticResource ToggleSwitchStyle}" Cursor="Hand" VerticalAlignment="Center"/>
                                                <TextBlock Text="腾讯云" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Margin="0,0,0,12">
                                                <CheckBox IsChecked="{Binding Config.EnableYoudao}" Style="{StaticResource ToggleSwitchStyle}" Cursor="Hand" VerticalAlignment="Center"/>
                                                <TextBlock Text="有道" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </StackPanel>

                                            <!-- Row 2 -->
                                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,0">
                                                <CheckBox IsChecked="{Binding Config.EnableGoogle}" Style="{StaticResource ToggleSwitchStyle}" Cursor="Hand" VerticalAlignment="Center"/>
                                                <TextBlock Text="Google" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,0">
                                                <CheckBox IsChecked="{Binding Config.EnableAiTranslation}" Style="{StaticResource ToggleSwitchStyle}" Cursor="Hand" VerticalAlignment="Center"/>
                                                <TextBlock Text="AI 翻译" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                            <TextBlock Text="翻译后自动复制结果" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                            <CheckBox IsChecked="{Binding Config.AutoCopyTranslationResult}" Style="{StaticResource ToggleSwitchStyle}" Cursor="Hand" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- QuickAction Settings -->
                                        <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,10,0,20"/>
                                        
                                        <TextBlock Text="划词助手 (QuickAction)" 
                                                   Style="{StaticResource FieldLabelTextStyle}" 
                                                   FontSize="14" 
                                                   FontWeight="SemiBold" 
                                                   Margin="0,0,0,12"/>

                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Text="长文本处理方式" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,8"/>
                                            
                                            <RadioButton GroupName="LongTextMode" 
                                                        Content="外部编辑器打开 (默认)" 
                                                        IsChecked="{Binding Config.QuickActionLongTextMode, 
                                                                   Converter={StaticResource EnumToBoolConverter}, 
                                                                   ConverterParameter=ExternalEditor}"
                                                        Margin="0,0,0,8"/>
                                            
                                            <RadioButton GroupName="LongTextMode" 
                                                        Content="应用内大屏展开"
                                                        IsChecked="{Binding Config.QuickActionLongTextMode, 
                                                                   Converter={StaticResource EnumToBoolConverter}, 
                                                                   ConverterParameter=InternalExpand}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Text="触发阈值（AI 回复超过此行数时触发长文本处理）" 
                                                      Style="{StaticResource FieldLabelTextStyle}" 
                                                      Margin="0,0,0,8"/>
                                            <TextBox Text="{Binding Config.QuickActionLineThreshold, Mode=TwoWay}" 
                                                    Style="{StaticResource ModernTextBoxStyle}" 
                                                    Width="100" 
                                                    HorizontalAlignment="Left"/>
                                        </StackPanel>

                                        <TextBlock Text="提示：在外部编辑器模式下，长文本will be saved to QuickAction_Archive folder and opened automatically." 
                                                   Style="{StaticResource HintTextStyle}" 
                                                   Margin="0,10,0,0" 
                                                   TextWrapping="Wrap"/>

                                    </StackPanel>

                                    <!-- Sub-Tab Content: Baidu -->
                                    <StackPanel x:Name="ExternalToolsBaiduTab" Visibility="Collapsed">
                                        <TextBlock Text="百度 OCR 配置" Style="{StaticResource FieldLabelTextStyle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="API Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox x:Name="BaiduOcrApiKey" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Secret Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox x:Name="BaiduOcrSecretKey" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                        </StackPanel>

                                        <Button Content="测试 OCR 连接" Click="TestBaiduOcr_Click" 
                                                HorizontalAlignment="Left" Margin="0,0,0,16"
                                                Style="{StaticResource TextLinkButtonStyle}"/>

                                        <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,8,0,20"/>

                                        <TextBlock Text="百度翻译配置" Style="{StaticResource FieldLabelTextStyle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="App ID" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox x:Name="BaiduTranslateAppId" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Secret Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox x:Name="BaiduTranslateSecretKey" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                        </StackPanel>

                                        <Button Content="测试翻译连接" Click="TestBaiduTranslate_Click" 
                                                HorizontalAlignment="Left" Margin="0,0,0,16"
                                                Style="{StaticResource TextLinkButtonStyle}"/>

                                        <TextBlock Text="配置已保存到主配置中，将在启用百度供应商时生效。" 
                                                   Style="{StaticResource HintTextStyle}" Margin="0,10,0,0"/>
                                    </StackPanel>

                                    <!-- Sub-Tab Content: Tencent Cloud -->
                                    <StackPanel x:Name="ExternalToolsTencentTab" Visibility="Collapsed">
                                        <TextBlock Text="腾讯云 OCR 配置" Style="{StaticResource FieldLabelTextStyle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Secret Id" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox x:Name="TencentOcrSecretId" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Secret Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox x:Name="TencentOcrSecretKey" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                        </StackPanel>

                                        <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,8,0,20"/>

                                        <TextBlock Text="腾讯云翻译配置" Style="{StaticResource FieldLabelTextStyle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Secret Id" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox x:Name="TencentTranslateSecretId" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="Secret Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox x:Name="TencentTranslateSecretKey" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                        </StackPanel>

                                        <Button Content="测试连接（暂未实现）" Click="TestTencentCloud_Click" 
                                                HorizontalAlignment="Left" Margin="0,0,0,16"
                                                Style="{StaticResource TextLinkButtonStyle}"
                                                IsEnabled="False"/>

                                        <TextBlock Text="注意：腾讯云后端集成将在未来版本中实现。" 
                                                   Style="{StaticResource HintTextStyle}" Margin="0,10,0,0" Foreground="#FFA500"/>
                                    </StackPanel>

                                    <!-- Sub-Tab Content: Youdao -->
                                    <StackPanel x:Name="ExternalToolsYoudaoTab" Visibility="Collapsed">
                                        <TextBlock Text="有道 OCR 配置" Style="{StaticResource FieldLabelTextStyle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="App Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox x:Name="YoudaoOcrAppKey" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="App Secret" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox x:Name="YoudaoOcrAppSecret" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                        </StackPanel>

                                        <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,8,0,20"/>

                                        <TextBlock Text="有道翻译配置" Style="{StaticResource FieldLabelTextStyle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="App Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox x:Name="YoudaoTranslateAppKey" Style="{StaticResource ModernTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="App Secret" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox x:Name="YoudaoTranslateAppSecret" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                        </StackPanel>

                                        <Button Content="测试连接（暂未实现）" Click="TestYoudao_Click" 
                                                HorizontalAlignment="Left" Margin="0,0,0,16"
                                                Style="{StaticResource TextLinkButtonStyle}"
                                                IsEnabled="False"/>

                                        <TextBlock Text="注意：有道后端集成将在未来版本中实现。" 
                                                   Style="{StaticResource HintTextStyle}" Margin="0,10,0,0" Foreground="#FFA500"/>
                                    </StackPanel>

                                    <!-- Sub-Tab Content: Google -->
                                    <StackPanel x:Name="ExternalToolsGoogleTab" Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                            <CheckBox IsChecked="{Binding Config.EnableGoogle, Mode=TwoWay}"
                                                          Style="{StaticResource ToggleSwitchStyle}"/>
                                            <TextBlock Text="启用 Google 翻译" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="API Base URL (可选, 支持 Cloudflare 代理)" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox x:Name="GoogleBaseUrl" Style="{StaticResource ModernTextBoxStyle}"
                                                     ToolTip="默认为 https://translation.googleapis.com。自定义地址示例：https://my-proxy.workers.dev"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="API Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                            <TextBox x:Name="GoogleApiKey" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                        </StackPanel>

                                        <Button Content="测试连接" Click="TestGoogle_Click" 
                                                HorizontalAlignment="Left" Margin="0,0,0,16"
                                                Style="{StaticResource TextLinkButtonStyle}"/>
                                        
                                        <TextBlock Text="说明：Google 翻译只需要 API Key，不需要 Secret。" 
                                                   Style="{StaticResource HintTextStyle}" Margin="0,10,0,0"/>
                                    </StackPanel>


                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
