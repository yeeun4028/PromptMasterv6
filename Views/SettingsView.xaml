                                                <TextBlock Text="翻译引擎" Style="{StaticResource SectionHeaderTextStyle}"/>
                                                
                                                <ItemsControl ItemsSource="{Binding ExternalToolsVM.TranslateProfiles}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                                <CheckBox IsChecked="{Binding IsEnabled}" 
                                                                          Style="{StaticResource ToggleSwitchStyle}" 
                                                                          Cursor="Hand" 
                                                                          VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Name}" 
                                                                           VerticalAlignment="Center" 
                                                                           Margin="12,0,0,0" 
                                                                           Foreground="{DynamicResource TextPrimary}"
                                                                           FontSize="14"/>
                                                                <TextBlock Text="{Binding ProviderDisplayName, StringFormat='({0})'}" 
                                                                           VerticalAlignment="Center" 
                                                                           Margin="8,0,0,0" 
                                                                           Foreground="{DynamicResource TextSecondary}" 
                                                                           FontSize="12"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <!-- Quick Settings Card -->
