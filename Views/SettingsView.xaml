                                            <TextBlock Text="语音控制配置 (Voice Control)" 
                                                       Style="{StaticResource FieldLabelTextStyle}" 
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,15"/>

                                            <!-- API Configuration -->
                                            <TextBlock Text="AI 模型设置" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,12"/>
                                            
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="选择用于语音识别的模型" Style="{StaticResource FieldLabelTextStyle}"/>
                                                <ComboBox ItemsSource="{Binding Config.SavedModels}"
                                                          DisplayMemberPath="DisplayName"
                                                          SelectedValuePath="Id"
                                                          SelectedValue="{Binding Config.VoiceModelId}"
                                                          Style="{StaticResource ModernComboBoxStyle}"
                                                          Height="35"
                                                          Margin="0,5,0,0"/>
                                                <TextBlock Text="请确保所选模型支持音频转录 (例如 whisper-1)。" 
                                                           Style="{StaticResource HintTextStyle}" 
                                                           Margin="0,5,0,0"/>
                                            </StackPanel>

                                            <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,8,0,20"/>

                                            <!-- Trigger Configuration -->
                                            <TextBlock Text="触发设置" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,12"/>

                                            <StackPanel Margin="0,0,0,20">
                                                <TextBlock Text="语音控制快捷键" Style="{StaticResource FieldLabelTextStyle}"/>
                                                <TextBox Text="{Binding Config.VoiceTriggerHotkey}" 
                                                         Style="{StaticResource ModernTextBoxStyle}"
                                                         Width="140"
                                                         HorizontalAlignment="Left"
                                                         IsReadOnly="True"
                                                         Cursor="IBeam"
                                                         PreviewKeyDown="VoiceTriggerHotkeyTextBox_PreviewKeyDown"
                                                         ToolTip="点击按下按键设置，按 Delete 清除"/>
                                            </StackPanel>

                                            <Border Height="1" Background="{DynamicResource DividerColor}" Margin="0,8,0,20"/>

                                            <!-- Commands Configuration -->
                                            <TextBlock Text="指令配置" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,12"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Button Content="打开指令配置文件 (voice_commands.json)"
                                                        Command="{Binding SettingsVM.OpenVoiceCommandsConfigCommand}"
                                                        Style="{StaticResource TextLinkButtonStyle}"/>
                                            </StackPanel>
                                            
                                            <TextBlock Text="在配置文件中添加 '指令词': '程序路径' 的映射。例如：&quot;打开计算器&quot;: &quot;calc.exe&quot;" 
                                                       Style="{StaticResource HintTextStyle}" 
                                                       Margin="0,5,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
