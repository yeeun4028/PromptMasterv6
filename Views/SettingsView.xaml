                                        <Button x:Name="BtnExternalAiTranslateTab" Content="AI 翻译配置" Padding="12,6" Margin="0,0,8,0" Click="ExternalToolsSubTab_Click" Tag="5" Style="{StaticResource SubTabButtonStyle}"/>
                                    </StackPanel>

                                    <!-- Sub-Tab Content: Main Interface -->
                                    <StackPanel x:Name="ExternalToolsMainTab">
