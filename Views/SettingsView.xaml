                                                          IsChecked="{Binding LocalConfig.MiniClearAiResultOnTyping}"
                                                          Style="{StaticResource ToggleSwitchStyle}"
                                                          Cursor="Hand"/>
                                            </Grid>
                                        </Grid>

                                        <TextBlock Text="说明：Enter=AI查询/匹配提示词（AI关闭时 Enter=发送到网页输入框）；Shift+Enter=换行；Ctrl+Enter/双击Enter=发送到网页输入框"
                                                   Style="{StaticResource HintTextStyle}"
                                                   Margin="0,16,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

