                                                    <StackPanel DataContext="{Binding SettingsVM}">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SelectedSavedModel}" Value="{x:Null}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>

                                                        <TextBlock Text="编辑选中的模型" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,15" FontSize="15" FontWeight="SemiBold"/>

                                                        <StackPanel Margin="0,0,0,12">
                                                            <TextBlock Text="API 地址 (Base URL)" Style="{StaticResource FieldLabelTextStyle}"/>
                                                            <TextBox Text="{Binding SelectedSavedModel.BaseUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                                                        </StackPanel>

                                                        <StackPanel Margin="0,0,0,12">
                                                            <TextBlock Text="API Key" Style="{StaticResource FieldLabelTextStyle}"/>
                                                            <TextBox Text="{Binding SelectedSavedModel.ApiKey, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ApiKeyTextBoxStyle}"/>
                                                        </StackPanel>

                                                        <StackPanel Margin="0,0,0,12">
                                                            <TextBlock Text="模型名称 (Model ID)" Style="{StaticResource FieldLabelTextStyle}"/>
                                                            <TextBox Text="{Binding SelectedSavedModel.ModelName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                                                        </StackPanel>
                                                        
                                                         <StackPanel Margin="0,0,0,12">
                                                            <TextBlock Text="备注名称 (Display Name)" Style="{StaticResource FieldLabelTextStyle}"/>
                                                            <TextBox Text="{Binding SelectedSavedModel.Remark, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}"/>
                                                        </StackPanel>

                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                                            <TextBlock x:Name="TestStatusText"
                                                                       Text="{Binding TestStatus}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,15,0"
                                                                       Style="{StaticResource HintTextStyle}"/>
