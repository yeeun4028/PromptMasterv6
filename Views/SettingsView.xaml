                                                                Command="{Binding ClearLogsCommand}"
                                                                Style="{StaticResource DangerLinkButtonStyle}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>



