<Window x:Class="PromptMasterv5.Views.PinToScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="贴图"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        MouseDown="Window_MouseDown"
        MouseMove="Window_MouseMove"
        MouseUp="Window_MouseUp"
        MouseWheel="Window_MouseWheel"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">

    <Window.Resources>
        <!-- 工具栏样式 -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- 边框 -->
        <Border x:Name="ImageBorder"
                Background="Transparent"
                BorderBrush="{Binding BorderColor, RelativeSource={RelativeSource AncestorType=Window}}"
                BorderThickness="{Binding BorderSize, RelativeSource={RelativeSource AncestorType=Window}}"
                CornerRadius="4">
            <Border.Effect>
                <DropShadowEffect x:Name="ShadowEffect"
                                  Color="Black"
                                  BlurRadius="15"
                                  ShadowDepth="3"
                                  Opacity="0.3"
                                  Direction="315"/>
            </Border.Effect>

            <!-- 图片显示 -->
            <Image x:Name="PinnedImage"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <!-- 工具栏 -->
        <Border x:Name="Toolbar"
                Background="#CC000000"
                CornerRadius="4"
                Padding="8,4"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,10,0,0"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="复制"
                        Click="CopyButton_Click"
                        ToolTip="复制图片到剪贴板 (Ctrl+C)"/>
                <TextBlock x:Name="ScaleText"
                           Text="100%"
                           Foreground="White"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="8,0"
                           Cursor="Hand"
                           MouseLeftButtonDown="ScaleText_MouseLeftButtonDown"
                           ToolTip="点击重置为100%"/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Content="关闭"
                        Click="CloseButton_Click"
                        ToolTip="关闭贴图 (右键)"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
