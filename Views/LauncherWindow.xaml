<Window x:Class="PromptMasterv5.Views.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PromptMasterv5.ViewModels"
        xmlns:converters="clr-namespace:PromptMasterv5.Converters"
        mc:Ignorable="d"
        Title="Launcher" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False" Topmost="True"
        Deactivated="Window_Deactivated" KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <converters:CountToVisibilityConverter x:Key="CountToVis"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- UI Template for items -->
        <DataTemplate x:Key="LauncherItemTemplate">
            <Button x:Name="ItemButton"
                    Command="{Binding DataContext.ExecuteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                    CommandParameter="{Binding}"
                    Margin="16" Width="55" Height="55" ClipToBounds="False"
                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                    AllowDrop="True" Drop="ItemButton_Drop"
                    PreviewMouseLeftButtonDown="ItemButton_MouseLeftButtonDown"
                    PreviewMouseMove="ItemButton_MouseMove"
                    PreviewMouseLeftButtonUp="ItemButton_MouseLeftButtonUp">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent" ClipToBounds="False">
                            
                            <!-- 图标名称（悬停时显示） -->
                            <TextBlock x:Name="NameText" Text="{Binding Title}" 
                                       HorizontalAlignment="Center" VerticalAlignment="Top"
                                       Foreground="#E0E0E0" FontSize="14" FontWeight="Medium"
                                       Opacity="0" IsHitTestVisible="False"
                                       TextTrimming="CharacterEllipsis" MaxWidth="100">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="NameTextTranslate" X="0" Y="0"/>
                                </TextBlock.RenderTransform>
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="1" Opacity="0.5" Direction="270"/>
                                </TextBlock.Effect>
                            </TextBlock>

                            <!-- 图标容器（带形变动画） -->
                            <Grid x:Name="CardGrid" Width="55" Height="55"
                                  HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.RenderTransform>
                                    <TranslateTransform x:Name="CardTranslate" X="0" Y="0"/>
                                </Grid.RenderTransform>
                                
                                <Rectangle x:Name="CardBg" RadiusX="18" RadiusY="18">
                                    <Rectangle.Fill>
                                        <SolidColorBrush x:Name="CardBackground" Color="#1E1E1E"/>
                                    </Rectangle.Fill>
                                    <Rectangle.Effect>
                                        <DropShadowEffect x:Name="CardShadow" Color="Black" BlurRadius="5" ShadowDepth="2" Opacity="0.2" Direction="270"/>
                                    </Rectangle.Effect>
                                </Rectangle>
                                
                                <Border x:Name="CardImageBorder" CornerRadius="18" 
                                        Visibility="{Binding CustomImagePath, Converter={StaticResource StringToVis}}">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding CustomImagePath}" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>

                                <Grid Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <Grid x:Name="VectorContent" Visibility="{Binding CustomImagePath, Converter={StaticResource StringToVisInverted}}">
                                        <Path Data="{Binding IconGeometry}" 
                                              Visibility="{Binding IconGeometry, Converter={StaticResource StringToVis}}"
                                              Fill="#4A90D9" 
                                              Stretch="Uniform" />
                                        <Path Data="M13,9V3.5L18.5,9M6,2C4.89,2 4,2.89 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2H6Z"
                                              Visibility="{Binding IconGeometry, Converter={StaticResource StringToVisInverted}}"
                                              Fill="#888888" 
                                              Stretch="Uniform" Opacity="0.7"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CardGrid" Storyboard.TargetProperty="Width" To="30" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardGrid" Storyboard.TargetProperty="Height" To="30" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardBg" Storyboard.TargetProperty="RadiusX" To="15" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardBg" Storyboard.TargetProperty="RadiusY" To="15" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="CardTranslate" Storyboard.TargetProperty="Y" To="10" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            
                                            <ColorAnimation Storyboard.TargetName="CardBackground" Storyboard.TargetProperty="Color" To="#252525" Duration="0:0:0.4">
                                                <ColorAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            
                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="BlurRadius" To="12" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="ShadowDepth" To="6" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="Opacity" To="0.3" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            
                                            <DoubleAnimation Storyboard.TargetName="NameText" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="NameTextTranslate" Storyboard.TargetProperty="Y" To="-10" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CardGrid" Storyboard.TargetProperty="Width" To="55" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardGrid" Storyboard.TargetProperty="Height" To="55" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardBg" Storyboard.TargetProperty="RadiusX" To="18" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardBg" Storyboard.TargetProperty="RadiusY" To="18" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="CardTranslate" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            
                                            <ColorAnimation Storyboard.TargetName="CardBackground" Storyboard.TargetProperty="Color" To="#1E1E1E" Duration="0:0:0.4">
                                                <ColorAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            
                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="BlurRadius" To="5" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="ShadowDepth" To="2" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardShadow" Storyboard.TargetProperty="Opacity" To="0.2" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            
                                            <DoubleAnimation Storyboard.TargetName="NameText" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="NameTextTranslate" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Border Background="#F2121212" 
            CornerRadius="12" Padding="15">
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标签页 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Config.IsLauncherSinglePageDisplayEnabled}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <RadioButton x:Name="TabBookmark" Content="书签" GroupName="Tabs" 
                             Style="{StaticResource TabRadioButtonStyle}" 
                             IsChecked="True" Checked="Tab_Checked" Tag="Bookmark"
                             MouseEnter="Tab_MouseEnter" MouseLeave="Tab_MouseLeave"/>
                <RadioButton x:Name="TabApplication" Content="应用" GroupName="Tabs" 
                             Style="{StaticResource TabRadioButtonStyle}" 
                             Checked="Tab_Checked" Tag="Application"
                             MouseEnter="Tab_MouseEnter" MouseLeave="Tab_MouseLeave"/>
                <RadioButton x:Name="TabTool" Content="工具" GroupName="Tabs" 
                             Style="{StaticResource TabRadioButtonStyle}" 
                             Checked="Tab_Checked" Tag="Tool"
                             MouseEnter="Tab_MouseEnter" MouseLeave="Tab_MouseLeave"/>
            </StackPanel>

            <!-- 内容区域 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <!-- 分页显示 (Tabbed Display) -->
                    <ItemsControl ItemsSource="{Binding FilteredItems}" ItemTemplate="{StaticResource LauncherItemTemplate}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Config.IsLauncherSinglePageDisplayEnabled}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel x:Name="IconPanel" Orientation="Horizontal" HorizontalAlignment="Center" MaxWidth="696"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Panel.ZIndex" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Panel.ZIndex" Value="100"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                    </ItemsControl>

                    <!-- 同一页显示 (Single Page Display) -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Config.IsLauncherSinglePageDisplayEnabled}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- 书签区 -->
                        <StackPanel Margin="0,0,0,20" Visibility="{Binding Bookmarks.Count, Converter={StaticResource CountToVis}}">
                            <StackPanel Orientation="Vertical" Margin="16,0,16,10">
                                <TextBlock Text="书签" Foreground="#AAAAAA" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                                <Border Height="0.5" Background="#444444" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Bookmarks}" ItemTemplate="{StaticResource LauncherItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" MaxWidth="696"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Panel.ZIndex" Value="0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Panel.ZIndex" Value="100"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 应用区 -->
                        <StackPanel Margin="0,0,0,20" Visibility="{Binding Applications.Count, Converter={StaticResource CountToVis}}">
                            <StackPanel Orientation="Vertical" Margin="16,0,16,10">
                                <TextBlock Text="应用" Foreground="#AAAAAA" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                                <Border Height="0.5" Background="#444444" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Applications}" ItemTemplate="{StaticResource LauncherItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" MaxWidth="696"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Panel.ZIndex" Value="0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Panel.ZIndex" Value="100"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                            </ItemsControl>
                        </StackPanel>

                        <!-- 工具区 -->
                        <StackPanel Margin="0,0,0,20" Visibility="{Binding Tools.Count, Converter={StaticResource CountToVis}}">
                            <StackPanel Orientation="Vertical" Margin="16,0,16,10">
                                <TextBlock Text="工具" Foreground="#AAAAAA" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="0,0,0,6"/>
                                <Border Height="0.5" Background="#444444" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Tools}" ItemTemplate="{StaticResource LauncherItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" MaxWidth="696"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Panel.ZIndex" Value="0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Panel.ZIndex" Value="100"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
