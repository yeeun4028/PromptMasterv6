<Window x:Class="PromptMasterv5.Views.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PromptMasterv5.ViewModels"
        mc:Ignorable="d"
        Title="Launcher" Height="300" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False" Topmost="True"
        Deactivated="Window_Deactivated" KeyDown="Window_KeyDown">

    <Border Background="{DynamicResource CardBackground}" 
            BorderBrush="{DynamicResource DividerBrush}" 
            BorderThickness="1" CornerRadius="12" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.ExecuteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                    CommandParameter="{Binding}"
                                    Margin="5" Width="70" Height="70"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="Transparent" CornerRadius="12" Padding="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsFocused, RelativeSource={RelativeSource Self}}" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ActionIconBrush}"/>
                                                <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Icon based on type -->
                                    <Grid Width="28" Height="28" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Path Data="{Binding IconGeometry}" 
                                              Visibility="{Binding IconGeometry, Converter={StaticResource StringToVis}}"
                                              Fill="{DynamicResource ActionIconBrush}" 
                                              Stretch="Uniform" />
                                        
                                        <!-- Fallback or File Icon placeholder (we could use Image Source="{Binding IconPath}" here if we have a converter) -->
                                        <Path Data="M13,9V3.5L18.5,9M6,2C4.89,2 4,2.89 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2H6Z"
                                              Visibility="{Binding IconGeometry, Converter={StaticResource StringToVisInverted}}"
                                              Fill="{DynamicResource TextSecondary}" 
                                              Stretch="Uniform" Opacity="0.5"/>
                                    </Grid>

                                    <TextBlock Grid.Row="1" Text="{Binding Title}" Margin="2,5,2,2" 
                                               TextAlignment="Center" TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextPrimary}" FontSize="10"
                                               MaxHeight="28" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <TextBlock Text="Tab 切换 • Enter 启动 • Esc 关闭" Grid.Row="3" VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                       Foreground="{DynamicResource TextSecondary}" FontSize="12" Opacity="0.5" Margin="0,15,0,0"/>
        </Grid>
    </Border>
</Window>
