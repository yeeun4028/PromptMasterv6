<Window x:Class="PromptMasterv5.Views.BackupSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="选择备份文件" Height="400" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F1F1EF">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="请选择要恢复的本地备份文件：" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

        <DataGrid Grid.Row="1" x:Name="BackupList" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  SelectionMode="Single"
                  Background="White"
                  BorderThickness="1"
                  BorderBrush="#E5E5E5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="200"/>
                <DataGridTextColumn Header="修改时间" Binding="{Binding LastModified, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="150"/>
                <DataGridTextColumn Header="大小 (字节)" Binding="{Binding Size}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="取消" Width="80" Height="30" Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="恢复" Width="80" Height="30" Click="Restore_Click" Background="#4A89DC" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
