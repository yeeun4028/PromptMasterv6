<Window x:Class="PromptMasterv5.Views.QuickActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:converters="clr-namespace:PromptMasterv5.Converters"
        Title="快速操作" 
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#363B40"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        AllowsTransparency="False"
        Topmost="True"
        ShowInTaskbar="False"
        Width="600"
        Height="60"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="1" CornerRadius="0" />
    </WindowChrome.WindowChrome>
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:IsStringEmptyGuidConverter x:Key="IsStringEmptyGuidConverter"/>
        
        <!-- Colors -->
        <SolidColorBrush x:Key="WindowBackBrush" Color="#363B40"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#b8bfc6"/>
        <SolidColorBrush x:Key="TextSubBrush" Color="#A0A6AC"/>
        <SolidColorBrush x:Key="HighlightBrush" Color="#5A99EC"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#50555A"/>
        <SolidColorBrush x:Key="CodeBlockBackBrush" Color="#2B2F33"/>
        <SolidColorBrush x:Key="MenuBackBrush" Color="#40464C"/>

        <!-- Button Style with rounded corners -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#4A4F55"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5A99EC"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Wireframe Icon Button (Right Toolbar) -->
        <Style x:Key="WireframeIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource HighlightBrush}"/>
                    <Setter Property="Background" Value="#1FFFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Border x:Name="MainBorder"
            Background="#E6363B40" 
            CornerRadius="4"
            Padding="15">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>        <!-- Message Area (initially collapsed) -->
                <RowDefinition Height="Auto"/>     <!-- Toolbar (always visible) -->
                <RowDefinition Height="Auto"/>     <!-- Input Area (initially collapsed) -->
            </Grid.RowDefinitions>
            
            <!-- Row 0: Message Display Area (Document Stream Style) -->
            <ScrollViewer Grid.Row="0" 
                         x:Name="MessageArea"
                         Visibility="Collapsed"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,10">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="1"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="Transparent">
                                        <Track x:Name="PART_Track" IsDirectionReversed="true">
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate>
                                                            <Border Background="Transparent"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,12">
                                <!-- User/Assistant Label -->
                                <TextBlock Text="{Binding Role}" 
                                          FontWeight="Bold"
                                          Foreground="#8AB4F8"
                                          FontSize="12"
                                          Margin="0,0,0,4"/>
                                
                                <!-- Message Content (Full Width) -->
                                <TextBlock Text="{Binding Content}"
                                          TextWrapping="Wrap"
                                          Foreground="#E0E0E0"
                                          FontSize="14"
                                          LineHeight="22"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Row 1: Toolbar (Central Anchor, Always Visible) -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>    <!-- Left: Preset Actions -->
                    <ColumnDefinition Width="Auto"/> <!-- Right: Operation Buttons -->
                </Grid.ColumnDefinitions>

                <!-- Left Side: Quick Action Buttons -->
                <ItemsControl Grid.Column="0" 
                             ItemsSource="{Binding QuickActions}"
                             x:Name="ActionList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Title}"
                                   Command="{Binding DataContext.ExecuteActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                   CommandParameter="{Binding}"
                                   Style="{StaticResource ModernButton}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Right Side: Operation Buttons (Copy/Replace/Zoom/Close) -->
                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal"
                           Visibility="{Binding IsRightToolbarVisible, Converter={StaticResource BoolToVisibility}}">
                    
                    <!-- Model Selector -->
                    <Button x:Name="ModelSelectorBtn" ToolTip="选择模型" Click="ModelSelectorBtn_Click" Style="{StaticResource WireframeIconButton}">
                        <Button.ContextMenu>
                            <ContextMenu ItemsSource="{Binding AvailableModels}" Background="{StaticResource MenuBackBrush}" BorderBrush="{StaticResource BorderBrush}">
                                <ContextMenu.ItemContainerStyle>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Header" Value="{Binding ModelName}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
                                        <Setter Property="Command" Value="{Binding DataContext.SelectModelCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Setter Property="CommandParameter" Value="{Binding}"/>
                                    </Style>
                                </ContextMenu.ItemContainerStyle>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Path Data="M4,6 H20 V18 H4 Z M6,8 V16 M10,8 V16 M14,8 V16 M18,8 V16 M2,9 V15 M22,9 V15 M9,2 V4 M15,2 V4 M9,20 V22 M15,20 V22" 
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" Fill="Transparent"
                              Stretch="Uniform" Width="18" Height="18"/>
                    </Button>
                    
                    <!-- Retry -->
                    <Button Command="{Binding RetryCommand}" Style="{StaticResource WireframeIconButton}" ToolTip="重试">
                        <Path Data="M12,4 V1 L8,5 L12,9 V6 C15.3,6 18,8.7 18,12 C18,15.3 15.3,18 12,18 C8.7,18 6,15.3 6,12" 
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" Fill="Transparent"
                              Stretch="Uniform" Width="16" Height="16"/>
                    </Button>
                    
                    <!-- Copy -->
                    <Button Command="{Binding CopyResultCommand}" Style="{StaticResource WireframeIconButton}" ToolTip="复制">
                        <Path Data="M8,8 H18 V20 H8 Z M6,5 H16 V6 H6 V18 H5 V5 Z" 
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" Fill="Transparent"
                              Stretch="Uniform" Width="16" Height="16"/>
                    </Button>
                    
                    <!-- Replace -->
                    <Button Command="{Binding ReplaceCommand}" Style="{StaticResource WireframeIconButton}" ToolTip="替换并粘贴">
                        <Path Data="M4,12 H16 M14,10 L16,12 L14,14 M12,4 L12,20" 
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" Fill="Transparent"
                              Stretch="Uniform" Width="16" Height="16"/>
                    </Button>
                    
                    <!-- Zoom -->
                    <Button Command="{Binding ToggleWindowSizeCommand}" Style="{StaticResource WireframeIconButton}" ToolTip="切换窗口大小">
                        <Path Data="M6,12 L2,12 M22,12 L18,12 M12,6 L12,2 M12,22 L12,18 M4,4 L7,7 M20,20 L17,17 M20,4 L17,7 M4,20 L7,17" 
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" Fill="Transparent"
                              Stretch="Uniform" Width="16" Height="16"/>
                    </Button>
                    
                    <!-- Open External -->
                    <Button Command="{Binding OpenInExternalEditorCommand}" Style="{StaticResource WireframeIconButton}" ToolTip="在外部编辑器中打开">
                        <Path Data="M6,6 H18 V18 H6 Z M18,6 L22,2 M22,2 H16 M22,2 V8" 
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" Fill="Transparent"
                              Stretch="Uniform" Width="16" Height="16"/>
                    </Button>
                    
                    <!-- Close -->
                    <Button Command="{Binding CloseWindowCommand}" Style="{StaticResource WireframeIconButton}" ToolTip="关闭">
                        <Path Data="M6,6 L18,18 M18,6 L6,18" 
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.5" Fill="Transparent"
                              Stretch="Uniform" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
            </Grid>
            
            <!-- Row 2: Input Area -->
            <Grid Grid.Row="2" 
                  x:Name="InputArea"
                  Visibility="Collapsed">
                <TextBox x:Name="InputTextBox"
                        Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        Background="{StaticResource WindowBackBrush}"
                        Foreground="{StaticResource TextMainBrush}"
                        BorderThickness="0"
                        Padding="10"
                        FontSize="14"
                        MinHeight="60"
                        MaxHeight="120"
                        VerticalScrollBarVisibility="Auto"
                        PreviewKeyDown="InputTextBox_PreviewKeyDown"
                        CaretBrush="{StaticResource HighlightBrush}">
                </TextBox>
            </Grid>
        </Grid>
    </Border>
</Window>
