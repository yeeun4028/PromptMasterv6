<Window x:Class="PromptMasterv5.Views.QuickActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:converters="clr-namespace:PromptMasterv5.Converters"
        Title="快速操作" 
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#363B40"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        AllowsTransparency="False"
        Topmost="True"
        ShowInTaskbar="False"
        Width="600"
        Height="60"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated">
    
    <Window.Resources>
        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:IsStringEmptyGuidConverter x:Key="IsStringEmptyGuidConverter"/>
        
        <!-- Button Style with rounded corners -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#4A4F55"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#5A99EC"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Icon Button Style (smaller, for toolbar right side) -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4F55"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Border x:Name="MainBorder"
            Background="#E6363B40" 
            CornerRadius="12"
            Padding="15">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>        <!-- Message Area (initially collapsed) -->
                <RowDefinition Height="Auto"/>     <!-- Toolbar (always visible) -->
                <RowDefinition Height="Auto"/>     <!-- Input Area (initially collapsed) -->
            </Grid.RowDefinitions>
            
            <!-- Row 0: Message Display Area (Document Stream Style) -->
            <ScrollViewer Grid.Row="0" 
                         x:Name="MessageArea"
                         Visibility="Collapsed"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,10">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Width" Value="1"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="Transparent">
                                        <Track x:Name="PART_Track" IsDirectionReversed="true">
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate>
                                                            <Border Background="Transparent"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,12">
                                <!-- User/Assistant Label -->
                                <TextBlock Text="{Binding Role}" 
                                          FontWeight="Bold"
                                          Foreground="#8AB4F8"
                                          FontSize="12"
                                          Margin="0,0,0,4"/>
                                
                                <!-- Message Content (Full Width) -->
                                <TextBlock Text="{Binding Content}"
                                          TextWrapping="Wrap"
                                          Foreground="#E0E0E0"
                                          FontSize="14"
                                          LineHeight="22"
                                          FontFamily="Consolas, Segoe UI, Microsoft YaHei UI, Sans-Serif"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Row 1: Toolbar (Central Anchor, Always Visible) -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>    <!-- Left: Preset Actions -->
                    <ColumnDefinition Width="Auto"/> <!-- Right: Operation Buttons -->
                </Grid.ColumnDefinitions>

                <!-- Left Side: Quick Action Buttons -->
                <ItemsControl Grid.Column="0" 
                             ItemsSource="{Binding QuickActions}"
                             x:Name="ActionList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Title}"
                                   Command="{Binding DataContext.ExecuteActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                   CommandParameter="{Binding}"
                                   Style="{StaticResource ModernButton}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Right Side: Operation Buttons (Copy/Replace/Zoom/Close) -->
                <StackPanel Grid.Column="1" 
                           Orientation="Horizontal"
                           Visibility="{Binding IsRightToolbarVisible, Converter={StaticResource BoolToVisibility}}">
                    
                    <!-- Model Selector Button -->
                    <Button x:Name="ModelSelectorBtn" ToolTip="选择模型" Click="ModelSelectorBtn_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                <Style.Triggers>
                                    <!-- Highlight when override model is selected -->
                                    <DataTrigger Binding="{Binding SelectedOverrideModel.Id, Converter={StaticResource IsStringEmptyGuidConverter}}" Value="False">
                                        <Setter Property="Background" Value="#4A90E2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.ContextMenu>
                            <ContextMenu ItemsSource="{Binding AvailableModels}">
                                <ContextMenu.ItemContainerStyle>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Header" Value="{Binding ModelName}"/>
                                        <Setter Property="Command" Value="{Binding DataContext.SelectModelCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Setter Property="CommandParameter" Value="{Binding}"/>
                                    </Style>
                                </ContextMenu.ItemContainerStyle>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <Path Data="M12,2A10,10,0,0,0,2,12,10,10,0,0,0,12,22,10,10,0,0,0,22,12,10,10,0,0,0,12,2M12,4A8,8,0,0,1,20,12,8,8,0,0,1,12,20,8,8,0,0,1,4,12,8,8,0,0,1,12,4M12,6A6,6,0,0,0,6,12A6,6,0,0,0,12,18A6,6,0,0,0,18,12A6,6,0,0,0,12,6M12,8A4,4,0,0,1,16,12A4,4,0,0,1,12,16A4,4,0,0,1,8,12A4,4,0,0,1,12,8Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Stretch="Uniform"
                              Width="16" Height="16"/>
                    </Button>
                    
                    <Button Command="{Binding RetryCommand}"
                           Style="{StaticResource IconButton}"
                           ToolTip="重试 (Retry)">
                        <Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4C7.58 4 4.01 7.58 4.01 12C4.01 16.42 7.58 20 12 20C15.73 20 18.84 17.45 19.73 14H17.65C16.83 16.33 14.61 18 12 18C8.69 18 6 15.31 6 12C6 8.69 8.69 6 12 6C13.66 6 15.14 6.69 16.22 7.78L13 11H20V4L17.65 6.35Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Stretch="Uniform"
                              Width="16" Height="16"/>
                    </Button>
                    
                    <Button Command="{Binding CopyResultCommand}"
                           Style="{StaticResource IconButton}"
                           ToolTip="复制">
                        <Path Data="M19 21H8V7H19M19 5H8C6.9 5 6 5.9 6 7V21C6 22.1 6.9 23 8 23H19C20.1 23 21 22.1 21 21V7C21 5.9 20.1 5 19 5M16 1H4C2.9 1 2 1.9 2 3V17H4V3H16V1Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Stretch="Uniform"
                              Width="16" Height="16"/>
                    </Button>
                    
                    <Button Command="{Binding ReplaceCommand}"
                           Style="{StaticResource IconButton}"
                           ToolTip="替换并粘贴">
                        <Path Data="M21 11V9L18 12L21 15V13H23V11M5 3H19C20.1 3 21 3.9 21 5V7H19V5H5V19H19V17H21V19C21 20.1 20.1 21 19 21H5C3.9 21 3 20.1 3 19V5C3 3.9 3.9 3 5 3M17 10V7L24 11.5L17 16V13H11V10H17Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Stretch="Uniform"
                              Width="16" Height="16"/>
                    </Button>
                    
                    <Button Command="{Binding ToggleWindowSizeCommand}"
                           Style="{StaticResource IconButton}"
                           ToolTip="切换窗口大小">
                        <Path x:Name="ZoomIcon"
                              Data="M10 21V19H6.41L10.91 14.5L9.5 13.09L5 17.59V14H3V21H10M14.5 10.91L19 6.41V10H21V3H14V5H17.59L13.09 9.5L14.5 10.91Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Stretch="Uniform"
                              Width="16" Height="16"/>
                    </Button>
                    
                    <Button Command="{Binding OpenInExternalEditorCommand}"
                           Style="{StaticResource IconButton}"
                           ToolTip="在外部编辑器中打开">
                        <Path Data="M14 2H6C4.9 2 4 2.9 4 4V20C4 21.1 4.9 22 6 22H18C19.1 22 20 21.1 20 20V8L14 2M18 20H6V4H13V9H18V20M8 15.2L9.4 13.8L12 16.4L18.6 9.8L20 11.2L12 19.2L8 15.2Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Stretch="Uniform"
                              Width="16" Height="16"/>
                    </Button>
                    
                    <Button Command="{Binding CloseWindowCommand}"
                           Style="{StaticResource IconButton}"
                           ToolTip="关闭">
                        <Path Data="M19 6.41L17.59 5L12 10.59L6.41 5L5 6.41L10.59 12L5 17.59L6.41 19L12 13.41L17.59 19L19 17.59L13.41 12L19 6.41Z" 
                              Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Stretch="Uniform"
                              Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>
            
            <!-- Row 2: Input Area (Appears after first response) -->
            <Grid Grid.Row="2" 
                  x:Name="InputArea"
                  Visibility="Collapsed">
                <TextBox x:Name="InputTextBox"
                        Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        Background="#2E3033"
                        Foreground="#E0E0E0"
                        BorderBrush="#4A4F55"
                        BorderThickness="1"
                        Padding="10"
                        FontSize="14"
                        MinHeight="60"
                        MaxHeight="120"
                        VerticalScrollBarVisibility="Auto"
                        PreviewKeyDown="InputTextBox_PreviewKeyDown">
                </TextBox>
            </Grid>
        </Grid>
    </Border>
</Window>
