<Window x:Class="PromptMasterv5.Views.QuickActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="快速操作" 
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        Width="600"
        Height="60"
        Deactivated="Window_Deactivated">
    
    <Border x:Name="MainBorder"
            Background="#E6363B40" 
            CornerRadius="12"
            Padding="15">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="3" Opacity="0.3"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                <RowDefinition Height="*"/> <!-- Result Area (initially collapsed) -->
                <RowDefinition Height="Auto"/> <!-- Input Area (initially collapsed) -->
            </Grid.RowDefinitions>
            
            <!-- Row 0: Quick Action Buttons -->
            <ItemsControl Grid.Row="0" 
                         ItemsSource="{Binding QuickActions}"
                         x:Name="ActionList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Title}"
                                Command="{Binding DataContext.ExecuteActionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"
                                Margin="4"
                                Padding="16,8"
                                Background="#4A4F55"
                                Foreground="#E0E0E0"
                                BorderThickness="0"
                                FontSize="14"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" 
                                                                    VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#5A99EC"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <!-- Row 1: Result Area (Expanded State) -->
            <ScrollViewer Grid.Row="1" 
                         x:Name="ResultArea"
                         Visibility="Collapsed"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,10,0,10">
                <TextBlock Text="{Binding CurrentResult}"
                          TextWrapping="Wrap"
                          Foreground="#E0E0E0"
                          FontSize="14"
                          FontFamily="Segoe UI, Microsoft YaHei UI, Microsoft YaHei, Sans-Serif"/>
            </ScrollViewer>
            
            <!-- Row 2: Input Area (Expanded State) -->
            <Grid Grid.Row="2" 
                  x:Name="InputArea"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Input Box -->
                <TextBox Grid.Row="0"
                        Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                        AcceptsReturn="False"
                        TextWrapping="Wrap"
                        Background="#2E3033"
                        Foreground="#E0E0E0"
                        BorderBrush="#4A4F55"
                        BorderThickness="1"
                        Padding="10"
                        FontSize="14"
                        Margin="0,0,0,8">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SendMessageCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                
                <!-- Action Buttons -->
                <StackPanel Grid.Row="1" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Right">
                    <Button Content="复制"
                           Command="{Binding CopyResultCommand}"
                           Margin="0,0,8,0"
                           Padding="16,6"
                           Background="#4A89DC"
                           Foreground="White"
                           BorderThickness="0"
                           Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#5A99EC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <Button Content="替换"
                           Command="{Binding ReplaceCommand}"
                           Padding="16,6"
                           Background="#4CAF50"
                           Foreground="White"
                           BorderThickness="0"
                           Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#5CBF60"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
