<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:md="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf">

    <!-- ==========================================
         1. 颜色与画笔系统 (Color System)
         ========================================== -->
    <Color x:Key="GithubTextColor">#333333</Color>
    <Color x:Key="GithubLinkColor">#4183C4</Color>
    <Color x:Key="GithubBorderColor">#E1E4E8</Color>
    <Color x:Key="GithubCodeBgColor">#F6F8FA</Color>
    <Color x:Key="GithubQuoteBorderColor">#DFE2E5</Color>

    <SolidColorBrush x:Key="GithubTextBrush" Color="{StaticResource GithubTextColor}"/>
    <SolidColorBrush x:Key="GithubLinkBrush" Color="{StaticResource GithubLinkColor}"/>
    <SolidColorBrush x:Key="GithubBorderBrush" Color="{StaticResource GithubBorderColor}"/>
    <SolidColorBrush x:Key="GithubCodeBgBrush" Color="{StaticResource GithubCodeBgColor}"/>
    <SolidColorBrush x:Key="GithubQuoteBorderBrush" Color="{StaticResource GithubQuoteBorderColor}"/>

    <!-- 字体回退栈: Open Sans -> Segoe UI -> YaHei -->
    <FontFamily x:Key="GithubFontFamily">Open Sans, Segoe UI, Microsoft YaHei UI, sans-serif</FontFamily>
    <FontFamily x:Key="GithubCodeFontFamily">Consolas, Cascadia Code, Courier New, monospace</FontFamily>

    <!-- ==========================================
         2. 全局文档样式
         注意: 排版属性已移至 MainWindow.xaml 的 MarkdownViewer 控件
         ========================================== -->
    <Style x:Key="{x:Static md:Styles.DocumentStyleKey}" TargetType="{x:Type FlowDocument}">
        <Setter Property="TextAlignment" Value="Left"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <!-- ==========================================
         3. 标题样式 (Headings)
         ========================================== -->
    <!-- H1: 36px, 底部边框 -->
    <Style x:Key="{x:Static md:Styles.Heading1StyleKey}" TargetType="{x:Type Paragraph}">
        <Setter Property="FontSize" Value="36"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,24,0,16"/>
        <Setter Property="BorderBrush" Value="#EEEEEE"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="0,0,0,10"/>
    </Style>

    <!-- H2: 28px, 底部边框 -->
    <Style x:Key="{x:Static md:Styles.Heading2StyleKey}" TargetType="{x:Type Paragraph}">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,24,0,16"/>
        <Setter Property="BorderBrush" Value="#EEEEEE"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="0,0,0,10"/>
    </Style>

    <!-- H3: 24px -->
    <Style x:Key="{x:Static md:Styles.Heading3StyleKey}" TargetType="{x:Type Paragraph}">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,24,0,16"/>
    </Style>

    <!-- H4: 20px -->
    <Style x:Key="{x:Static md:Styles.Heading4StyleKey}" TargetType="{x:Type Paragraph}">
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="0,24,0,16"/>
    </Style>

    <!-- ==========================================
         4. 链接样式 (Links)
         对应: 蓝色 #4183C4, 下划线
         ========================================== -->
    <Style x:Key="{x:Static md:Styles.HyperlinkStyleKey}" TargetType="{x:Type Hyperlink}">
        <Setter Property="Foreground" Value="{StaticResource GithubLinkBrush}"/>
        <Setter Property="TextDecorations" Value="Underline"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="TextDecorations" Value="None"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ==========================================
         5. 代码块样式 (Code Blocks)
         对应: 背景 #f8f8f8, 圆角 3px, 边框 1px
         ========================================== -->
    <Style x:Key="{x:Static md:Styles.CodeBlockStyleKey}" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource GithubCodeBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource GithubBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Margin" Value="0,16,0,16"/>
    </Style>

    <!-- 代码文本: 14.4px (90%) -->
    <Style TargetType="{x:Type Run}" x:Key="GithubCodeRunStyle">
        <Setter Property="FontFamily" Value="{StaticResource GithubCodeFontFamily}"/>
        <Setter Property="FontSize" Value="14.4"/>
    </Style>

    <!-- ==========================================
         6. 引用块样式 (Blockquotes)
         对应: 左边框 4px #dfe2e5, 文本灰色
         ========================================== -->
    <Style x:Key="{x:Static md:Styles.QuoteBlockStyleKey}" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{StaticResource GithubQuoteBorderBrush}"/>
        <Setter Property="BorderThickness" Value="4,0,0,0"/>
        <Setter Property="Padding" Value="16,0,16,0"/>
        <Setter Property="Margin" Value="0,16,0,16"/>
    </Style>

    <!-- ==========================================
         7. 分割线 (Thematic Break)
         ========================================== -->
    <Style x:Key="{x:Static md:Styles.ThematicBreakStyleKey}" TargetType="{x:Type Line}">
        <Setter Property="Stroke" Value="{StaticResource GithubBorderBrush}"/>
        <Setter Property="StrokeThickness" Value="2"/>
        <Setter Property="X2" Value="1"/>
        <Setter Property="Stretch" Value="Fill"/>
        <Setter Property="Margin" Value="0,16,0,16"/>
    </Style>

</ResourceDictionary>