<Window x:Class="PromptMasterv5.IconInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置图标" Height="340" Width="460"
        Style="{DynamicResource ModernDialogWindowStyle}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="设置图标 (SVG Path)" Style="{StaticResource SectionHeaderTextStyle}"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputBox" 
                     AcceptsReturn="True" 
                     TextWrapping="Wrap" 
                     Style="{StaticResource ModernTextBoxStyle}"
                     VerticalContentAlignment="Top"
                     TextChanged="InputBox_TextChanged"
                     ToolTip="例如: M10,10 L50,50..."
                     Margin="0,0,20,0"/>

            <Border Grid.Column="1" Width="100" Height="100" CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource DividerBrush}" Background="{DynamicResource CardBackground}" VerticalAlignment="Top">
                <Grid>
                    <TextBlock Text="预览" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Opacity="0.3" FontSize="14" FontWeight="Bold"/>
                    <Path x:Name="PreviewPath" 
                          Fill="{DynamicResource TextPrimary}" 
                          Stretch="Uniform" 
                          Width="48" 
                          Height="48" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="清除图标" Click="Clear_Click" Style="{StaticResource DangerLinkButtonStyle}" Margin="0,0,16,0"/>
            <Button Content="取消" IsCancel="True" Style="{StaticResource TextLinkButtonStyle}" Margin="0,0,16,0"/>
            <Button Content="确定" IsDefault="True" Click="Ok_Click" Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>