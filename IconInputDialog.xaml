<Window x:Class="PromptMasterv5.IconInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置图标" Height="300" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Background="#FAFAFA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="请输入 SVG Path 代码 (d值):" FontWeight="Bold" Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputBox" 
                     AcceptsReturn="True" 
                     TextWrapping="Wrap" 
                     Padding="5"
                     VerticalContentAlignment="Top"
                     TextChanged="InputBox_TextChanged"
                     ToolTip="例如: M10,10 L50,50..."/>

            <Border Grid.Column="1" Margin="10,0,0,0" BorderBrush="#EEE" BorderThickness="1" Background="White">
                <Grid>
                    <TextBlock Text="预览" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#EEE" FontSize="20" FontWeight="Bold"/>
                    <Path x:Name="PreviewPath" 
                          Fill="#333" 
                          Stretch="Uniform" 
                          Width="40" 
                          Height="40" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="清除图标" Click="Clear_Click" Margin="0,0,10,0" Padding="10,5" Background="Transparent" Foreground="Red" BorderThickness="0"/>
            <Button Content="取消" IsCancel="True" Margin="0,0,10,0" Padding="15,5"/>
            <Button Content="确定" IsDefault="True" Click="Ok_Click" Padding="15,5" Background="#333" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>