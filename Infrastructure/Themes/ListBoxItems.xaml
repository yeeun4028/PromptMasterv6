<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:PromptMasterv6.Infrastructure.Converters">

    <converters:StringToGeometryConverter x:Key="StringToGeometryConverter"/>

    <Style x:Key="FolderListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="0,4"/>
        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border Background="{TemplateBinding Background}" Width="40" Height="40" CornerRadius="4">
                        <Border.ToolTip>
                            <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="{Binding Name}"/>
                        </Border.ToolTip>
                        <Path x:Name="IconPath" 
                              Data="{Binding IconGeometry, Converter={StaticResource StringToGeometryConverter}, FallbackValue={StaticResource IconFolderLinear}}" 
                              Fill="{DynamicResource ActionIconBrush}" 
                              Stretch="Uniform" 
                              Width="14" Height="14" 
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IconGeometry}" Value="{x:Null}">
                            <Setter TargetName="IconPath" Property="Data" Value="{StaticResource IconFolderLinear}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IconGeometry}" Value="">
                            <Setter TargetName="IconPath" Property="Data" Value="{StaticResource IconFolderLinear}"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu Style="{StaticResource ModernContextMenuStyle}"
                             DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="更改图标"
                              Style="{StaticResource ModernMenuItemStyle}"
                              Command="{Binding ChangeFolderIconVM.ExecuteCommand}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="重命名"
                              Style="{StaticResource ModernMenuItemStyle}"
                              Command="{Binding RenameFolderVM.ExecuteCommand}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                    <MenuItem Header="删除"
                              Style="{StaticResource ModernMenuItemStyle}"
                              Command="{Binding DeleteFolderVM.ExecuteCommand}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FileListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path x:Name="FileIcon" 
                                  Data="{Binding IconGeometry, Converter={StaticResource StringToGeometryConverter}, FallbackValue={StaticResource IconFolderLinear}}" 
                                  Visibility="Visible" 
                                  Fill="{DynamicResource PlaceholderTextBrush}" 
                                  Stretch="Uniform" 
                                  Width="14" 
                                  Height="14" 
                                  Margin="0,1,8,0" 
                                  VerticalAlignment="Center"/>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IconGeometry}" Value="{x:Null}">
                            <Setter TargetName="FileIcon" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IconGeometry}" Value="">
                            <Setter TargetName="FileIcon" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                            <Setter TargetName="FileIcon" Property="Fill" Value="{DynamicResource SecondaryTextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource ListItemSelectedBackgroundBrush}"/>
                            <Setter TargetName="FileIcon" Property="Fill" Value="{DynamicResource PrimaryTextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu Style="{StaticResource ModernContextMenuStyle}"
                             DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="重命名"
                              Style="{StaticResource ModernMenuItemStyle}"
                              Command="{Binding RenameFileVM.ExecuteCommand}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <MenuItem Header="更改图标"
                              Style="{StaticResource ModernMenuItemStyle}"
                              Command="{Binding ChangeFileIconVM.ExecuteCommand}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    <Separator Style="{StaticResource ModernSeparatorStyle}"/>
                    <MenuItem Header="删除"
                              Style="{StaticResource ModernMenuItemStyle}"
                              Command="{Binding DeleteFileVM.ExecuteCommand}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                </ContextMenu>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
