                                                <SolidColorBrush Color="Transparent"/>
                                            </Button.Background>
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                            <Setter Property="Background" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                            <Setter Property="Foreground" Value="Black"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="4">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Resources>
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource IconShortcut}" Fill="#666" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
