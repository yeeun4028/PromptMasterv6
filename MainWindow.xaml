                                        <TextBox Text="{Binding Config.AiModel}" Padding="5" Margin="0,0,0,15" Background="#F5F5F5" BorderThickness="0" ToolTip="例如: deepseek-chat, qwen-turbo"/>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                            <TextBlock x:Name="TestStatusText"
                                                       Style="{StaticResource TestStatusTextStyle}"
                                                       Text=""/>

                                            <Button x:Name="TestConnectionBtn"
                                                    Content="测试"
                                                    Click="TestAiConnection_Click"
                                                    Padding="20,8"
                                                    Background="#4183C4"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Cursor="Hand">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <Button x:Name="AddModelBtn"
                                                    Content="保存"
                                                    Command="{Binding AddAiModelCommand}"
                                                    Padding="20,8"
                                                    Background="#4183C4"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Margin="10,0,0,0">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </StackPanel>

                                        <ListBox ItemsSource="{Binding Config.SavedModels}"
