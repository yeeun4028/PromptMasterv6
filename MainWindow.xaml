                                            </StackPanel>
                                        </Button>

                                        <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="1"
                                                Style="{StaticResource SettingsTabBtnStyle}" Margin="0,15,0,0">
                                            <Button.Background>
                                                <SolidColorBrush Color="Transparent"/>
                                            </Button.Background>
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                            <Setter Property="Background" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                            <Setter Property="Foreground" Value="Black"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="4">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Resources>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⚡  自动化" FontSize="14"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="2"
                                                Style="{StaticResource SettingsTabBtnStyle}" Margin="0,15,0,0">
                                            <Button.Background>
                                                <SolidColorBrush Color="Transparent"/>
                                            </Button.Background>
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                            <Setter Property="Background" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                            <Setter Property="Foreground" Value="Black"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="4">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Resources>
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource IconModel}" Fill="#666" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="模型" FontSize="14" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="3"
                                                Style="{StaticResource SettingsTabBtnStyle}" Margin="0,15,0,0">
                                            <Button.Background>
                                                <SolidColorBrush Color="Transparent"/>
                                            </Button.Background>
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                            <Setter Property="Background" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                            <Setter Property="Foreground" Value="Black"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="4">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Resources>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="☁️  同步" FontSize="14"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="4"
                                                Style="{StaticResource SettingsTabBtnStyle}" Margin="0,15,0,0">
                                            <Button.Background>
                                                <SolidColorBrush Color="Transparent"/>
                                            </Button.Background>
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="4">
                                                            <Setter Property="Background" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="4">
                                                            <Setter Property="Foreground" Value="Black"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="3">
                                                            <Setter Property="Foreground" Value="#666"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Resources>
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="{StaticResource IconMiniWindow}" Fill="#666" Stretch="Uniform" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="极简窗口" FontSize="14" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Column="1" Margin="30">
                                    <Button Command="{Binding SaveSettingsCommand}" 
                                            Content="✕" FontSize="16" Foreground="#999"
                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-15,-15,0"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent">
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Tab 0: 快捷键 -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>


                                        <Border Background="#F9F9F9" CornerRadius="4" Padding="10" Margin="0,0,0,20">
                                            <CheckBox IsChecked="{Binding Config.EnableDoubleCtrl}" Cursor="Hand">
                                                <CheckBox.Content>
                                                    <StackPanel>
                                                        <TextBlock Text="双击 Ctrl 键唤醒/隐藏窗口" FontSize="14" Foreground="#333"/>
                
                                                    </StackPanel>
                                                </CheckBox.Content>
                                            </CheckBox>
                                        </Border>

                                        
                                        <TextBlock Text="即使窗口最小化，按下此快捷键也能立即唤醒/隐藏程序。" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,20"/>

                                        <TextBlock Text="当前热键" Foreground="#666" Margin="0,0,0,5"/>

                                        <TextBox Text="{Binding Config.GlobalHotkey}"
                                                 Padding="10"
                                                 FontSize="14"
                                                 FontWeight="Bold"
                                                 Background="#F5F5F5"
                                                 BorderThickness="1"
                                                 BorderBrush="#DDD"
                                                 IsReadOnly="True"
                                                 Cursor="IBeam"
                                                 PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                                 ToolTip="点击此处并按下键盘组合键来修改"/>

                                        
                                    </StackPanel>

                                    <!-- Tab 1: 自动化 -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>

                                        <TextBlock Text="输入发送模式" Foreground="#333" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                                        <Border Background="#F9F9F9" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                                            <RadioButton GroupName="InputMode"
                                                         IsChecked="{Binding LocalConfig.Mode, Converter={models:EnumToBoolConverter}, ConverterParameter=SmartFocus}"
                                                         Content="智能回退模式 (推荐)"
                                                         FontSize="14" FontWeight="Bold" Cursor="Hand"/>
                                        </Border>
                                        <TextBlock Text="软件隐藏后，自动将焦点还给上一个活动的窗口 (如浏览器输入框)，然后发送内容。"
                                                   Foreground="#888" FontSize="12" Margin="5,0,0,20" TextWrapping="Wrap"/>

                                        <Border Background="#F9F9F9" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                                            <RadioButton GroupName="InputMode"
                                                         IsChecked="{Binding LocalConfig.Mode, Converter={models:EnumToBoolConverter}, ConverterParameter=CoordinateClick}"
                                                         Content="坐标点击模式"
                                                         FontSize="14" FontWeight="Bold" Cursor="Hand"/>
                                        </Border>
                                        <TextBlock Text="软件隐藏后，强制点击屏幕上的指定位置来激活输入框。"
                                                   Foreground="#888" FontSize="12" Margin="5,0,0,10" TextWrapping="Wrap"/>

                                        <StackPanel Margin="20,0,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LocalConfig.Mode}" Value="CoordinateClick">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <Grid Margin="0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="X 坐标" Foreground="#666" FontSize="12"/>
                                                    <TextBox Text="{Binding LocalConfig.ClickX}" Width="60" Padding="5" Margin="0,5,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Y 坐标" Foreground="#666" FontSize="12"/>
                                                    <TextBox Text="{Binding LocalConfig.ClickY}" Width="60" Padding="5" Margin="0,5,0,0"/>
                                                </StackPanel>

                                                <Button Grid.Column="4" Content="⏱️ 3秒后拾取" Click="PickCoordinate_Click"
                                                        VerticalAlignment="Bottom" Height="30" Padding="10,0"
                                                        Background="#4183C4" Foreground="White" BorderThickness="0">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="4"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </Grid>
                                            <TextBlock Text="* 点击按钮后请迅速移动鼠标到目标位置，等待3秒自动记录。" Foreground="#999" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Tab 2: 模型配置 -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
