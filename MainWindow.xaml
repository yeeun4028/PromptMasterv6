<Window x:Class="PromptMasterv5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
        xmlns:dd="urn:gong-wpf-dragdrop"
        xmlns:models="clr-namespace:PromptMasterv5.Models"
        mc:Ignorable="d"
        Title="PromptMaster v5 (新版已生效)" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="8" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="TextBrush" Color="#333333"/>
        <SolidColorBrush x:Key="GitHubBlue" Color="#4183C4"/>
        <SolidColorBrush x:Key="Block1Background" Color="#F1F1EF"/>

        <Geometry x:Key="IconChevronRight">M 9,6 L 15,12 L 9,18</Geometry>
        <Geometry x:Key="IconChevronLeft">M 15,6 L 9,12 L 15,18</Geometry>
        <Geometry x:Key="IconFolderLinear">M20,18H4V8H20M20,6H12L10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6Z</Geometry>
        <Geometry x:Key="IconFileLinear">M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z</Geometry>
        <Geometry x:Key="IconNewFolder">M20 6h-8l-2-2H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.9-2-2-2zm-1 8h-3v3h-2v-3h-3v-2h3V9h2v3h3v2z</Geometry>
        <Geometry x:Key="IconNewDoc">M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z</Geometry>
        <Geometry x:Key="IconSettings">M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.488.488 0 0 0-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84a.484.484 0 0 0-.48.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0 .59-.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.27.41.48.41h3.84c.24 0 .44-.17.48-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z</Geometry>
        <Geometry x:Key="IconCopyThin">M20 2H10c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H10V4h10v12zM4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6z</Geometry>
        <Geometry x:Key="IconLockClosedThin">M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z</Geometry>
        <Geometry x:Key="IconLockOpenThin">M12 17a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm6-9h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6h2c0-1.66 1.34-3 3-3s3 1.34 3 3v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm0 12H6V10h12v10z</Geometry>
        <Geometry x:Key="IconDelete">M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z</Geometry>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="Block1ToolTipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="{StaticResource Block1Background}"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Grid Margin="0,0,5,5">
                            <Border Background="{TemplateBinding Background}" CornerRadius="2" Padding="8,4">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.2" ShadowDepth="2" Direction="315" BlurRadius="4"/>
                                </Border.Effect>
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FolderListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Header="设置图标..." 
                                  Command="{Binding PlacementTarget.Tag.ChangeFolderIconCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="重命名..." 
                                  Command="{Binding PlacementTarget.Tag.RenameFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" Width="40" Height="40" CornerRadius="4">
                            <Border.ToolTip>
                                <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="{Binding Name}"/>
                            </Border.ToolTip>
                            <Path x:Name="IconPath" 
                                  Data="{Binding IconGeometry}" 
                                  Fill="#898888" 
                                  Stretch="Uniform" 
                                  Width="20" Height="20" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IconGeometry}" Value="{x:Null}">
                                <Setter TargetName="IconPath" Property="Data" Value="{StaticResource IconFolderLinear}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IconGeometry}" Value="">
                                <Setter TargetName="IconPath" Property="Data" Value="{StaticResource IconFolderLinear}"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconPath" Property="Fill" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="IconPath" Property="Fill" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FileListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>

            <EventSetter Event="MouseDoubleClick" Handler="FileListBoxItem_MouseDoubleClick"/>

            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Header="设置图标..." 
                                  Command="{Binding PlacementTarget.Tag.ChangeFileIconCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                        <Separator/>
                        <MenuItem Header="删除" 
                                  Command="{Binding PlacementTarget.Tag.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}">
                            <MenuItem.Icon>
                                <Path Data="{StaticResource IconDelete}" Fill="#333" Stretch="Uniform" Width="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path x:Name="FileIcon" 
                                      Data="{Binding IconGeometry}" 
                                      Visibility="Visible" 
                                      Fill="#999" 
                                      Stretch="Uniform" 
                                      Width="14" 
                                      Height="14" 
                                      Margin="0,1,8,0" 
                                      VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IconGeometry}" Value="{x:Null}">
                                <Setter TargetName="FileIcon" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IconGeometry}" Value="">
                                <Setter TargetName="FileIcon" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EAEAEA"/>
                                <Setter TargetName="FileIcon" Property="Fill" Value="#666"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter TargetName="FileIcon" Property="Fill" Value="#333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Width="40" Height="40" CornerRadius="4" ToolTip="{TemplateBinding Content}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionIconPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="#898888"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Fill" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmallHeaderIconStyle" TargetType="Path" BasedOn="{StaticResource ActionIconPathStyle}">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Fill" Value="#666666"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Fill" Value="#333333"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsTabBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FAFAFA" CornerRadius="5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Height="40" VerticalAlignment="Top" Background="Transparent" MouseLeftButtonDown="TopBar_MouseLeftButtonDown" />

            <Border Grid.Column="0" 
                    Width="60"
                    Visibility="{Binding IsNavigationVisible, Converter={StaticResource BoolToVis}}"
                    Background="{StaticResource Block1Background}" 
                    CornerRadius="5,0,0,5">
                <Grid>
                    <ListBox ItemsSource="{Binding Folders}" 
                             SelectedItem="{Binding SelectedFolder}"
                             ItemContainerStyle="{StaticResource FolderListBoxItemStyle}" 
                             Background="Transparent" 
                             BorderThickness="0" 
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                             VerticalAlignment="Top" 
                             Margin="0,15,0,0"
                             dd:DragDrop.IsDragSource="True" 
                             dd:DragDrop.IsDropTarget="True"
                             dd:DragDrop.DropHandler="{Binding FolderDropHandler}"/>

                    <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,20">
                        <Button Style="{StaticResource ActionBtnStyle}" Content="新建文档" Command="{Binding CreateFileCommand}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <Path Data="{StaticResource IconNewDoc}" Style="{StaticResource ActionIconPathStyle}"/>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                        <Button Style="{StaticResource ActionBtnStyle}" Content="新建文件夹" Command="{Binding CreateFolderCommand}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <Path Data="{StaticResource IconNewFolder}" Style="{StaticResource ActionIconPathStyle}"/>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                        <Button Style="{StaticResource ActionBtnStyle}" Content="设置" Command="{Binding OpenSettingsCommand}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <Path Data="{StaticResource IconSettings}" Style="{StaticResource ActionIconPathStyle}"/>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>

                        <TextBlock Text="{Binding SyncTimeDisplay}" 
                                   HorizontalAlignment="Center" 
                                   FontSize="10" 
                                   Foreground="#999999"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="0" 
                          Visibility="{Binding IsNavigationVisible, Converter={StaticResource BoolToVis}}"
                          Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True"/>

            <Border Grid.Column="1" Background="#F1F1EF">
                <Grid>
                    <Grid Height="40" VerticalAlignment="Top" Background="Transparent" MouseLeftButtonDown="TopBar_MouseLeftButtonDown"/>

                    <ListBox ItemsSource="{Binding FilesView}"
                             SelectedItem="{Binding SelectedFile}"
                             ItemContainerStyle="{StaticResource FileListBoxItemStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="10,15,5,10"
                             dd:DragDrop.IsDragSource="True"
                             dd:DragDrop.IsDropTarget="True">

                        <ListBox.InputBindings>
                            <KeyBinding Key="Delete" Command="{Binding DeleteFileCommand}"/>
                        </ListBox.InputBindings>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}" Foreground="#333333" FontSize="13" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True"/>
            <Border Grid.Column="1" Width="1" HorizontalAlignment="Right" Background="#E0E0E0" IsHitTestVisible="False"/>

            <Border Grid.Column="2" Background="#FAFAFA" CornerRadius="0,5,5,0">
                <Grid>
                    <Grid.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="0"/>
                            <Setter Property="MinWidth" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid Background="Transparent"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
                        </Style>
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="7*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="3*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="20,10,20,0">
                        <TextElement.FontFamily>Segoe UI, Microsoft YaHei UI</TextElement.FontFamily>
                        <TextElement.Foreground>#333333</TextElement.Foreground>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFile}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Hidden"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,10" Background="Transparent" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding SelectedFile.Title, UpdateSourceTrigger=PropertyChanged}" FontSize="18" FontWeight="Bold" BorderThickness="0" Background="Transparent" Foreground="#333333" FontFamily="Segoe UI, Microsoft YaHei UI">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <TextBlock Grid.Column="0" Text="{Binding SelectedFile.Title}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" IsHitTestVisible="False" Foreground="#333333" FontFamily="Segoe UI, Microsoft YaHei UI">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Command="{Binding ToggleNavigationCommand}" Style="{StaticResource ActionBtnStyle}" ToolTip="切换侧边栏">
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Path x:Name="ChevronPath" Stroke="#666666" StrokeThickness="1.5" Stretch="None" Data="{StaticResource IconChevronLeft}"/>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsNavigationVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                    <Setter TargetName="ChevronPath" Property="Data" Value="{StaticResource IconChevronLeft}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DataContext.IsNavigationVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                    <Setter TargetName="ChevronPath" Property="Data" Value="{StaticResource IconChevronRight}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                    <Setter TargetName="ChevronPath" Property="Stroke" Value="#333333"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button Command="{Binding CopyCompiledTextCommand}" Style="{StaticResource ActionBtnStyle}" ToolTip="复制最终结果 (Ctrl+C)">
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Path Data="{StaticResource IconCopyThin}">
                                                <Path.Style>
                                                    <Style TargetType="Path" BasedOn="{StaticResource SmallHeaderIconStyle}"/>
                                                </Path.Style>
                                            </Path>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button Command="{Binding ToggleEditModeCommand}" Style="{StaticResource ActionBtnStyle}">
                                    <Button.ToolTip>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                            <Setter Property="Text" Value="点击锁定并保存"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                            <Setter Property="Text" Value="点击解锁编辑"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Path Data="{StaticResource IconLockOpenThin}">
                                                    <Path.Style>
                                                        <Style TargetType="Path" BasedOn="{StaticResource SmallHeaderIconStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                                <Path Data="{StaticResource IconLockClosedThin}">
                                                    <Path.Style>
                                                        <Style TargetType="Path" BasedOn="{StaticResource SmallHeaderIconStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                            </Grid>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <TextBox Grid.Row="1" Text="{Binding SelectedFile.Content, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" BorderThickness="0" Background="Transparent" FontSize="14" Padding="5" FontFamily="Segoe UI, Microsoft YaHei UI">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <md:MarkdownViewer Grid.Row="1" Markdown="{Binding SelectedFile.Content}" xml:lang="zh-CN">
                            <md:MarkdownViewer.Style>
                                <Style TargetType="md:MarkdownViewer">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="Margin" Value="5,0,10,0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </md:MarkdownViewer.Style>
                            <md:MarkdownViewer.Resources>
                                <Style x:Key="{x:Static md:Styles.DocumentStyleKey}" TargetType="{x:Type FlowDocument}">
                                    <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, sans-serif"/>
                                    <Setter Property="FontSize" Value="15"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                    <Setter Property="TextAlignment" Value="Left"/>
                                    <Setter Property="LineHeight" Value="24"/>
                                </Style>
                            </md:MarkdownViewer.Resources>
                        </md:MarkdownViewer>
                    </Grid>

                    <Border Grid.Row="1" Height="1" Background="#E0E0E0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                    <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent" ResizeBehavior="PreviousAndNext" ShowsPreview="True"/>

                    <Grid Grid.Row="2" Margin="20,10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" BorderThickness="0">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasVariables}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>
                            <ItemsControl ItemsSource="{Binding Variables}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name, StringFormat='{}{0}:'}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Top" Margin="0,6,10,0" HorizontalAlignment="Right" Foreground="#333333" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                            <Border x:Name="InputBorder" Grid.Column="1" BorderThickness="0" Background="Transparent" CornerRadius="2,2,0,0">
                                                <TextBox x:Name="InputBox" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Padding="5" FontSize="14" VerticalContentAlignment="Top" AcceptsReturn="True" TextWrapping="Wrap" PreviewKeyDown="TextBox_PreviewKeyDown" Foreground="#333333" FontFamily="Segoe UI, Microsoft YaHei UI" Style="{x:Null}"/>
                                            </Border>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <Trigger SourceName="InputBox" Property="IsMouseOver" Value="True">
                                                <Setter TargetName="InputBorder" Property="Background" Value="White"/>
                                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource GitHubBlue}"/>
                                                <Setter TargetName="InputBorder" Property="BorderThickness" Value="0,0,0,1"/>
                                            </Trigger>
                                            <Trigger SourceName="InputBox" Property="IsKeyboardFocused" Value="True">
                                                <Setter TargetName="InputBorder" Property="Background" Value="White"/>
                                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource GitHubBlue}"/>
                                                <Setter TargetName="InputBorder" Property="BorderThickness" Value="0,0,0,1"/>
                                            </Trigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBox Text="{Binding AdditionalInput, UpdateSourceTrigger=PropertyChanged}" 
                                 PreviewKeyDown="AdditionalInputBox_PreviewKeyDown"
                                 AcceptsReturn="True" 
                                 TextWrapping="Wrap" 
                                 Padding="10" 
                                 BorderThickness="0" 
                                 Background="Transparent" 
                                 VerticalContentAlignment="Top" 
                                 FontSize="14" 
                                 Foreground="#333333" 
                                 FontFamily="Segoe UI, Microsoft YaHei UI">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasVariables}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Grid>
            </Border>

            <Grid Background="#7F000000" Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVis}}">
                <Border Background="White" Width="600" Height="400" CornerRadius="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#F7F7F7" CornerRadius="8,0,0,8">
                            <StackPanel Margin="10,20">
                                <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="0"
                                        Style="{StaticResource SettingsTabBtnStyle}">
                                    <Button.Background>
                                        <SolidColorBrush Color="Transparent"/>
                                    </Button.Background>
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                    <Setter Property="Background" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="Black"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                    <Setter Property="Foreground" Value="#666"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                    <Setter Property="Foreground" Value="#666"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Resources>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="☁️  同步" FontSize="14"/>
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="1"
                                        Style="{StaticResource SettingsTabBtnStyle}" Margin="0,5,0,0">
                                    <Button.Background>
                                        <SolidColorBrush Color="Transparent"/>
                                    </Button.Background>
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                    <Setter Property="Background" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="Black"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                    <Setter Property="Foreground" Value="#666"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                    <Setter Property="Foreground" Value="#666"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Resources>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⌨️  快捷键" FontSize="14"/>
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding SelectSettingsTabCommand}" CommandParameter="2"
                                        Style="{StaticResource SettingsTabBtnStyle}" Margin="0,5,0,0">
                                    <Button.Background>
                                        <SolidColorBrush Color="Transparent"/>
                                    </Button.Background>
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                    <Setter Property="Background" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="Foreground" Value="Black"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                    <Setter Property="Foreground" Value="#666"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                    <Setter Property="Foreground" Value="#666"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Resources>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚡  自动化" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Column="1" Margin="30">
                            <Button Command="{Binding SaveSettingsCommand}" 
                                    Content="✕" FontSize="16" Foreground="#999"
                                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-15,-15,0"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="WebDAV 网址" Foreground="#666" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Config.WebDavUrl}" Padding="5" Margin="0,0,0,15" Background="#F5F5F5" BorderThickness="0"/>

                                <TextBlock Text="账号 (邮箱)" Foreground="#666" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Config.UserName}" Padding="5" Margin="0,0,0,15" Background="#F5F5F5" BorderThickness="0"/>

                                <TextBlock Text="应用密码 (非登录密码)" Foreground="#666" Margin="0,0,0,5"/>
                                <PasswordBox x:Name="WebDavPasswordBox" 
                                             PasswordChar="●"
                                             Padding="5" 
                                             Margin="0,0,0,20" 
                                             Background="#F5F5F5" 
                                             BorderThickness="0"
                                             PasswordChanged="WebDavPasswordBox_PasswordChanged"
                                             Loaded="WebDavPasswordBox_Loaded"/>

                                <Border Height="1" Background="#EEE" Margin="0,10"/>

                                <TextBlock Text="手动操作" Foreground="#666" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="☁️ 备份到远程" Command="{Binding ManualBackupCommand}" 
                                            Background="#4183C4" Foreground="White" BorderThickness="0" Padding="15,8" Margin="0,0,10,0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                    <Button Content="⬇️ 从远程恢复" Command="{Binding ManualRestoreCommand}" 
                                            Background="White" Foreground="#4183C4" BorderBrush="#4183C4" BorderThickness="1" Padding="15,8" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="1">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="极速唤醒" Foreground="#333" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                                <Border Background="#F9F9F9" CornerRadius="4" Padding="10" Margin="0,0,0,20">
                                    <CheckBox IsChecked="{Binding Config.EnableDoubleCtrl}" Cursor="Hand">
                                        <CheckBox.Content>
                                            <StackPanel>
                                                <TextBlock Text="双击 Ctrl 键唤醒/隐藏窗口" FontSize="14" Foreground="#333"/>
                                                <TextBlock Text="推荐开启。就像使用 Listary 一样方便。" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </CheckBox.Content>
                                    </CheckBox>
                                </Border>

                                <TextBlock Text="传统组合热键" Foreground="#333" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                                <TextBlock Text="即使窗口最小化，按下此快捷键也能立即唤醒/隐藏程序。" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,20"/>

                                <TextBlock Text="当前热键" Foreground="#666" Margin="0,0,0,5"/>

                                <TextBox Text="{Binding Config.GlobalHotkey}" 
                                         Padding="10" 
                                         FontSize="14"
                                         FontWeight="Bold"
                                         Background="#F5F5F5" 
                                         BorderThickness="1"
                                         BorderBrush="#DDD"
                                         IsReadOnly="True" 
                                         Cursor="IBeam"
                                         PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                                         ToolTip="点击此处并按下键盘组合键来修改"/>

                                <TextBlock Text="* 点击输入框并直接按下键盘组合键（如 Ctrl+Shift+X）即可修改" Foreground="#999" FontSize="11" Margin="0,5,0,0"/>
                            </StackPanel>

                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSettingsTab}" Value="2">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="输入发送模式" Foreground="#333" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                                <Border Background="#F9F9F9" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                                    <RadioButton GroupName="InputMode" 
                                                 IsChecked="{Binding LocalConfig.Mode, Converter={models:EnumToBoolConverter}, ConverterParameter=SmartFocus}"
                                                 Content="智能回退模式 (推荐)" 
                                                 FontSize="14" FontWeight="Bold" Cursor="Hand"/>
                                </Border>
                                <TextBlock Text="软件隐藏后，自动将焦点还给上一个活动的窗口 (如浏览器输入框)，然后发送内容。" 
                                           Foreground="#888" FontSize="12" Margin="5,0,0,20" TextWrapping="Wrap"/>

                                <Border Background="#F9F9F9" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                                    <RadioButton GroupName="InputMode" 
                                                 IsChecked="{Binding LocalConfig.Mode, Converter={models:EnumToBoolConverter}, ConverterParameter=CoordinateClick}"
                                                 Content="坐标点击模式" 
                                                 FontSize="14" FontWeight="Bold" Cursor="Hand"/>
                                </Border>
                                <TextBlock Text="软件隐藏后，强制点击屏幕上的指定位置来激活输入框。" 
                                           Foreground="#888" FontSize="12" Margin="5,0,0,10" TextWrapping="Wrap"/>

                                <StackPanel Margin="20,0,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LocalConfig.Mode}" Value="CoordinateClick">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Grid Margin="0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="X 坐标" Foreground="#666" FontSize="12"/>
                                            <TextBox Text="{Binding LocalConfig.ClickX}" Width="60" Padding="5" Margin="0,5,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Y 坐标" Foreground="#666" FontSize="12"/>
                                            <TextBox Text="{Binding LocalConfig.ClickY}" Width="60" Padding="5" Margin="0,5,0,0"/>
                                        </StackPanel>

                                        <Button Grid.Column="4" Content="⏱️ 3秒后拾取" Click="PickCoordinate_Click"
                                                VerticalAlignment="Bottom" Height="30" Padding="10,0"
                                                Background="#4183C4" Foreground="White" BorderThickness="0">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="4"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                    <TextBlock Text="* 点击按钮后请迅速移动鼠标到目标位置，等待3秒自动记录。" Foreground="#999" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Orientation="Horizontal">
                                <Button Content="完成" Command="{Binding SaveSettingsCommand}" 
                                        Background="#333" Foreground="White" BorderThickness="0" Padding="25,8" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>