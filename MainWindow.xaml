                                                         FontSize="14" FontWeight="Bold" Cursor="Hand"/>
                                        </Border>
                                        

                                        <Border Background="#F9F9F9" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                                            <RadioButton GroupName="MiniEnterMode"
