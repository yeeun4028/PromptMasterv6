        <Style x:Key="Block1ToolTipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource Block1Background}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Grid Margin="0,0,5,5">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2" Padding="8,4">
                                <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.2" ShadowDepth="2" Direction="315" BlurRadius="4"/>
                            </Border.Effect>
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 状态文本样式 -->
        <Style x:Key="TestStatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding TestStatus}" Value="Failed">
                    <Setter Property="Foreground" Value="#E53935"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TestStatus}" Value="Success">
                    <Setter Property="Foreground" Value="#43A047"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TestStatus}" Value="Testing">
                    <Setter Property="Foreground" Value="#666"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 旋转动画 -->
        <Storyboard x:Key="RotateAnimation" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                From="0" To="360" Duration="0:0:1"/>
        </Storyboard>

        <!-- Modern ContextMenu Style -->
        <Style x:Key="ModernContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Grid.IsSharedSizeScope" Value="True"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border x:Name="Border" 
                                Background="{DynamicResource ShellBackground}"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource DividerBrush}"
                                CornerRadius="8"
                                Padding="4">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="2"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tray MenuItem Style -->
        <Style x:Key="TrayMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}" 
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="ContentPresenter" 
                                              Content="{TemplateBinding Header}" 
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              ContentStringFormat="{TemplateBinding HeaderStringFormat}"
                                              RecognizesAccessKey="True" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- No Icon MenuItem Style (Win11 Style) -->
        <Style x:Key="NoIconMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}" 
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="ContentPresenter" 
                                              Content="{TemplateBinding Header}" 
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              ContentStringFormat="{TemplateBinding HeaderStringFormat}"
                                              RecognizesAccessKey="True" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NoIconSeparatorStyle" TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="{TemplateBinding Height}" 
                                Background="{TemplateBinding Background}" 
                                Margin="{TemplateBinding Margin}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tray ContextMenu Resource -->
        <ContextMenu x:Key="TrayMenu" Style="{StaticResource ModernContextMenuStyle}">
              <MenuItem Header="显示/隐藏窗口"
                        Style="{StaticResource TrayMenuItemStyle}"
                        Click="Tray_ToggleVisibility_Click"/>
              <MenuItem Header="云端同步" 
                        Style="{StaticResource TrayMenuItemStyle}"
                        Command="{Binding ManualBackupCommand}"/>
              <MenuItem Header="配置中心" 
                        Style="{StaticResource TrayMenuItemStyle}"
                        Command="{Binding OpenSettingsCommand}"/>
              <MenuItem Header="退出" 
                        Style="{StaticResource TrayMenuItemStyle}"
                        Click="Tray_Exit_Click"/>
          </ContextMenu>

        <Style x:Key="FolderListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                <Setter Property="ContextMenu">
                    <Setter.Value>
                        <ContextMenu Style="{StaticResource ModernContextMenuStyle}">
                            <ContextMenu.Resources>
                                <Style TargetType="MenuItem" BasedOn="{StaticResource NoIconMenuItemStyle}"/>
                                <Style TargetType="Separator" BasedOn="{StaticResource NoIconSeparatorStyle}"/>
                            </ContextMenu.Resources>
                            <MenuItem Header="设置图标" 
                                      Command="{Binding PlacementTarget.Tag.SidebarVM.ChangeFolderIconCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding}"/>
                            <MenuItem Header="重命名" 
                                      Command="{Binding PlacementTarget.Tag.SidebarVM.RenameFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding}"/>
                            <MenuItem Header="删除" 
                                      Command="{Binding PlacementTarget.Tag.SidebarVM.DeleteFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding}"/>
                        </ContextMenu>
                    </Setter.Value>
                </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" Width="40" Height="40" CornerRadius="4">
                            <Border.ToolTip>
                                <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="{Binding Name}"/>
                            </Border.ToolTip>
                            <Path x:Name="IconPath" 
                                  Data="{Binding IconGeometry, Converter={StaticResource StringToGeometryConverter}, FallbackValue={StaticResource IconFolderLinear}}" 
                                  Fill="{DynamicResource ActionIconBrush}" 
                                  Stretch="Uniform" 
                                  Width="18" Height="18" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IconGeometry}" Value="{x:Null}">
                                <Setter TargetName="IconPath" Property="Data" Value="{StaticResource IconFolderLinear}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IconGeometry}" Value="">
                                <Setter TargetName="IconPath" Property="Data" Value="{StaticResource IconFolderLinear}"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FileListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                <Setter Property="ContextMenu">
                    <Setter.Value>
                        <ContextMenu Style="{StaticResource ModernContextMenuStyle}">
                            <ContextMenu.Resources>
                                <Style TargetType="MenuItem" BasedOn="{StaticResource NoIconMenuItemStyle}"/>
                                <Style TargetType="Separator" BasedOn="{StaticResource NoIconSeparatorStyle}"/>
                            </ContextMenu.Resources>
                            <MenuItem Header="设置图标" 
                                      Command="{Binding PlacementTarget.Tag.ChangeFileIconCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding}"/>
                            <MenuItem Header="删除" 
                                      Command="{Binding PlacementTarget.Tag.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding}"/>

                        </ContextMenu>
                    </Setter.Value>
                </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path x:Name="FileIcon" 
                                      Data="{Binding IconGeometry, Converter={StaticResource StringToGeometryConverter}, FallbackValue={StaticResource IconFolderLinear}}" 
                                      Visibility="Visible" 
                                      Fill="{DynamicResource PlaceholderTextBrush}" 
                                      Stretch="Uniform" 
                                      Width="14" 
                                      Height="14" 
                                      Margin="0,1,8,0" 
                                      VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IconGeometry}" Value="{x:Null}">
                                <Setter TargetName="FileIcon" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IconGeometry}" Value="">
                                <Setter TargetName="FileIcon" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                <Setter TargetName="FileIcon" Property="Fill" Value="{DynamicResource SecondaryTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ListItemSelectedBackgroundBrush}"/>
                                <Setter TargetName="FileIcon" Property="Fill" Value="{DynamicResource PrimaryTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Width="40" Height="40" CornerRadius="4" ToolTip="{TemplateBinding Content}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionIconPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="{DynamicResource ActionIconBrush}"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmallHeaderIconStyle" TargetType="Path" BasedOn="{StaticResource ActionIconPathStyle}">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Fill" Value="{DynamicResource HeaderIconBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Fill" Value="{DynamicResource HeaderIconHoverBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsTabBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HiddenScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="Transparent"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555" CornerRadius="2" Opacity="0.4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <Style x:Key="Block2ScrollBarStyle" TargetType="ScrollBar" BasedOn="{StaticResource HiddenScrollBarStyle}">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource Block2Background}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="Transparent" CornerRadius="2" Opacity="0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>




    </Window.Resources>

    <Grid UseLayoutRounding="True" SnapsToDevicePixels="True">
        <!-- Growl Toast Notification Host -->
        <StackPanel hc:Growl.GrowlParent="True"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,20,20,0" Panel.ZIndex="10000" IsHitTestVisible="False"/>

        <Grid x:Name="FullModeContainer"
              Visibility="{Binding IsFullMode, Converter={StaticResource BoolToVis}}"
              Background="Transparent">

            <Border Background="{DynamicResource ShellBackground}" CornerRadius="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding LocalConfig.Block1Width, Mode=TwoWay, Converter={StaticResource DoubleToGridLengthConverter}}" MinWidth="20"/>
                        <ColumnDefinition Width="{Binding LocalConfig.Block2Width, Mode=TwoWay, Converter={StaticResource DoubleToGridLengthConverter}}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Height="40" VerticalAlignment="Top" Background="Transparent">
                        <b:Interaction.Behaviors>
                            <behaviors:WindowDragBehavior/>
                        </b:Interaction.Behaviors>
                    </Border>

                    <Border Grid.Column="0" 
                            Background="{DynamicResource Block1Background}" 
                            CornerRadius="5,0,0,5">
                        <Grid>
                            <ListBox ItemsSource="{Binding SidebarVM.Folders}" 
                                     SelectedItem="{Binding SidebarVM.SelectedFolder}"
                                     ItemContainerStyle="{StaticResource FolderListBoxItemStyle}" 
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                                     VerticalAlignment="Top" 
                                     Margin="0,15,0,0"
                                     dd:DragDrop.IsDragSource="True" 
                                     dd:DragDrop.IsDropTarget="True"
                                     dd:DragDrop.DropHandler="{Binding SidebarVM.FolderDropHandler}"/>

                            <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,20">
                                <Button Style="{StaticResource ActionBtnStyle}" Content="新建文档" Command="{Binding SidebarVM.CreateFileCommand}">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="设置图标..."
                                                      Command="{Binding ChangeActionIconCommand}"
                                                      CommandParameter="CreateFile"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="新建文档"/>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Path Data="{Binding DataContext.LocalConfig.ActionIcons[CreateFile], RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringToGeometryConverter}, FallbackValue={StaticResource IconNewDoc}}" Style="{StaticResource ActionIconPathStyle}"/>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button Style="{StaticResource ActionBtnStyle}" Content="新建文件夹" Command="{Binding SidebarVM.CreateFolderCommand}">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="设置图标..."
                                                      Command="{Binding ChangeActionIconCommand}"
                                                      CommandParameter="CreateFolder"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="新建文件夹"/>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Path Data="{Binding DataContext.LocalConfig.ActionIcons[CreateFolder], RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringToGeometryConverter}, FallbackValue={StaticResource IconNewFolder}}" Style="{StaticResource ActionIconPathStyle}"/>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button Style="{StaticResource ActionBtnStyle}" Content="导入" Command="{Binding ImportMarkdownFilesCommand}">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="设置图标..."
                                                      Command="{Binding ChangeActionIconCommand}"
                                                      CommandParameter="Import"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="导入 Markdown 文件"/>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Path Data="{Binding DataContext.LocalConfig.ActionIcons[Import], RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringToGeometryConverter}, FallbackValue={StaticResource IconImport}}" Style="{StaticResource ActionIconPathStyle}"/>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button Style="{StaticResource ActionBtnStyle}" Content="设置" Command="{Binding OpenSettingsCommand}">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="设置图标..."
                                                      Command="{Binding ChangeActionIconCommand}"
                                                      CommandParameter="Settings"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="设置"/>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Path Data="{Binding DataContext.LocalConfig.ActionIcons[Settings], RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource StringToGeometryConverter}, FallbackValue={StaticResource IconSettings}}" Style="{StaticResource ActionIconPathStyle}"/>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                                    <TextBlock Text="{Binding SyncTimeDisplay}" 
                                               FontSize="10" 
                                               Foreground="{DynamicResource PlaceholderTextBrush}"
                                               VerticalAlignment="Center"/>
                                    <!-- ★★★ 新增：脏数据状态指示器 (红色星号) ★★★ -->
                                    <TextBlock Text="*" 
                                               FontSize="14" 
                                               FontWeight="Bold"
                                               Foreground="#E53935" 
                                               Margin="2,-5,0,0"
                                               VerticalAlignment="Center"
                                               ToolTip="有未备份的更改 (请点击上方设置按钮旁的备份按钮)"
                                               Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="0" 
                                  Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True"/>

                    <Border Grid.Column="1" Background="{DynamicResource Block2Background}">
                        <Grid>
                            <Grid Height="40" VerticalAlignment="Top" Background="Transparent">
                                <b:Interaction.Behaviors>
                                    <behaviors:WindowDragBehavior/>
                                </b:Interaction.Behaviors>
                            </Grid>

                            <ListBox ItemsSource="{Binding FilesView}"
                                      SelectedItem="{Binding SelectedFile}"
                                      ItemContainerStyle="{StaticResource FileListBoxItemStyle}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Margin="10,23,5,10"
                                      dd:DragDrop.IsDragSource="True"
                                      dd:DragDrop.IsDropTarget="True">
                                <ListBox.Resources>
                                    <Style TargetType="ScrollBar" BasedOn="{StaticResource Block2ScrollBarStyle}"/>
                                </ListBox.Resources>

                                <ListBox.InputBindings>
                                    <KeyBinding Key="Delete" Command="{Binding DeleteFileCommand}" CommandParameter="{Binding SelectedFile}"/>
                                </ListBox.InputBindings>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True"/>
                    <Border Grid.Column="1" Width="1" HorizontalAlignment="Right" Background="{DynamicResource DividerBrush}" IsHitTestVisible="False"/>

                    <Border Grid.Column="2" Background="{DynamicResource Block3Background}" CornerRadius="0,5,5,0">
                        <Grid>
                            <Grid.Resources>
                                <Style TargetType="ScrollBar">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Grid Background="Transparent"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                                    <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
                                </Style>
                            </Grid.Resources>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="7*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="3*"/>
                            </Grid.RowDefinitions>

                            <!-- 空状态占位提示 -->
                            <TextBlock Grid.Row="0"
                                       Text="请在左侧选择或新建提示词"
                                       FontSize="16"
                                       Foreground="{DynamicResource PlaceholderTextBrush}"
                                       FontFamily="Segoe UI, Microsoft YaHei UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedFile}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Grid Grid.Row="0" Margin="20,10,20,0" TextElement.Foreground="{DynamicResource Block3EditorTextBrush}" TextElement.FontFamily="Segoe UI, Microsoft YaHei UI">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedFile}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,10" Background="Transparent">
                                    <b:Interaction.Behaviors>
                                        <behaviors:WindowDragBehavior/>
                                    </b:Interaction.Behaviors>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Margin="0,20,0,0">
                                        <TextBox x:Name="Block3TitleEditor"
                                                 ContextMenu="{DynamicResource UnifiedEditorContextMenu}"
                                                 Text="{Binding SelectedFile.Title, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="18"
                                                 FontWeight="Bold"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Foreground="{DynamicResource Block3EditorTextBrush}"
                                                 CaretBrush="{DynamicResource Block3EditorCaretBrush}"
                                                 SelectionBrush="{DynamicResource Block3EditorSelectionBrush}"
                                                 SelectionOpacity="1"
                                                 TextBlock.LineHeight="26"
                                                 TextOptions.TextFormattingMode="Ideal"
                                                 TextOptions.TextRenderingMode="ClearType"
                                                 FontFamily="Segoe UI, Microsoft YaHei UI"
                                                 LostFocus="Block3TitleEditor_LostFocus">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                        <TextBlock Text="未命名提示词"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource PlaceholderTextBrush}"
                                                   FontFamily="Segoe UI, Microsoft YaHei UI"
                                                   IsHitTestVisible="False"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding ElementName=Block3TitleEditor, Path=Text}" Value=""/>
                                                                <Condition Binding="{Binding ElementName=Block3TitleEditor, Path=IsKeyboardFocusWithin}" Value="False"/>
                                                                <Condition Binding="{Binding IsEditMode}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding SelectedFile.Title}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"
                                               Foreground="{DynamicResource Block3EditorTextBrush}"
                                               FontFamily="Segoe UI, Microsoft YaHei UI"
                                               Margin="0,20,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedFile.Title}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedFile.Title}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="0"
                                               Text="未命名提示词"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"
                                               Foreground="{DynamicResource PlaceholderTextBrush}"
                                               FontFamily="Segoe UI, Microsoft YaHei UI"
                                               Margin="0,20,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedFile.Title}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding SelectedFile.Title}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">


                                        <!-- ★★★ 新增：手动备份按钮 ★★★ -->
                                        <Button Command="{Binding ManualBackupCommand}" Style="{StaticResource ActionBtnStyle}">
                                            <Button.ToolTip>
                                                <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="备份到云端"/>
                                            </Button.ToolTip>
                                            <Button.ContentTemplate>
                                                <DataTemplate>
                                                    <Path x:Name="IconPath" 
                                                          Data="{StaticResource IconCloudUpload}"
                                                          Style="{StaticResource SmallHeaderIconStyle}"/>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.IsDirty, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                            <Setter TargetName="IconPath" Property="Fill" Value="#E53935"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </Button.ContentTemplate>
                                        </Button>
                                        <Button Command="{Binding ToggleEditModeCommand}" Style="{StaticResource ActionBtnStyle}">
                                            <Button.ToolTip>
                                                <ToolTip>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ToolTip}}" Value="True">
                                                                        <Setter Property="Text" Value="点击锁定并保存"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding PlacementTarget.DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ToolTip}}" Value="False">
                                                                        <Setter Property="Text" Value="点击解锁编辑"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </ToolTip>
                                            </Button.ToolTip>
                                            <Button.ContentTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Path Data="{StaticResource IconLockOpenThin}">
                                                            <Path.Style>
                                                                <Style TargetType="Path" BasedOn="{StaticResource SmallHeaderIconStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                        <Path Data="{StaticResource IconLockClosedThin}">
                                                            <Path.Style>
                                                                <Style TargetType="Path" BasedOn="{StaticResource SmallHeaderIconStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Grid>
                                                </DataTemplate>
                                            </Button.ContentTemplate>
                                        </Button>

                                        <Button x:Name="MaximizeRestoreButton" Click="MaximizeRestoreButton_Click" Style="{StaticResource ActionBtnStyle}">
                                            <Button.ToolTip>
                                                <ToolTip>
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding PlacementTarget.(Window.WindowState), RelativeSource={RelativeSource AncestorType=ToolTip}}" Value="Maximized">
                                                                        <Setter Property="Text" Value="还原窗口"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding PlacementTarget.(Window.WindowState), RelativeSource={RelativeSource AncestorType=ToolTip}}" Value="Normal">
                                                                        <Setter Property="Text" Value="最大化窗口"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </ToolTip>
                                            </Button.ToolTip>
                                            <Button.ContentTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Path x:Name="MaximizeIcon" Data="{StaticResource IconMaximizeThin}" Style="{StaticResource SmallHeaderIconStyle}"/>
                                                        <Path x:Name="RestoreIcon" Data="{StaticResource IconRestoreThin}" Style="{StaticResource SmallHeaderIconStyle}" Visibility="Collapsed"/>
                                                    </Grid>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                                                            <Setter TargetName="MaximizeIcon" Property="Visibility" Value="Collapsed"/>
                                                            <Setter TargetName="RestoreIcon" Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </Button.ContentTemplate>
                                        </Button>

                                        <Button Click="CloseButton_Click" Style="{StaticResource ActionBtnStyle}" ToolTip="关闭窗口 (隐藏)">
                                            <Button.ContentTemplate>
                                                <DataTemplate>
                                                    <Path Data="{StaticResource IconCloseThin}" Style="{StaticResource SmallHeaderIconStyle}"/>
                                                </DataTemplate>
                                            </Button.ContentTemplate>
                                        </Button>

                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <TextBox x:Name="Block3ContentEditor"
                                             ContextMenu="{DynamicResource UnifiedEditorContextMenu}"
                                             Text="{Binding SelectedFile.Content, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalContentAlignment="Top"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{DynamicResource Block3EditorTextBrush}"
                                             CaretBrush="{DynamicResource Block3EditorCaretBrush}"
                                             SelectionBrush="{DynamicResource Block3EditorSelectionBrush}"
                                             SelectionOpacity="1"
                                             FontSize="14"
                                             TextBlock.LineHeight="26"
                                             TextOptions.TextFormattingMode="Ideal"
                                             TextOptions.TextRenderingMode="ClearType"
                                             Padding="5"
                                             FontFamily="Segoe UI, Microsoft YaHei UI"
                                             PreviewKeyDown="TextBox_PreviewKeyDown"
                                             LostFocus="Block3ContentEditor_LostFocus"
                                             hc:InfoElement.Placeholder="在此处键入提示词内容...">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                </Grid>

                                <md:MarkdownViewer Grid.Row="1"
                                                  Loaded="MarkdownViewer_Loaded"
                                                  ContextMenu="{DynamicResource UnifiedEditorContextMenu}"
                                                  Markdown="{Binding PreviewContent}"
                                                  Pipeline="{Binding Pipeline}"
                                                  xml:lang="zh-CN"
                                                  Background="{DynamicResource Block3Background}">
                                    <md:MarkdownViewer.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#4A89DC"/>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#B8BFC6"/>

                                        <Style TargetType="FlowDocumentScrollViewer">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>

                                        <Style x:Key="{x:Static md:Styles.DocumentStyleKey}" TargetType="{x:Type FlowDocument}">
                                            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
                                            <Setter Property="FontSize" Value="16"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Block3EditorTextBrush}"/>
                                            <Setter Property="LineHeight" Value="26"/>
                                            <Setter Property="TextAlignment" Value="Left"/>
                                            <Setter Property="PagePadding" Value="30,30,30,50"/>
                                            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
                                            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Style>
                                    </md:MarkdownViewer.Resources>
                                    <md:MarkdownViewer.Style>
                                        <Style TargetType="md:MarkdownViewer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </md:MarkdownViewer.Style>
                                </md:MarkdownViewer>
                                <TextBlock Grid.Row="1"
                                           Text="在此处键入内容..."
                                           Foreground="{DynamicResource PlaceholderTextBrush}"
                                           FontFamily="Segoe UI, Microsoft YaHei UI"
                                           FontSize="14"
                                           Margin="5"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Top">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedFile.Content}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedFile.Content}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <Border Grid.Row="1" Height="1" Background="{DynamicResource DividerBrush}" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent" ResizeBehavior="PreviousAndNext" ShowsPreview="True"/>

                            <Border Grid.Row="2" Background="{DynamicResource Block4Background}">
                                <Border.Resources>
                                    <Style x:Key="Block4MenuItemStyle" TargetType="MenuItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="Padding" Value="12,4"/>
                                        <Setter Property="Margin" Value="0,0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="MenuItem">
                                                    <Border x:Name="Bd" 
                                                            Background="{TemplateBinding Background}" 
                                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                                            BorderThickness="{TemplateBinding BorderThickness}" 
                                                            Padding="{TemplateBinding Padding}" 
                                                            CornerRadius="6"
                                                            SnapsToDevicePixels="True">
                                                        <ContentPresenter x:Name="ContentPresenter" 
                                                                          Content="{TemplateBinding Header}" 
                                                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                                          ContentStringFormat="{TemplateBinding HeaderStringFormat}"
                                                                          RecognizesAccessKey="True" 
                                                                          VerticalAlignment="Center" 
                                                                          HorizontalAlignment="Left"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsHighlighted" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemSelectedBackgroundBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>

                                    <Style x:Key="Block4EditorContextMenuStyle" TargetType="ContextMenu">
                                        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        <Setter Property="Padding" Value="0,4"/>
                                        <Setter Property="ItemContainerStyle" Value="{StaticResource Block4MenuItemStyle}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContextMenu">
                                                    <Border x:Name="Bd" 
                                                            Background="{TemplateBinding Background}" 
                                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8"
                                                            Padding="{TemplateBinding Padding}">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="12" Opacity="0.3"/>
                                                        </Border.Effect>
                                                        <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>

                                    <ContextMenu x:Key="Block4EditorContextMenu" x:Shared="False" Style="{StaticResource Block4EditorContextMenuStyle}">
                                        <MenuItem Command="ApplicationCommands.Cut" Header="剪切" InputGestureText=""/>
                                        <MenuItem Command="ApplicationCommands.Copy" Header="复制" InputGestureText=""/>
                                        <MenuItem Command="ApplicationCommands.Paste" Header="粘贴" InputGestureText=""/>
                                        <Separator Style="{StaticResource NoIconSeparatorStyle}"/>
                                        <MenuItem Command="ApplicationCommands.SelectAll" Header="全选" InputGestureText=""/>
                                    </ContextMenu>
                                </Border.Resources>
                                <Grid Margin="20,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- ★★★ Web Direct Targets (Block4 顶部) ★★★ -->
                                    <Grid Grid.Row="0" Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <ItemsControl ItemsSource="{Binding Config.WebDirectTargets}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.OpenWebTargetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="{Binding Name}"
                                                            Visibility="{Binding IsEnabled, Converter={StaticResource BoolToVis}}"
                                                            Margin="0,0,8,0"
                                                            Padding="6,4"
                                                            Cursor="Hand"
                                                            Background="Transparent"
                                                            BorderThickness="0">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Path x:Name="Icon" 
                                                                              Data="{Binding IconData, Converter={StaticResource StringToGeometryConverter}}"
                                                                              Visibility="{Binding IconData, Converter={StaticResource StringVisibilityConverter}}"
                                                                              Fill="{DynamicResource ActionIconBrush}"
                                                                              Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                                                                        <TextBlock x:Name="Label" Text="{Binding Name}" 
                                                                                   Foreground="{DynamicResource SecondaryTextBrush}" 
                                                                                   FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"
                                                                                   FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                                                    </StackPanel>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                                        <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                                                                        <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- GitHub Search Button -->
                                        <Button Command="{Binding SearchOnGitHubCommand}"
                                                ToolTip="在 GitHub 上搜索 (仅搜索此输入框内容)"
                                                Margin="0,0,0,0"
                                                Padding="6,4"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Path x:Name="Icon" 
                                                                  Data="{StaticResource IconGitHub}"
                                                                  Fill="{DynamicResource ActionIconBrush}"
                                                                  Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                                                            <TextBlock x:Name="Label" Text="GitHub" 
                                                                       Foreground="{DynamicResource SecondaryTextBrush}" 
                                                                       FontSize="11" Margin="5,0,0,0" VerticalAlignment="Center"
                                                                       FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                            <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                                                            <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        </StackPanel>

                                        <!-- Copy Result Button (Far Right) -->
                                        <Button Command="{Binding CopyCompiledTextCommand}"
                                                ToolTip="复制最终结果 (Ctrl+C)"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,0,0"
                                                Padding="6,4"
                                                Cursor="Hand"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <Path x:Name="Icon" 
                                                              Data="{StaticResource IconCopyThin}"
                                                              Fill="{DynamicResource ActionIconBrush}"
                                                              Stretch="Uniform" Width="14" Height="14" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListItemHoverBackgroundBrush}"/>
                                                            <Setter TargetName="Icon" Property="Fill" Value="{DynamicResource ActionIconHoverBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" BorderThickness="0">
                                        <ScrollViewer.Style>
                                            <Style TargetType="ScrollViewer">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasVariables}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ScrollViewer.Style>
                                        <ItemsControl ItemsSource="{Binding Variables}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name, StringFormat='{}{0}:'}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Top" Margin="0,6,10,0" HorizontalAlignment="Right" Foreground="{DynamicResource PrimaryTextBrush}" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                                        <Border x:Name="InputBorder" Grid.Column="1" BorderThickness="0" Background="Transparent" CornerRadius="2,2,0,0">
                                                            <TextBox x:Name="InputBox" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Padding="5" FontSize="14" ContextMenu="{DynamicResource UnifiedEditorContextMenu}" VerticalContentAlignment="Top" AcceptsReturn="True" TextWrapping="Wrap" PreviewKeyDown="TextBox_PreviewKeyDown" Foreground="{DynamicResource PrimaryTextBrush}" FontFamily="Segoe UI, Microsoft YaHei UI" Style="{x:Null}"/>
                                                        </Border>
                                                    </Grid>
                                                    <DataTemplate.Triggers>
                                                        <Trigger SourceName="InputBox" Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="InputBorder" Property="Background" Value="{DynamicResource InputFocusBackgroundBrush}"/>
                                                            <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource GitHubBlue}"/>
                                                            <Setter TargetName="InputBorder" Property="BorderThickness" Value="0,0,0,1"/>
                                                        </Trigger>
                                                        <Trigger SourceName="InputBox" Property="IsKeyboardFocused" Value="True">
                                                            <Setter TargetName="InputBorder" Property="Background" Value="{DynamicResource InputFocusBackgroundBrush}"/>
                                                            <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource GitHubBlue}"/>
                                                            <Setter TargetName="InputBorder" Property="BorderThickness" Value="0,0,0,1"/>
                                                        </Trigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <TextBox Grid.Row="1" Text="{Binding AdditionalInput, UpdateSourceTrigger=PropertyChanged}" 
                                             Foreground="{DynamicResource PrimaryTextBrush}"
                                             CaretBrush="{DynamicResource PrimaryTextBrush}"
                                             PreviewKeyDown="AdditionalInputBox_PreviewKeyDown"
                                             AcceptsReturn="True" 
                                             TextWrapping="Wrap" 
                                             Padding="10" 
                                             BorderThickness="0" 
                                             Background="Transparent" 
                                             VerticalContentAlignment="Top" 
                                             ContextMenu="{DynamicResource UnifiedEditorContextMenu}"
                                             FontSize="14" 
                                             FontFamily="Segoe UI, Microsoft YaHei UI">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasVariables}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
