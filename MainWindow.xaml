        <utils:InverseBoolConverter x:Key="InverseBoolConverter"/>

        <!-- 加载动画图标（旋转圆环） -->
        <Geometry x:Key="IconLoading">M12 2A10 10 0 1 0 22 12A10 10 0 0 0 12 2M12 4A8 8 0 1 1 4 12A8 8 0 0 1 12 4Z</Geometry>

        <Style x:Key="Block1ToolTipStyle" TargetType="ToolTip">
            <Setter Property="Background" Value="{StaticResource Block1Background}"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Grid Margin="0,0,5,5">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2" Padding="8,4">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.2" ShadowDepth="2" Direction="315" BlurRadius="4"/>
                                </Border.Effect>
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 状态文本样式 -->
        <Style x:Key="TestStatusTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding TestStatus}" Value="Failed">
                    <Setter Property="Foreground" Value="#E53935"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TestStatus}" Value="Success">
                    <Setter Property="Foreground" Value="#43A047"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TestStatus}" Value="Testing">
                    <Setter Property="Foreground" Value="#666"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 旋转动画 -->
        <Storyboard x:Key="RotateAnimation" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                From="0" To="360" Duration="0:0:1"/>
        </Storyboard>

        <Style x:Key="FolderListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                <Setter Property="ContextMenu">
                    <Setter.Value>
                        <ContextMenu>
                            <MenuItem Header="设置图标..." 
                                      Command="{Binding PlacementTarget.Tag.ChangeFolderIconCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding}"/>
                            <MenuItem Header="重命名..." 
                                      Command="{Binding PlacementTarget.Tag.RenameFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding}"/>
                            <Separator/>
                            <MenuItem Header="删除" 
                                      Command="{Binding PlacementTarget.Tag.DeleteFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding}">
                                <MenuItem.Icon>
                                    <Path Data="{StaticResource IconDelete}" Fill="#333" Stretch="Uniform" Width="12"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </Setter.Value>
                </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" Width="40" Height="40" CornerRadius="4">
                            <Border.ToolTip>
                                <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="{Binding Name}"/>
                            </Border.ToolTip>
                            <Path x:Name="IconPath" 
                                  Data="{Binding IconGeometry}" 
                                  Fill="#898888" 
                                  Stretch="Uniform" 
                                  Width="20" Height="20" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IconGeometry}" Value="{x:Null}">
                                <Setter TargetName="IconPath" Property="Data" Value="{StaticResource IconFolderLinear}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IconGeometry}" Value="">
                                <Setter TargetName="IconPath" Property="Data" Value="{StaticResource IconFolderLinear}"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="IconPath" Property="Fill" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="IconPath" Property="Fill" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FileListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
            <EventSetter Event="MouseDoubleClick" Handler="FileListBoxItem_MouseDoubleClick"/>
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Header="设置图标..." 
                                  Command="{Binding PlacementTarget.Tag.ChangeFileIconCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                        <Separator/>
                        <MenuItem Header="删除" 
                                  Command="{Binding PlacementTarget.Tag.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}">
                            <MenuItem.Icon>
                                <Path Data="{StaticResource IconDelete}" Fill="#333" Stretch="Uniform" Width="12"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path x:Name="FileIcon" 
                                      Data="{Binding IconGeometry}" 
                                      Visibility="Visible" 
                                      Fill="#999" 
                                      Stretch="Uniform" 
                                      Width="14" 
                                      Height="14" 
                                      Margin="0,1,8,0" 
                                      VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IconGeometry}" Value="{x:Null}">
                                <Setter TargetName="FileIcon" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IconGeometry}" Value="">
                                <Setter TargetName="FileIcon" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EAEAEA"/>
                                <Setter TargetName="FileIcon" Property="Fill" Value="#666"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E0E0E0"/>
                                <Setter TargetName="FileIcon" Property="Fill" Value="#333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Width="40" Height="40" CornerRadius="4" ToolTip="{TemplateBinding Content}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionIconPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="#898888"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Fill" Value="Black"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SmallHeaderIconStyle" TargetType="Path" BasedOn="{StaticResource ActionIconPathStyle}">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Fill" Value="#666666"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                    <Setter Property="Fill" Value="#333333"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsTabBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#EAEAEA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HiddenScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="Transparent"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555" CornerRadius="2" Opacity="0.4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="MiniModeContainer" 
              Visibility="{Binding IsFullMode, Converter={StaticResource InverseBoolToVis}}"
              Background="Transparent">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource MiniBackgroundBrush}" 
                    CornerRadius="8" 
                    Margin="10,10,10,0"
                    Panel.ZIndex="1"
                    Effect="{StaticResource EffectShadow2}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="15" Background="Transparent" Cursor="SizeAll" MouseLeftButtonDown="MiniWindow_MouseLeftButtonDown">
                        <Path Data="M4,10 L4,20 M8,10 L8,20" Stroke="#555" StrokeThickness="2" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>

                    <Grid Grid.Column="1" VerticalAlignment="Stretch" Margin="5,5">
                        <TextBox x:Name="MiniInputBox"
                                 Text="{Binding MiniInputText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MiniTextBoxStyle}"
                                 VerticalScrollBarVisibility="Auto"  
                                 d:Text="输入 / 搜索提示词..."
                                 PreviewKeyDown="MiniInput_PreviewKeyDown"
                                 TextChanged="MiniInput_TextChanged">
                            <TextBox.Resources>
                                <Style TargetType="ScrollBar" BasedOn="{StaticResource HiddenScrollBarStyle}"/>
                            </TextBox.Resources>
                        </TextBox>

                        <Popup IsOpen="{Binding IsSearchPopupOpen}" 
                               PlacementTarget="{Binding ElementName=MiniInputBox}"
                               Placement="Bottom"
                               StaysOpen="False"
                               VerticalOffset="5">
                            <Border Background="{StaticResource MiniSearchBackgroundBrush}" 
                                    BorderBrush="#444" 
                                    BorderThickness="1" 
                                    CornerRadius="4" 
                                    Width="400" 
                                    MaxHeight="300">
                                <ListBox x:Name="SearchListBox"
                                         ItemsSource="{Binding SearchResults}" 
                                         SelectedItem="{Binding SelectedSearchItem}"
                                         Background="Transparent" 
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="5">
                                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Content}" Foreground="#999" FontSize="11" TextTrimming="CharacterEllipsis" MaxHeight="30"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="5"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource MiniHighlightBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <EventSetter Event="MouseLeftButtonUp" Handler="SearchResult_Click"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Border>
                        </Popup>
                    </Grid>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,15,10,0">
                        <!-- ★★★ 新增：AI 处理状态指示器 ★★★ -->
                        <TextBlock Text="✨ 思考中..." 
                                   Foreground="#AAA" 
                                   FontSize="11" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,10,0"
                                   Visibility="{Binding IsAiProcessing, Converter={StaticResource BoolToVis}}"/>

                        <Button Command="{Binding EnterFullModeCommand}"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="展开 (Ctrl+Up)">
                            <Path Data="M4,12 L10,6 L16,12" Stroke="#888" StrokeThickness="2"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource MiniSearchBackgroundBrush}" 
                    CornerRadius="8"
                    Margin="10,1,10,10"
                    Padding="0,10,0,5"
                    Effect="{StaticResource EffectShadow2}"
                    Visibility="{Binding IsMiniVarsExpanded, Converter={StaticResource BoolToVis}}"
                    VerticalAlignment="Top">

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource HiddenScrollBarStyle}"/>
                    </ScrollViewer.Resources>

                    <ItemsControl x:Name="MiniVarsList" ItemsSource="{Binding Variables}" Margin="15,5">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="MiniLabel"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name, StringFormat='{}{0}:'}" 
                                               Foreground="#CCC" 
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" 
                                               HorizontalAlignment="Right" 
                                               Margin="0,0,10,0"/>
                                    <Border x:Name="InputBorder" Grid.Column="1" 
                                            BorderThickness="0,0,0,1" 
                                            BorderBrush="#555" 
                                            Background="Transparent">
                                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                                 Background="Transparent" 
                                                 Foreground="White" 
                                                 BorderThickness="0" 
                                                 Padding="2"
                                                 CaretBrush="White"
                                                 PreviewKeyDown="TextBox_PreviewKeyDown"/>
                                    </Border>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="InputBorder" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid x:Name="FullModeContainer"
              Visibility="{Binding IsFullMode, Converter={StaticResource BoolToVis}}"
              Background="Transparent">

            <Border Background="#FAFAFA" CornerRadius="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Height="40" VerticalAlignment="Top" Background="Transparent" MouseLeftButtonDown="FullWindow_MouseLeftButtonDown" />

                    <Border Grid.Column="0" 
                            Width="60"
                            Visibility="{Binding IsNavigationVisible, Converter={StaticResource BoolToVis}}"
                            Background="{StaticResource Block1Background}" 
                            CornerRadius="5,0,0,5">
                        <Grid>
                            <ListBox ItemsSource="{Binding Folders}" 
                                     SelectedItem="{Binding SelectedFolder}"
                                     ItemContainerStyle="{StaticResource FolderListBoxItemStyle}" 
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                                     VerticalAlignment="Top" 
                                     Margin="0,15,0,0"
                                     dd:DragDrop.IsDragSource="True" 
                                     dd:DragDrop.IsDropTarget="True"
                                     dd:DragDrop.DropHandler="{Binding FolderDropHandler}"/>

                            <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,20">
                                <Button Style="{StaticResource ActionBtnStyle}" Content="新建文档" Command="{Binding CreateFileCommand}">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="设置图标..."
                                                      Command="{Binding ChangeActionIconCommand}"
                                                      CommandParameter="CreateFile"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="新建文档"/>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Path Data="{Binding LocalConfig.ActionIcons[CreateFile], TargetNullValue={StaticResource IconNewDoc}, FallbackValue={StaticResource IconNewDoc}}" Style="{StaticResource ActionIconPathStyle}"/>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button Style="{StaticResource ActionBtnStyle}" Content="新建文件夹" Command="{Binding CreateFolderCommand}">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="设置图标..."
                                                      Command="{Binding ChangeActionIconCommand}"
                                                      CommandParameter="CreateFolder"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="新建文件夹"/>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Path Data="{Binding LocalConfig.ActionIcons[CreateFolder], TargetNullValue={StaticResource IconNewFolder}, FallbackValue={StaticResource IconNewFolder}}" Style="{StaticResource ActionIconPathStyle}"/>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button Style="{StaticResource ActionBtnStyle}" Content="导入" Command="{Binding ImportMarkdownFilesCommand}">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="设置图标..."
                                                      Command="{Binding ChangeActionIconCommand}"
                                                      CommandParameter="Import"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="导入 Markdown 文件"/>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Path Data="{Binding LocalConfig.ActionIcons[Import], TargetNullValue={StaticResource IconImport}, FallbackValue={StaticResource IconImport}}" Style="{StaticResource ActionIconPathStyle}"/>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>
                                <Button Style="{StaticResource ActionBtnStyle}" Content="设置" Command="{Binding OpenSettingsCommand}">
                                    <Button.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="设置图标..."
                                                      Command="{Binding ChangeActionIconCommand}"
                                                      CommandParameter="Settings"/>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <Button.ToolTip>
                                        <ToolTip Style="{StaticResource Block1ToolTipStyle}" Content="设置"/>
                                    </Button.ToolTip>
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <Path Data="{Binding LocalConfig.ActionIcons[Settings], TargetNullValue={StaticResource IconSettings}, FallbackValue={StaticResource IconSettings}}" Style="{StaticResource ActionIconPathStyle}"/>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>

                                <TextBlock Text="{Binding SyncTimeDisplay}" 
                                           HorizontalAlignment="Center" 
                                           FontSize="10" 
                                           Foreground="#999999"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="0" 
                                  Visibility="{Binding IsNavigationVisible, Converter={StaticResource BoolToVis}}"
                                  Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True"/>

                    <Border Grid.Column="1" Background="#F1F1EF">
                        <Grid>
                            <Grid Height="40" VerticalAlignment="Top" Background="Transparent" MouseLeftButtonDown="FullWindow_MouseLeftButtonDown"/>

                            <ListBox ItemsSource="{Binding FilesView}"
                                      SelectedItem="{Binding SelectedFile}"
                                      ItemContainerStyle="{StaticResource FileListBoxItemStyle}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Margin="10,23,5,10"
                                      dd:DragDrop.IsDragSource="True"
                                      dd:DragDrop.IsDropTarget="True">

                                <ListBox.InputBindings>
                                    <KeyBinding Key="Delete" Command="{Binding DeleteFileCommand}"/>
                                </ListBox.InputBindings>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Title}" Foreground="#333333" FontSize="13" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Right" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="True"/>
                    <Border Grid.Column="1" Width="1" HorizontalAlignment="Right" Background="#E0E0E0" IsHitTestVisible="False"/>

                    <Border Grid.Column="2" Background="#FAFAFA" CornerRadius="0,5,5,0">
                        <Grid>
                            <Grid.Resources>
                                <Style TargetType="ScrollBar">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Grid Background="Transparent"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                                    <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
                                </Style>
                            </Grid.Resources>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="7*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="3*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="20,10,20,0">
                                <TextElement.FontFamily>Segoe UI, Microsoft YaHei UI</TextElement.FontFamily>
                                <TextElement.Foreground>#333333</TextElement.Foreground>
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedFile}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Hidden"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,10" Background="Transparent" MouseLeftButtonDown="FullWindow_MouseLeftButtonDown">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding SelectedFile.Title, UpdateSourceTrigger=PropertyChanged}" FontSize="18" FontWeight="Bold" BorderThickness="0" Background="Transparent" Foreground="#333333" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,20,0,0">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <TextBlock Grid.Column="0" Text="{Binding SelectedFile.Title}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" IsHitTestVisible="False" Foreground="#333333" FontFamily="Segoe UI, Microsoft YaHei UI" Margin="0,20,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Command="{Binding ToggleNavigationCommand}" Style="{StaticResource ActionBtnStyle}" ToolTip="切换侧边栏">
                                            <Button.ContentTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Path x:Name="ChevronPath" Stroke="#666666" StrokeThickness="1.5" Stretch="None" Data="{StaticResource IconChevronLeft}"/>
                                                    </Grid>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.IsNavigationVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                            <Setter TargetName="ChevronPath" Property="Data" Value="{StaticResource IconChevronLeft}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DataContext.IsNavigationVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                            <Setter TargetName="ChevronPath" Property="Data" Value="{StaticResource IconChevronRight}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                            <Setter TargetName="ChevronPath" Property="Stroke" Value="#333333"/>
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </Button.ContentTemplate>
                                        </Button>
                                        <Button Command="{Binding CopyCompiledTextCommand}" Style="{StaticResource ActionBtnStyle}" ToolTip="复制最终结果 (Ctrl+C)">
                                            <Button.ContentTemplate>
                                                <DataTemplate>
                                                    <Path Data="{StaticResource IconCopyThin}">
                                                        <Path.Style>
                                                            <Style TargetType="Path" BasedOn="{StaticResource SmallHeaderIconStyle}"/>
                                                        </Path.Style>
                                                    </Path>
                                                </DataTemplate>
                                            </Button.ContentTemplate>
                                        </Button>
                                        <Button Command="{Binding ToggleEditModeCommand}" Style="{StaticResource ActionBtnStyle}">
                                            <Button.ToolTip>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                    <Setter Property="Text" Value="点击锁定并保存"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                                    <Setter Property="Text" Value="点击解锁编辑"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button.ToolTip>
                                            <Button.ContentTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Path Data="{StaticResource IconLockOpenThin}">
                                                            <Path.Style>
                                                                <Style TargetType="Path" BasedOn="{StaticResource SmallHeaderIconStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                        <Path Data="{StaticResource IconLockClosedThin}">
                                                            <Path.Style>
                                                                <Style TargetType="Path" BasedOn="{StaticResource SmallHeaderIconStyle}">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Grid>
                                                </DataTemplate>
                                            </Button.ContentTemplate>
                                        </Button>

                                    </StackPanel>
                                </Grid>

                                <TextBox Grid.Row="1" Text="{Binding SelectedFile.Content, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" BorderThickness="0" Background="Transparent" FontSize="14" Padding="5" FontFamily="Segoe UI, Microsoft YaHei UI" PreviewKeyDown="TextBox_PreviewKeyDown">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <md:MarkdownViewer Grid.Row="1" 
                   Markdown="{Binding SelectedFile.Content}" 
                   xml:lang="zh-CN">
                                    <md:MarkdownViewer.Style>
                                        <Style TargetType="md:MarkdownViewer">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <!-- 将 Margin 设为 0，因为 GitHub 主题内部已经定义了 PagePadding (内边距) -->
                                            <Setter Property="Margin" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </md:MarkdownViewer.Style>
                                    <!-- 此处移除了 <md:MarkdownViewer.Resources> 块，从而自动应用全局 GitHub 主题 -->
                                </md:MarkdownViewer>
                            </Grid>

                            <Border Grid.Row="1" Height="1" Background="#E0E0E0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent" ResizeBehavior="PreviousAndNext" ShowsPreview="True"/>

                            <Grid Grid.Row="2" Margin="20,10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" BorderThickness="0">
                                    <ScrollViewer.Style>
                                        <Style TargetType="ScrollViewer">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasVariables}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Style>
                                    <ItemsControl ItemsSource="{Binding Variables}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Label"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Name, StringFormat='{}{0}:'}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Top" Margin="0,6,10,0" HorizontalAlignment="Right" Foreground="#333333" FontFamily="Segoe UI, Microsoft YaHei UI"/>
                                                    <Border x:Name="InputBorder" Grid.Column="1" BorderThickness="0" Background="Transparent" CornerRadius="2,2,0,0">
                                                        <TextBox x:Name="InputBox" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Padding="5" FontSize="14" VerticalContentAlignment="Top" AcceptsReturn="True" TextWrapping="Wrap" PreviewKeyDown="TextBox_PreviewKeyDown" Foreground="#333333" FontFamily="Segoe UI, Microsoft YaHei UI" Style="{x:Null}"/>
                                                    </Border>
