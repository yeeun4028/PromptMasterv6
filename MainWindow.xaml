                                        <TextBlock Text="API Key" Foreground="#666" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding Config.AiApiKey}" Padding="5" Margin="0,0,0,10" Background="#F5F5F5" BorderThickness="0"/>

