                                        <TextBlock Text="默认使用AI" Foreground="#333" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                        <Border Background="#F9F9F9" CornerRadius="4" Padding="15" Margin="0,0,0,20">
