                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.ColumnSpan="3" Background="#7F000000" Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVis}}">
